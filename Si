public void RevisionEstOrdenesDePago(String numProcesoPago,
                                     String cantidadPagos,
                                     String convenioPago) throws Exception {

    click(By.xpath("//*[@id=\"formMenu:consultas\"]"));
    click(By.xpath("//*[@id=\"formMenu:conEstadosPago\"]"));

    waitForElement(this.btnBuscarEstadoProceso, TIMEOUT_MEDIO);

    Util.wait(3);

    Evidence.save("Ventana Estado de Pago", this);

    Reporter.write("*** WARNING ------ **************ESTADO DE LA ORDEN DE PAGO****************");

    int totalPagos = Integer.parseInt(cantidadPagos);

    for (int i = 1; i <= totalPagos; i++) {

        Reporter.write("*** WARNING ------ --------FILA " + i + "----------");

        String[] datosExcel = ExtraerDatosDe2doExcel(i + 1);

        click(this.btnBuscarEstadoProceso);

        String xpathFilaBase = this.xpathNumEstadoPago
                .replace("NUM_PROCESO_PAGO", numProcesoPago)
                + "[" + i + "]";

        esperarFilaEstado(xpathFilaBase);

        validarRegistroEstadoPago(
                xpathFilaBase,
                numProcesoPago,
                convenioPago,
                datosExcel
        );
    }

    Evidence.save("Registro Estado de Pago encontrado", this);
}

private void esperarFilaEstado(String xpathFilaBase) throws Exception {

    int contador = 0;
    int reintentos = 0;

    while (!isDisplayed(By.xpath(xpathFilaBase))
            && reintentos < 4) {

        Util.wait(1);
        contador++;

        if (contador >= 10) {

            click(this.btnBuscarEstadoProceso);

            contador = 0;
            reintentos++;
        }
    }

    if (!isDisplayed(By.xpath(xpathFilaBase))) {

        Reporter.write(
                "No se encontró el registro esperado en Estado de Pago"
        );

        SettingsRun.exitTestIteration();
    }
}

private void validarRegistroEstadoPago(String xpathFilaBase,
                                       String numProcesoPago,
                                       String convenioPago,
                                       String[] datosExcel) throws Exception {

    validarCampo(
            xpathFilaBase.replace("td[2]", "td[2]"),
            numProcesoPago,
            "Número de proceso"
    );

    validarCampo(
            xpathFilaBase.replace("td[2]", "td[3]"),
            datosExcel[1],
            "ID Beneficiario"
    );

    validarCampo(
            xpathFilaBase.replace("td[2]", "td[4]"),
            datosExcel[2],
            "Beneficiario"
    );

    validarCampo(
            xpathFilaBase.replace("td[2]", "td[6]"),
            "PAGO NACIONAL",
            "Destino"
    );

    validarCampoContiene(
            xpathFilaBase.replace("td[2]", "td[7]"),
            convenioPago,
            "Convenio"
    );

    validarValorPago(
            xpathFilaBase.replace("td[2]", "td[8]"),
            datosExcel[8]
    );
}

private void validarValorPago(String xpath,
                              String valorEsperado) throws Exception {

    String valorPortal = getText(element(xpath))
            .replace("$", "")
            .replace(",", "")
            .replace(".", "");

    if (valorPortal.contains(valorEsperado)) {

        Reporter.write("*** PASSED :: Valor correcto");
        Reporter.write("*** PASSED ------ " + valorPortal);

    } else {

        Reporter.write("*** FAIL :: Valor incorrecto");
        Reporter.write("*** FAIL ------ " + valorPortal);
        Reporter.write("*** FAIL ------ " + valorEsperado);
    }
}
