import java.util.ArrayList;
import java.util.List;
import java.util.Map;

import javax.swing.JOptionPane;

import org.openqa.selenium.By;
import org.openqa.selenium.WebDriver;
import org.openqa.selenium.WebElement;

import ControllerPyme.ControllerTestLoginPyme;
import dav.library.common.NotificacionSMS;
import library.catalogue.ProjectUrls;
import library.common.Util;
import library.core.BasePageWeb;
import library.reporting.Evidence;
import library.reporting.Reporter;
import library.settings.SettingsRun;

public class PageLoginPymesSp extends BasePageWeb {

    // ── Constantes públicas ────────────────────────────────────────────────────

    public static final String PORTAL_FRONT_PYME = "PYMES";
    public static final String TOKEN_ESTATIC  = "ESTATICO";
    public static final String TOKEN_FISICO   = "FISICO";
    public static final String TOKEN_OTP      = "OTP";
    public static final String TOKEN_VIRTUAL  = "VIRTUAL";
    public static final String CRRA_SESION    = "//*[contains(@id,'Sesion')]";
    public static String       LAST_TOKEN;

    // ── Constantes privadas ────────────────────────────────────────────────────

    private static final String SCRIPT_RELOAD_PAGE = "window.location.reload(true);";

    // Locators fijos
    private static final By LOC_ACCESS_DENIED   = By.xpath("//h1[@class='center']");
    private static final By LOC_CAPTCHA_ANCHOR  = By.xpath("//span[@id='recaptcha-anchor']");
    private static final By LOC_BTN_INGRESAR    = By.xpath("//input[@value='Ingresar']");
    private static final By LOC_BTN_CERRAR_MODAL= By.xpath("//a[@class='boldcn' and @aria-label='Close']");
    private static final By LOC_MAIN_IFRAME     = By.id("main-iframe");
    private static final By LOC_BTN_VALIDAR     = By.xpath("//input[@value='Validar Contraseña Nueva']");
    private static final By LOC_BTN_CONFIRMAR   = By.xpath("//input[@value='Confirmar']");

    // Fragmentos XPath reutilizables
    private static final String XP_TIPO_ID   = "//div[@id='divTipoIdentificacion']";
    private static final String XP_NUM_DOCU  = "//div[@id='divNumeroDocumento']";
    private static final String XP_CLAVE_PV  = "//div[@id='divClavePersonal']";
    private static final String XP_NUM_TOK   = "//div[@id='divClaveToken']";
    private static final String XP_CLIENTE   = "//div[@id='divNumerClienteEmpresarial']";
    private static final String XP_TEXT      = "//input[@type='text']";
    private static final String XP_PASS      = "//input[@type='password']";
    private static final String XP_SELECT    = "//select";
    private static final String XP_CLAVE_ANT = "//div[@id='divClaveAnterior']//input[@filtertype]";
    private static final String XP_CLAVE_NEW = "//div[@id='divClaveNueva']//input[@filtertype]";
    private static final String XP_CLAVE_CNF = "//div[@id='divClaveNuevaConfirmar']//input[@filtertype]";
    private static final String XP_OTP_LABEL = "//*[contains(text(),'código de confirmación')]";
    private static final String XP_OTP_INPUT = "//div[@id='DivOtp']//input[@filtertype]";

    // Mapeo de ambientes
    private static final Map<String, String> AMBIENTES = Map.of(
        "1", "POST_NUBE",        "POST_NUBE",       "POST_NUBE",
        "2", "CONTENCION_NUBE",  "CONTENCION_NUBE", "CONTENCION_NUBE",
        "3", "PROYECTOS_NUBE",   "PROYECTOS_NUBE",  "PROYECTOS_NUBE",
        "4", "PROYECTOS_SO",     "PROYECTOS_SO",    "PROYECTOS_SO",
        "5", "POST_SO",          "POST_SO",         "POST_SO",
        "6", "CONT_SO",          "CONT_SO",         "CONT_SO"
    );

    // ── Estado de sesión ───────────────────────────────────────────────────────

    private ProjectUrls projectUrls;
    private String      ambienteName;
    private String      currentPortal;

    // Datos de login (se cargan en iniciarSesionDriver)
    private static String loginType;
    private static String clientNumber;
    private static String docType;
    private static String docNumber;
    private static String password;
    private static String tokenType;
    private static String tokenValue;

    // ── Constructores ──────────────────────────────────────────────────────────

    public PageLoginPymesSp(String browser) {
        super(browser);
    }

    public PageLoginPymesSp(BasePageWeb parentPage) {
        super(parentPage);
    }

    // ── API pública ────────────────────────────────────────────────────────────

    public void iniciarSesionDriver() throws Exception {
        ambienteName  = resolveAmbiente();
        currentPortal = PORTAL_FRONT_PYME;

        String[] loginData = ControllerTestLoginPyme.getLoginData();
        loginType    = safeGet(loginData, 3);
        clientNumber = safeGet(loginData, 4);
        docType      = safeGet(loginData, 5);
        docNumber    = safeGet(loginData, 6);
        password     = safeGet(loginData, 7);
        tokenType    = safeGet(loginData, 8).toUpperCase();
        tokenValue   = safeGet(loginData, 9);

        projectUrls = new ProjectUrls();
        String url  = projectUrls.getSiteUrl(ambienteName, "PYMES FRONT");

        maximizeBrowser();
        navigate(url);
        handleCaptchaIfPresent();
    }

    public void loginFront() throws Exception {
        int maxRetries = 3;

        while (maxRetries-- > 0) {
            String alert = fillInitialLoginData(clientNumber, docType, docNumber);
            handleCaptchaIfPresent();

            if (alert == null) {
                fillPasswordAndToken();
                return;
            }

            if (alert.contains("ha expirado")) {
                changeExpiredPassword();
                return;
            }

            String alertUpper = alert.toUpperCase();
            boolean shouldRetry = alertUpper.contains("INGRESE")
                               || alertUpper.contains("POR FAVOR INGRESE LOS DATOS");

            if (!shouldRetry) {
                Reporter.reportEvent(Reporter.MIC_HEADER, "Resultado login: " + alert);
                return;
            }
        }
    }

    public void cambiarClaveVirtual() throws Exception {
        waitElements(5, element(By.xpath(XP_CLAVE_ANT)));

        write(By.xpath(XP_CLAVE_ANT), password);
        Util.presionarTecla("TAB");

        write(By.xpath(XP_CLAVE_NEW), tokenValue);
        Util.presionarTecla("TAB");

        write(By.xpath(XP_CLAVE_CNF), tokenValue);
        Util.presionarTecla("TAB");

        Util.wait(3);
        click(LOC_BTN_VALIDAR);

        Util.wait(1);
        waitElements(8, element(By.xpath(XP_OTP_LABEL)));

        NotificacionSMS.loadHour();
        NotificacionSMS.loadTipoNotificacion(NotificacionSMS.TIPO_NOTIF_PYME_OBLIGATORIO);
        String otp = NotificacionSMS.consultarOTP("", 3);

        Util.wait(1);
        Util.presionarTecla("TAB");
        write(By.xpath(XP_OTP_INPUT), otp);
        scrollDown(1);

        Util.wait(1);
        click(LOC_BTN_CONFIRMAR);
        Util.wait(1);
    }

    public void handleCaptchaIfPresent() {
        try {
            Util.wait(5);

            WebElement mainFrame = element(LOC_MAIN_IFRAME);
            if (mainFrame == null) return;

            getDriver().switchTo().frame(mainFrame);
            if (element(LOC_ACCESS_DENIED) == null) return;

            Util.wait(3);

            WebElement challengeFrame = element(By.xpath("//div[contains(@class,'modal')]//iframe"));
            if (challengeFrame == null) return;

            getDriver().switchTo().frame(challengeFrame);
            if (element(LOC_CAPTCHA_ANCHOR) == null) return;

            click(LOC_CAPTCHA_ANCHOR);
            changeToDefaultFrame();
            getDriver().switchTo().frame(mainFrame);

            Util.wait(4);

            WebElement captchaFrame = element(By.xpath("//iframe[contains(@src,'recaptcha')]"));
            if (captchaFrame == null) return;

            getDriver().switchTo().frame(captchaFrame);
            getJse().executeScript(
                "var b = document.querySelector('#recaptcha-reload-button'); if (b) b.click();"
            );

            Util.wait(2);

            WebElement helpButton = element(
                "//div[contains(@class,'button-holder') and contains(@class,'help-button-holder')]"
            );
            if (helpButton != null) {
                mouseOver(helpButton);
                mouseClick();
            }

        } finally {
            changeToDefaultFrame();
        }
    }

    public String getMsgAlertIfExist(String... alertIds) {
        for (String id : alertIds) {
            By locator = By.id(id);
            if (!isDisplayed(locator)) continue;

            String msg = getText(locator);
            if (msg != null) msg = msg.trim();

            if (msg != null && !msg.isEmpty()) return msg;
        }
        return null;
    }

    public static String solicitarDato(String mensaje) {
        String valor;
        do {
            valor = JOptionPane.showInputDialog(null, mensaje, "Ingreso de Datos",
                                                JOptionPane.INFORMATION_MESSAGE);
            if (valor == null || valor.trim().isEmpty()) {
                JOptionPane.showMessageDialog(null, "Debe ingresar un valor para continuar.",
                                              "Dato requerido", JOptionPane.WARNING_MESSAGE);
            }
        } while (valor == null || valor.trim().isEmpty());

        return valor.trim();
    }

    // ── Métodos privados ───────────────────────────────────────────────────────

    private String resolveAmbiente() {
        String codigo = SettingsRun.getGlobalData("AMBIENTE_PYME");
        String nombre = (codigo != null)
            ? AMBIENTES.getOrDefault(codigo.trim().toUpperCase(), "")
            : "";

        int level = nombre.isEmpty() ? Reporter.MIC_FAIL : Reporter.MIC_HEADER;
        Reporter.reportEvent(level, "Nombre del ambiente seleccionado: Portal - " + nombre);
        return nombre;
    }

    private String fillInitialLoginData(String clientNum, String docType, String docNumber)
            throws Exception {

        Evidence.save("LoginFront", this);
        waitElements(15, element(XP_NUM_DOCU));

        getJse().executeScript(SCRIPT_RELOAD_PAGE);
        Util.wait(1);

        waitElements(10, element(XP_CLIENTE));
        write(element(By.xpath(XP_CLIENTE + XP_TEXT)), clientNum);

        String selectError = selectListItem(element(By.xpath(XP_TIPO_ID + XP_SELECT)), docType);
        if (selectError != null && !selectError.trim().isEmpty()) {
            closeAllBrowsers();
            Reporter.writeErr("No se encuentra el tipo de documento: " + selectError, true);
            return selectError;
        }

        write(element(By.xpath(XP_NUM_DOCU + XP_TEXT)), docNumber);
        Util.presionarTecla("TAB");

        if (isDisplayed(element(By.xpath(XP_CLAVE_PV)))) return null;

        click(LOC_BTN_INGRESAR);
        Evidence.save("Datos Iniciales", this);

        return waitForPasswordFieldOrAlert();
    }

    private String waitForPasswordFieldOrAlert() {
        int attempts = 15;
        while (attempts-- > 0) {
            if (isDisplayed(element(By.xpath(XP_CLAVE_PV)))) return null;

            String alert = getMsgAlertIfExist("LbMensaje", "mensajeModal");
            if (alert != null) {
                Evidence.save("ErrorData", this);
                if (isDisplayed(LOC_BTN_CERRAR_MODAL)) click(LOC_BTN_CERRAR_MODAL);
                return alert;
            }

            Util.wait(1);
        }
        return null;
    }

    private String fillPasswordAndToken() throws Exception {
        waitElements(5, element(By.xpath(XP_CLAVE_PV)));
        write(By.xpath(XP_CLAVE_PV + "//input[1]"), password);
        Util.wait(1);
        Util.presionarTecla("TAB");

        fillTokenField();

        Util.wait(3);
        click(LOC_BTN_INGRESAR);

        String alert = getText(By.id("LbMensaje"));
        boolean enteredPortal;

        if (alert == null) {
            enteredPortal = switchToPortalWindow();
            alert = getMsgAlertIfExist("LbMensaje", "lblMasterAlerta", "mensajeModal");
        } else {
            enteredPortal = false;
        }

        Util.wait(1);
        reportLoginResult(enteredPortal, alert);
        closeSessionIfOpen(enteredPortal);
        return null;
    }

    private void fillTokenField() {
        if (TOKEN_ESTATIC.equals(tokenType)) {
            write(By.xpath(XP_NUM_TOK + "//input[1]"), tokenValue);
            return;
        }
        if (TOKEN_FISICO.equals(tokenType)) {
            String value = "Fallida".equals(loginType) ? "123456" : solicitarDato("Ingresar clave fisica");
            Util.wait(2);
            write(By.xpath(XP_NUM_TOK + "//input[1]"), value);
        }
    }

    private void reportLoginResult(boolean enteredPortal, String alert) {
        boolean isSuccessTest = "Exitosa".equals(loginType);
        boolean passed        = isSuccessTest == enteredPortal;

        String evidence = buildEvidenceMessage(isSuccessTest, enteredPortal);
        Evidence.save(evidence, this);
        Reporter.reportEvent(passed ? Reporter.MIC_PASS : Reporter.MIC_FAIL, evidence);

        if (alert != null && !enteredPortal) {
            Reporter.reportEvent(Reporter.MIC_INFO, alert);
        }
    }

    private String buildEvidenceMessage(boolean isSuccessTest, boolean enteredPortal) {
        if (isSuccessTest) {
            return enteredPortal
                ? "Ingreso al portal, en una prueba exitosa."
                : "No ingreso al portal, en una prueba exitosa.";
        } else {
            return enteredPortal
                ? "Ingreso al portal, en una prueba de falla."
                : "No ingreso al portal, en una prueba de falla.";
        }
    }

    private void closeSessionIfOpen(boolean enteredPortal) {
        if (!enteredPortal) return;
        waitElements(5, element(CRRA_SESION));
        mouseClick(element(CRRA_SESION));
    }

    private void changeExpiredPassword() throws Exception {
        cambiarClaveVirtual();
    }

    private boolean switchToPortalWindow() {
        WebDriver driver = getDriver();
        List<String> windows = new ArrayList<>(driver.getWindowHandles());
        String targetWindow = null;

        for (String handle : windows) {
            try {
                driver.switchTo().window(handle);
                Reporter.write("Ventana: " + handle);

                boolean hasWelcomeBanner = !driver
                    .findElements(By.xpath("//*[contains(text(),'ingresado al Portal Pyme')]"))
                    .isEmpty();

                boolean hasCloseSession = !driver
                    .findElements(By.xpath(CRRA_SESION))
                    .isEmpty();

                if (!hasWelcomeBanner && hasCloseSession) {
                    targetWindow = handle;
                }
            } catch (Exception ignored) {}
        }

        if (targetWindow == null) {
            Util.wait(2);
            return false;
        }

        for (String handle : windows) {
            if (!handle.equals(targetWindow)) {
                try {
                    driver.switchTo().window(handle);
                    driver.close();
                } catch (Exception ignored) {}
            }
        }

        try {
            driver.switchTo().window(targetWindow);
            driver.switchTo().defaultContent();
            Reporter.write("Ventana correcta encontrada y demás ventanas cerradas.");
            return true;
        } catch (Exception e) {
            return false;
        }
    }

    private static String safeGet(String[] values, int index) {
        if (values == null || index < 0 || index >= values.length || values[index] == null) {
            return "";
        }
        return values[index].trim();
    }
}
