private void ejecutarTransaccionSegunServicio(boolean guardarPrimero) throws Exception {

    String back = SettingsRun.getGlobalData("VALIDACION.BACK");

    if (SERVICIOS_NOMINA_PROVEEDORES.contains(servicio)) {
        controller.crearPagoNomina_Proveedores(guardarPrimero);
        return;
    }

    List<String> datos = null;

    switch (servicio) {

        case "Pago de Servicios":
        case "Servicios":
            controller.crearPagoServicios(guardarPrimero);
            return;

        case "Pagos Automaticos":
            controller.crearPagosAutomaticos(guardarPrimero);
            return;

        case "Transferencias Mismo NIT":
        case "Transferencia NIT Propio":
        case "Mismo NIT":
            datos = controller.crearTranferenciaMismoNit(guardarPrimero);
            break;

        case "Transferencias Cuenta Inscrita":
        case "Cuenta Inscrita":
            datos = controller.crearTransferenciaCtaInscrita(guardarPrimero);
            break;

        case "Transferencias Cuenta No Inscrita":
        case "Transferencias Cuenta NO Inscrita":
        case "Cuenta No Inscrita":
            datos = controller.crearTransferenciaCtaNoInscrita(guardarPrimero);
            break;

        case "ORPA":
            controller.OrdenesDePago();
            return;

        case "Pagos Propios":
            controller.crearPagosPropios(guardarPrimero);
            return;

        case "Avances Tarjeta de Crédito":
        case "Avance TC":

            datos = controller.crearAvanceTC(guardarPrimero);

            if (back.contains("SI")) {
                procesarBackAvanceTC(datos);
            }

            return;

        case "Tx Internacionales Recibir desde el exterior":
            controller.Recibirdinerodelexterior(guardarPrimero);
            return;

        case "Tx Internacionales Enviar al exterior":
            controller.EnviarTransferenciasInternacionales(guardarPrimero);
            return;

        case "Tx Internacionales Enviar al exterior Pendiente Aprobación":
            controller.inicioCrearTx();
            controller.EnviarTransferenciasInternacionalesPendAprobacion();
            return;

        case "Divisas Documentos y Formularios":
            flujoDivisasDocumentosYFormularios(guardarPrimero);
            return;

        case "Consulta Tx Internacionales Validar Estado":
            ejecutarConsultaValidarEstado();
            return;
    }

    if (datos != null && back.contains("SI")) {
        registrarBackSAF(datos);
    }
}

private void registrarBackSAF(List<String> datos) throws Exception {

    String tipFIC = SettingsRun.getTestData()
            .getParameter("Tipo producto origen / Franquicia")
            .trim();

    String numFIC = obtenerNumeroFicCompleto(tipFIC);

    Date fechaTx = obtenerFechaTx(datos);

    double valorTxD = Double.parseDouble(valorTx);

    DataSheetBack.TO_MAIL = SettingsRun.getGlobalData("SAF.correoDataBack");

    new DataSheetBackSAF().setRegistro(
            servicio,
            tipoDoc,
            numDoc,
            numFIC,
            valorTxD,
            fechaTx,
            ""
    );
}

private void procesarBackAvanceTC(List<String> datos) throws Exception {

    String tipo = datos.get(0);

    String tipFIC = SettingsRun.getTestData()
            .getParameter("Tipo producto origen / Franquicia")
            .trim();

    String numFIC = SettingsRun.getTestData()
            .getParameter("Número producto origen")
            .trim();

    Date fechaTx = obtenerFechaTx(datos);

    String fecha = datos.get(1);

    Date fechaT = new SimpleDateFormat("dd/MM/yyyy")
            .parse(fecha);

    if (numFIC.length() <= 4) {

        String[] datosTitular = {
                tipoIDEmpresa,
                numeroIDEmpresa
        };

        instanciaStratus = LoginStratus();

        instanciaStratus.getDatosPantallaSaldos(
                tipoIDEmpresa,
                numeroIDEmpresa,
                tipo,
                numFIC
        );

        numFIC = instanciaStratus.getNumProdCompleto();

        String[] arrayVents = {
                MovimientoStratus.VENT_INDIC
        };

        List<MovimientoStratus> movimientos =
                instanciaStratus.getMovimientosEnRango(
                        "TARJETA_CREDITO",
                        numFIC,
                        arrayVents,
                        fechaT,
                        1,
                        datosTitular
                );

        String talon = obtenerTalonMovimiento(movimientos);

        Reporter.reportEvent(
                Reporter.MIC_INFO,
                "Talon encontrado: " + talon
        );

        // Si luego quieres usarlo:
        // DataSheetBackFACT.setRegistro(... talon ...)
    }

    double valorTxD = Double.parseDouble(valorTx);

    DataSheetBack.TO_MAIL = SettingsRun.getGlobalData("SAF.correoDataBack");

    new DataSheetBackSAF().setRegistro(
            servicio,
            tipoDoc,
            numDoc,
            numFIC,
            valorTxD,
            fechaTx,
            ""
    );
}

private String obtenerNumeroFicCompleto(String tipFIC) throws Exception {

    String numFIC = SettingsRun.getTestData()
            .getParameter("Número producto origen")
            .trim();

    if (numFIC.length() > 4) {
        return numFIC;
    }

    instanciaStratus = LoginStratus();

    instanciaStratus.getDatosPantallaSaldos(
            tipoIDEmpresa,
            numeroIDEmpresa,
            tipFIC,
            numFIC
    );

    return instanciaStratus.getNumProdCompleto();
}

private Date obtenerFechaTx(List<String> datos) throws Exception {

    String fechaHora = datos.get(1) + " - " + datos.get(2);

    return new SimpleDateFormat("dd/MM/yyyy - HH:mm")
            .parse(fechaHora);
}

private String obtenerTalonMovimiento(List<MovimientoStratus> movimientos) {

    if (movimientos == null || movimientos.isEmpty()) {
        return "";
    }

    for (MovimientoStratus movimiento : movimientos) {

        String raw = movimiento.toString();

        raw = raw.replace("[INDIC: ", "")
                 .replace("]", "")
                 .trim();

        String[] partes = raw.split("\\|");

        if (partes.length >= 4) {
            return partes[3].trim();
        }
    }

    return "";
}
