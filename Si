private String ingresarClaveTokenFornt(String clave,
                                       String tipoTok,
                                       String condicion) throws Exception {

    final String SCRIPT_RELOAD = "window.location.reload(true);";

    waitElements(15, this.element(cmClavePV));

    this.getJse().executeScript(SCRIPT_RELOAD);

    while (!this.isDisplayed(this.element(cmClavePV))) {
        Util.wait(1);
        this.existDialogAccept();
    }

    WebElement campoFocus = this.element(cmNumTok);

    if (campoFocus != null) {
        this.focus(campoFocus);
    } else {
        this.focus(this.element(cmClavePV));
    }

    waitElements(10, this.element(cmClavePV + cmTexto + "[1]"));

    this.write(
            this.element(cmClavePV + cmTexto + "[1]"),
            clave);

    Evidence.save("Ingreso pass", this);

    // Token físico / dinámico
    if (!DatosEmpresarial.TOKEN_OTP.equals(tipoTok)) {

        String valToken =
                DatosEmpresarial.getArrayToken(condicion)[0];

        this.write(
                this.element(cmNumTok + cmTexto + "[1]"),
                valToken);
    }

    // Click Ingresar
    try {

        this.moveToElement(cmBtIngr);

        this.fechaHoraLogMR = new Date();

        this.clickNoScrollIntoView(cmBtIngr);

    } catch (ElementClickInterceptedException e) {

        this.closePopupSnippetCliente();

        this.fechaHoraLogMR = new Date();

        this.click(cmBtIngr);
    }

    String msgAlerta = this.getText(By.id("LbMensaje"));
    String entroPortal = null;

    int timeout = 20;

    while (timeout-- > 0 && entroPortal == null && msgAlerta == null) {

        try {

            entroPortal = this.accedioAlPortal();

            msgAlerta = this.getMsgAlertIfExist(
                    "LbMensaje",
                    "lblMasterAlerta",
                    "mensajeModal");

        } catch (Exception e) {

            entroPortal = null;
            msgAlerta = null;
        }

        if (entroPortal == null && msgAlerta == null) {
            Util.wait(1);
        }
    }

    if (msgAlerta != null) {

        String evidencia =
                (entroPortal != null)
                        ? "MsgPopup"
                        : "ErrorLogueo";

        Evidence.save(evidencia, this);

        if (this.isDisplayed(cmBtAcept)) {
            this.click(cmBtAcept);
        }
    }

    return msgAlerta;
}
