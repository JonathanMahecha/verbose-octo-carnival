	// ============================================================
	// AMBIENTE – mapeo por tipo de portal (patrón nuevo framework)
	// ============================================================

	private void normalizarAmbiente(String codigoAmbiente) {
		String normalizado = mapearAmbiente(codigoAmbiente);

		if (normalizado.isEmpty()) {
			Reporter.reportEvent(Reporter.MIC_WARNING,
					"No se pudo normalizar ambiente: " + codigoAmbiente);
			return;
		}

		Reporter.reportEvent(Reporter.MIC_HEADER, "Ambiente seleccionado: " + normalizado);
		DatosEmpresarial.AMBIENTE_TEST = normalizado;
	}

	private String mapearAmbiente(String codigo) {
		if (codigo == null || codigo.trim().isEmpty()) return "";
		codigo = codigo.trim().toUpperCase();

		switch (portalType) {
			case PYME:
				switch (codigo) {
					case "1": case "POST_NUBE":        return "POST_NUBE";
					case "2": case "CONTENCION_NUBE":  return "CONTENCION_NUBE";
					case "3": case "PROYECTOS_NUBE":   return "PROYECTOS_NUBE";
					case "4": case "PROYECTOS_SO":     return "PROYECTOS_SO";
					case "5": case "POST_SO":          return "POST_SO";
				}
				break;
			case EMPRESARIAL:
				switch (codigo) {
					case "1": case "POST_NUBE":        return "POST_NUBE";
					case "2": case "CONTENCION_NUBE":  return "CONTENCION_NUBE";
					case "3": case "PROYECTOS_NUBE":   return "PROYECTOS_NUBE";
					case "4": case "PROYECTOS_SO":     return "PROYECTOS_SO";
					case "5": case "POST_SO":          return "POST_SO";
				}
				break;
		}
		return "";
	}

