	/**
	 * Valida los campos de Referencia y Descripción en el detalle de una Transferencia del Portal.
	 */
	public void TransferenciaPortalDetalleReferencia(String detalleVacio) throws Exception {
		String dataDescripcion = SettingsRun.getTestData().getParameter("Descripcion").trim();
		String dataReferencia  = SettingsRun.getTestData().getParameter("Referencia").trim();
		Evidence.saveAllScreens("3", this);

		String referencia;
		String detalle;

		// BUG CORREGIDO: string truncado "Pago de N" → "Pago de Nomina"
		if (detalleVacio.equals("Pago de Nomina") || detalleVacio.equals("Pago a Proveedores")) {
			referencia = element(By.xpath("//*[@id=\"cphCuerpo_lblEjecutadoReferencia\"]")).getText();
			detalle    = element(By.xpath("//*[@id=\"cphCuerpo_lblEjecutadoDescripcion\"]")).getText();
		} else {
			referencia = element(By.xpath("//*[@id=\"cphCuerpo_lblERReferencia\"]")).getText();
			detalle    = element(By.xpath("//*[@id=\"cphCuerpo_lblERDescripcion\"]")).getText();
		}

		reportarCampoAdenda("Descripcion", detalle,    dataDescripcion, detalleVacio);
		reportarCampoAdenda("Referencia",  referencia, dataReferencia, "000000000000000000000000");
	}

	/**
	 * Valida los campos de Referencia y Descripción en una Nota de Débito.
	 */
	public void NotaDebitoDetalleReferencia(String detalleVacio) throws Exception {
		String dataDescripcion = SettingsRun.getTestData().getParameter("Descripcion").trim();
		String dataReferencia  = SettingsRun.getTestData().getParameter("Referencia").trim();
		Evidence.saveAllScreens("2", this);
		Util.wait(5);

		String detalle    = null;
		String referencia = null;

		try {
			detalle    = element(By.xpath("//*[@id=\"cphCuerpo_lblCDDetalle\"]")).getText();
			referencia = element(By.xpath("//*[@id=\"cphCuerpo_lblCDReferencia\"]")).getText();
		} catch (Exception e) {
			// BUG CORREGIDO: bucle infinito en catch eliminado — se reporta y se sale
			Reporter.reportEvent(1, "No se encuentra el elemento de detalle/referencia en Nota Debito");
			return;
		}

		reportarCampoAdenda("Descripcion", detalle,    dataDescripcion, detalleVacio);
		reportarCampoAdenda("Referencia",  referencia, dataReferencia, "000000000000000000000000");
	}

	/**
	 * Revisa los datos de una Orden de Pago (proceso) contra los valores esperados.
	 */
	public void RevisionProOrdenesDePago(String numPocesoPago, String nomProcesoPago,
			String cantidaPagos, String valorPagos, String convenioPago) throws Exception {

		Date fecha      = new Date();
