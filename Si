	/**
	 * Resuelve el texto de tipo de producto usado en XPath para seleccionarOrigen.
	 * BUG CORREGIDO: código duplicado entre seleccionarOrigen y seleccionarOrigenAutomatico
	 * extraído a método privado.
	 */
	private String resolverTipoProd(String tipoProductoUpper) {
		if (tipoProductoUpper.contains("AHORROS") || tipoProductoUpper.contains("ahorros"))
			return "ahorro";
		if (tipoProductoUpper.contains("CORRIENTE") || tipoProductoUpper.contains("corriente"))
			return "corriente";
		if (tipoProductoUpper.contains("DIPLUS") || tipoProductoUpper.contains("diplus"))
			return "diplus";
		if (tipoProductoUpper.contains("EXPRES") || tipoProductoUpper.contains("rediexpress")) {
			if (tipoProductoUpper.contains("rediexpress") && tipoProductoUpper.contains("ompanita"))
				return "ompanita";
			if (tipoProductoUpper.contains("rediexpress") && tipoProductoUpper.contains("emp pyme 22"))
				return "emp pyme 22";
			return "rediexpress";
		}
		if (tipoProductoUpper.contains("Agropecuaria")) return "Tarjetas Agropecuaria";
		if (tipoProductoUpper.contains("agropecuaria")) return "Tarjetas agropecuaria";
		if (tipoProductoUpper.contains("DINERS"))       return "Tarjeta Diners Empresarial";
		if (tipoProductoUpper.contains("ClMastercard") || tipoProductoUpper.contains("clmastercard")
				|| tipoProductoUpper.contains("Clasica Mastercard")
				|| tipoProductoUpper.contains("clasica mastercard"))
			return "ClMastercard";
		if (tipoProductoUpper.contains("MASTERCARD") || tipoProductoUpper.contains("mastercard"))
			return "Empresarial mastercard";
		if (tipoProductoUpper.contains("visa"))
			return "Empresarial visa";
		if (tipoProductoUpper.contains("FAMILIARES") || tipoProductoUpper.contains("familiares")
				|| tipoProductoUpper.contains("Familiares"))
			return "Tarjeta Credito Sociedades Familiares";
		if (tipoProductoUpper.contains("Garantizada Platinum Visa"))
			return "Garantizada Platinum Visa";
		if (tipoProductoUpper.contains("Tarjeta Visa Signature"))
			return "Tarjeta Visa Signature";
		return " ";
	}

	/** Variante para flujo automático (difiere en "Familiares" y default). */
	private String resolverTipoProdAutomatico(String tipoProductoUpper) {
		if (tipoProductoUpper.contains("FAMILIARES") || tipoProductoUpper.contains("familiares")
				|| tipoProductoUpper.contains("Familiares"))
			return "Tarjeta crsociedades familiares";
		return resolverTipoProd(tipoProductoUpper);
	}

	/** Variante para seleccionarCuenta (opera con tipo ya en mayúsculas). */
	private String resolverTipoProdCuenta(String tipoProdUpper) {
		if (tipoProdUpper.contains("AHORROS"))          return "AHORROS";
		if (tipoProdUpper.contains("DIPLUS"))           return "diplus";
		if (tipoProdUpper.contains("EXPRES"))           return "rediexpress";
		if (tipoProdUpper.contains("AGROPECUARIA"))     return "Tarjetas agropecuaria";
		if (tipoProdUpper.contains("DINERS"))           return "Tarjeta Diners Empresarial";
		if (tipoProdUpper.contains("MASTERCARD"))       return "Empresarial mastercard";
		if (tipoProdUpper.contains("VISA"))             return "Empresarial visa";
		if (tipoProdUpper.contains("FAMILIARES"))       return "Tarjeta crsociedades familiares";
		return "CORRIENTE";
	}

	/** Busca el radio button de un producto en la tabla de origen (flujo normal). */
	private WebElement buscarRadioButtonProducto(String tipoProductoUpper, String tipoProd,
			String numeroProducto) {

		if (!tipoProductoUpper.contains("FIC")) {
			String xPathRB = this.xPathRBOrigen
					.replace("NUM_PROD",  Util.right(numeroProducto, 4))
					.replace("TIPO_PROD", tipoProd);
			return element(xPathRB);
		}

		// Producto FIC: buscar el primero que no sea de tipo normal (AHORRO/CORRIENTE/etc.)
		String xPathRB = this.xPathRBOrigenFic.replace("NUM_PROD", Util.right(numeroProducto, 4));
		List<WebElement> listaObjs = findElements(By.xpath(xPathRB));
		for (WebElement elem : listaObjs) {
			String tipoProdTab = getText(element(elem, this.locTipoPruebaFic));
			if (!Util.itemContainsAnyArrayItem(tipoProdTab.toUpperCase(), this.arrTipoProdNoFic)) {
				return elem;
			}
		}
		return null;
	}

