	/**
	 * Espera hasta que el elemento esté presente en el DOM.
	 * Reemplaza los loops manuales con Util.wait() + element().
	 */
	private WebElement waitForPresence(By locator, int timeoutSeconds) {
		try {
			return new WebDriverWait(getDriver(), timeoutSeconds)
					.until(ExpectedConditions.presenceOfElementLocated(locator));
		} catch (Exception e) {
			return null;
		}
	}

	/**
	 * Espera hasta que el elemento sea visible en pantalla.
	 */
	private WebElement waitForVisible(By locator, int timeoutSeconds) {
		try {
			return new WebDriverWait(getDriver(), timeoutSeconds)
					.until(ExpectedConditions.visibilityOfElementLocated(locator));
		} catch (Exception e) {
			return null;
		}
	}

	/**
	 * Espera hasta que el elemento sea clickeable (visible + habilitado).
	 */
	private WebElement waitForClickable(By locator, int timeoutSeconds) {
		try {
			return new WebDriverWait(getDriver(), timeoutSeconds)
					.until(ExpectedConditions.elementToBeClickable(locator));
		} catch (Exception e) {
			return null;
		}
	}

	/**
	 * FluentWait: sondea cada POLL_INTERVAL_MS e ignora NoSuchElementException.
	 * Útil cuando el framework personalizado (this.element) debe ser el buscador.
	 */
	private WebElement fluentWaitForElement(By locator, int timeoutSeconds) {
		try {
			FluentWait<WebDriver> wait = new FluentWait<>(getDriver())
					.withTimeout(Duration.ofSeconds(timeoutSeconds))
					.pollingEvery(Duration.ofMillis(POLL_INTERVAL_MS))
					.ignoring(NoSuchElementException.class)
					.ignoring(org.openqa.selenium.StaleElementReferenceException.class);

			return wait.until(driver -> this.element(locator));
		} catch (Exception e) {
			return null;
		}
	}

	/**
	 * Espera a que this.element() retorne no-null usando FluentWait.
	 * Versión más corta para uso frecuente dentro de la clase.
	 */
	private WebElement waitElement(By locator, int timeoutSeconds) {
		return fluentWaitForElement(locator, timeoutSeconds);
	}

