public String seleccionarOrigen(String servicio,
                                String tipoDocumento,
                                String numeroDoc,
                                String tipoProducto,
                                String numeroProducto) throws Exception {

    WebElement pasoOrigen = waitForElement(this.locPasoPage, TIMEOUT_LARGO);

    if (pasoOrigen == null) {
        return "No se encontró la pantalla de origen";
    }

    Evidence.saveFullPage("Origen", this);

    WebElement radioProducto = buscarProductoOrigen(tipoProducto, numeroProducto, "1", false);

    if (radioProducto == null) {
        Evidence.saveFullPage("Error-ProdOrigen", this);
        return "Producto origen [" + tipoProducto + " - " + numeroProducto + "] NO encontrado";
    }

    if (!DatosDavivienda.IS_RISKMOTOR) {
        validacionSaldosStratus(
                servicio,
                tipoDocumento,
                numeroDoc,
                normalizarTipoProducto(tipoProducto, false),
                numeroProducto,
                true
        );
    }

    Util.wait(3);
    click(radioProducto);

    Evidence.saveFullPage("ProductoOrigen", this);

    Util.wait(3);
    click(this.locButtonSig);

    return null;
}

public String seleccionarOrigenAutomatico(String tipoProducto,
                                          String numeroProducto,
