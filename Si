public void siExisteVerificacionRobot() {

    Util.wait(7);

    WebElement mainFrame = this.element(By.id("main-iframe"));
    if (mainFrame == null) {
        return;
    }

    this.getDriver().switchTo().frame(mainFrame);

    if (this.element(accesDenegado) == null) {
        return;
    }

    Util.wait(5);

    WebElement challengeFrame = this.element(
            By.xpath("//div[contains(@class,'modal')]//iframe"));

    if (challengeFrame == null) {
        return;
    }

    this.getDriver().switchTo().frame(challengeFrame);

    if (this.element(imNOtaRobot) == null) {
        return;
    }

    this.click(imNOtaRobot);

    this.changeToDefaultFrame();

    this.getDriver().switchTo().frame(mainFrame);

    Util.wait(6);

    WebElement captchaFrame = this.element(
            By.xpath("//iframe[contains(@src,'recaptcha')]"));

    if (captchaFrame == null) {
        return;
    }

    this.getDriver().switchTo().frame(captchaFrame);

    this.getJse().executeScript(
            "document.querySelector('#recaptcha-reload-button').click();");

    Util.wait(3);

    WebElement helpButton = this.element(
            "//div[contains(@class,'button-holder') and contains(@class,'help-button-holder')]");

    if (helpButton != null) {
        this.mouseOver(helpButton);
        this.mouseClick();
    }

    this.changeToDefaultFrame();
}
