	/**
	 * Resuelve el nombre del link de navegación según el servicio indicado.
	 * BUG CORREGIDO: strings truncados restaurados, chequeo duplicado de "Prove" eliminado.
	 * NOTA: verificar que los textos de los links coincidan con la UI real.
	 */
	private String getNbLinkServicio(String servicio) {
		// BUG CORREGIDO: "N" era string truncado de "Nomina" (Nómina)
		if (servicio.contains("Nomina"))
			return "Nomina";
		if (servicio.contains("Prove"))
			return "Proveedores";
		if (servicio.contains("AFC"))
			return "Cuentas AFC";
		if (servicio.contains("Serv") || servicio.contains("Fact"))
			return "Pago de factura";
		// BUG CORREGIDO: "Programacipagos autom" era "Programación de pagos automáticos" truncado
		if (servicio.contains("Pagos Automaticos") || servicio.contains("Automaticos"))
			return "Programacion de pagos automaticos";
		if (servicio.contains("NIT"))
			return "Entre productos Davivienda del mismo NIT";
		if (servicio.contains("Cuenta No Inscrita") || servicio.contains("Cuenta NO Inscrita"))
			return "Hacia un tercero con cuenta NO inscrita";
		if (servicio.contains("Cuenta Inscrita"))
			return "Hacia un tercero con cuenta inscrita";
		if (servicio.contains("Hacia un tercero con Productos NO inscritos"))
			return "Hacia un tercero con Productos NO inscritos";
		if (servicio.contains("Hacia un tercero con Productos inscritos"))
			return "Hacia un tercero con Productos inscritos";
		if (servicio.contains("Propios"))
			return "Sus Productos Davivienda";
		// BUG CORREGIDO: "Avances Tarjeta de Cr" era "Avances Tarjeta de Crédito" truncado
		if (servicio.contains("Avance"))
			return "Avances Tarjeta de Credito";
		// BUG CORREGIDO: "cr", "Cr" eran "crédito"/"Crédito" truncados; "Crde terceros" era "Crédito de terceros"
		if (servicio.contains("credito") || servicio.contains("terceros")
				|| servicio.contains("Credito") || servicio.contains("Terceros"))
			return "Credito de terceros";
		if (servicio.contains("Internacionales") || servicio.contains("internacionales")
				|| servicio.contains("Divisas Documentos y Formularios"))
			return "Transferencias Internacionales";
		// BUG CORREGIDO: "de Pago" era "Ordenes de Pago" truncado en el caso ORPA
		if (servicio.contains("ORPA"))
			return "Ordenes de Pago";

		return "NO HAY LINK DISPONIBLE";
	}

	/** Lógica de Nota de Débito para múltiples registros (Pago a Proveedores / Nómina). */
	private void procesarNotaDebitoMasiva(String descripcion, String detalleVacio) throws Exception {
		String numRegistros   = SettingsRun.getTestData().getParameter("Filas a Tomar").trim();
		String[] parts        = numRegistros.split(" ");
		int primerNumero      = Integer.parseInt(parts[0]);
		int segundoNumero     = Integer.parseInt(parts[2]);
		int resta             = segundoNumero - primerNumero;

		int i = 1;
		do {
			// BUG CORREGIDO: empty do-while sin sleep → while con Util.wait
			while (element(this.btnDatosAdenda) == null) { Util.wait(1); }
			click(this.btnDatosAdenda);
			while (element(this.tableAdenda) == null)    { Util.wait(1); }

			Evidence.saveAllScreens("1", this);

			boolean encontrado = intentarClickRegistroAdenda(descripcion, i);

			Util.wait(4);
			if (encontrado) {
				NotaDebitoDetalleReferencia(detalleVacio);
			} else {
				Reporter.reportEvent(1, "No se encuentra el registro de la transaccion");
				this.pagePortalPymes.terminarIteracion();
			}

			click(By.xpath("//*[@id=\"cphCuerpo_btnVolver\"]"));
			i++;
		} while (i < resta + 2);
	}

	/** Lógica de Nota de Débito para un único registro. */
	private void procesarNotaDebitoSimple(String descripcion, String detalleVacio) throws Exception {
		// BUG CORREGIDO: empty do-while sin sleep
		while (element(this.btnDatosAdenda) == null) { Util.wait(1); }
		click(this.btnDatosAdenda);
		while (element(this.tableAdenda) == null)    { Util.wait(1); }

		Util.wait(5);
		Evidence.saveAllScreens("1", this);

		boolean encontrado = intentarClickRegistroAdenda(descripcion, 0);

		Util.wait(4);
		if (encontrado) {
			Util.wait(4);
			NotaDebitoDetalleReferencia(detalleVacio);
		} else {
			Reporter.reportEvent(1, "No se encuentra el registro de la transaccion");
			this.pagePortalPymes.terminarIteracion();
		}

		click(By.xpath("//*[@id=\"cphCuerpo_btnVolver\"]"));
	}

	/**
	 * Intenta hacer click en el primer registro de la tabla de adenda que contenga la descripción.
	 * Busca en filas 1, 2 y 3. Devuelve true si encontró y clicó el registro.
	 */
	private boolean intentarClickRegistroAdenda(String descripcion, int offset) {
		String baseXpath = "(//*[@id=\"cphCuerpo_gvMovimientosCuentas\"]/tbody/tr[FILA]/td/span[contains(text(), '"
				+ descripcion + "')])[1]";

		for (int fila = 1; fila <= 3; fila++) {
			String registroXpath = baseXpath.replace("FILA", String.valueOf(fila));
			if (element(By.xpath(registroXpath)) != null) {
				// Construir XPath del link en la columna de acción
				String linkXpath = registroXpath
						.replace("td", "td[4]")
						.replace("/span[contains(text(), '" + descripcion + "')])[1]", "/a")
						.replace("(", "");

				if (offset > 0) {
					linkXpath = linkXpath.replace("tr[" + fila + "]", "tr[" + (fila - 1 + offset) + "]");

					String dataXpath = linkXpath.replace("td[4]", "td[3]").replace("/a", "");
					WebElement dataEl = element(By.xpath(dataXpath));
					if (dataEl != null) {
						Reporter.reportEvent(0, ".........." + dataEl.getText() + "...........");
					}
				} else {
					Util.wait(2);
				}

				click(element(linkXpath));
				return true;
			}
		}
		return false;
	}

	/**
	 * Obtiene el saldo disponible del portal según tipo de servicio y cuenta.
	 */
	private String obtenerSaldoDisponiblePortal(String servicio, String tipoCta, String numCta) {
		try {
			if (servicio.contains("Servicios")) {
				return getText(element(this.saldoDisServiciosXpath2
						.replace("NUMCUENTA",  Util.right(numCta, 4))
						.replace("TIPOCUENTA", tipoCta)
						.replace("NUM",        "4")));
			}
			if (tipoCta.contains("Familiares")) {
				return getText(element(this.saldoDisServiciosXpath2
						.replace("NUMCUENTA",  Util.right(numCta, 4))
						.replace("TIPOCUENTA", tipoCta)
						.replace("NUM",        "5")));
			}
			if (servicio.contains("Mismo NIT") || servicio.contains("TC")) {
				return getText(element(this.saldoDisXpathMismoNit
						.replace("NUMCUENTA",  Util.right(numCta, 4))
						.replace("TIPOCUENTA", tipoCta)));
			}
			return getText(element(this.saldoDisXpath
					.replace("NUMCUENTA",  Util.right(numCta, 4))
					.replace("TIPOCUENTA", tipoCta)));
		} catch (Exception e) {
			return null;
		}
	}

	/** Actualiza las variables estáticas de saldo con los datos de Stratus. */
	private void actualizarSaldosStratus(String tipoCta, String[] saldosDisponibles, boolean esOrigen) {
		if (tipoCta.contains("ahorro") || tipoCta.contains("AH")) {
			if (esOrigen) { saldoTotalInicial = saldosDisponibles[0].replace("$ ", ""); saldoDispoInicial = saldosDisponibles[1].replace("$ ", ""); saldoPignGMF = saldosDisponibles[6].replace("$ ", ""); }
			else          { saldoTotalFinal   = saldosDisponibles[0].replace("$ ", ""); saldoDispoFinal   = saldosDisponibles[1].replace("$ ", ""); }
		} else if (tipoCta.contains("corriente") || tipoCta.contains("CC")) {
			if (esOrigen) { saldoTotalInicial = saldosDisponibles[6].replace("$ ", ""); saldoDispoInicial = saldosDisponibles[0].replace("$ ", ""); }
			else          { saldoTotalFinal   = saldosDisponibles[6].replace("$ ", ""); saldoDispoFinal   = saldosDisponibles[0].replace("$ ", ""); }
		} else if (tipoCta.contains("CREDITO")) {
			if (esOrigen) { saldoTotalInicial = saldosDisponibles[7].replace("$ ", ""); saldoDispoInicial = saldosDisponibles[2].replace("$ ", ""); }
			else          { saldoTotalFinal   = saldosDisponibles[7].replace("$ ", ""); saldoDispoFinal   = saldosDisponibles[2].replace("$ ", ""); saldoTotalFinal = saldoDispoFinal; }
		} else if (tipoCta.contains("Familiares")) {
			if (esOrigen) { saldoDispoInicial = saldosDisponibles[0].replace("$ ", ""); saldoTotalInicial = saldosDisponibles[1].replace("$ ", ""); }
			else          { saldoTotalFinal   = saldosDisponibles[0].replace("$ ", ""); saldoDispoFinal   = saldosDisponibles[1].replace("$ ", ""); }
		}

		// Reportar saldos
		if (esOrigen) {
			if (!tipoCta.contains("CREDITO")) {
				Reporter.reportEvent(5, "El saldo stratus Total Inicial: "                        + saldoTotalInicial.replace(".", ","));
				Reporter.reportEvent(5, "El saldo stratus Disponible Efectivo Inicial: "          + saldoDispoInicial.replace(".", ","));
			} else {
				Reporter.reportEvent(5, "El saldo stratus Cupo disponible Crediexpress rotativo Inicial: " + saldoTotalInicial.replace(".", ","));
				Reporter.reportEvent(5, "El saldo stratus Crediexpress rotativo Inicial: "                 + saldoDispoInicial.replace(".", ","));
			}
		} else {
			if (!tipoCta.contains("CREDITO")) {
				Reporter.reportEvent(5, "El saldo Total stratus Final: "                + saldoTotalFinal.replace(".", ","));
				Reporter.reportEvent(5, "El saldo Disponible Efectivo stratus Final: "  + saldoDispoFinal.replace(".", ","));
			} else {
				Reporter.reportEvent(5, "El saldo stratus Cupo disponible Crediexpress rotativo Final: " + saldoTotalFinal.replace(".", ","));
				Reporter.reportEvent(5, "El saldo stratus Crediexpress rotativo Final: "                 + saldoDispoFinal.replace(".", ","));
			}
		}
	}

	/** Valida y reporta la correspondencia del saldo portal vs Stratus. */
	private void validarSaldoConPortal(String tipoCta, String numCta, String saldoDis,
			String saldoDisponible, List<String> saldoscuentasCredi) {

		if (!tipoCta.contains("CREDITO")) {
			if (saldoTotalInicial != null && saldoTotalInicial.contains(saldoDisponible)) {
				Reporter.reportEvent(5, "El saldo total en stratus " + saldoTotalInicial.replace(".", ",")
						+ " corresponde al saldo disponible en el portal: " + saldoDis);
			} else {
				Reporter.reportEvent(5, "El saldo total en stratus " + saldoTotalInicial
						+ " no corresponde al saldo disponible en el portal: " + saldoDis);
			}
		} else {
			Reporter.reportEvent(5, "==========[SALDOS DISPONIBLES DE LA CUENTA "
					+ numCta + " - CONSULTAS]=====");

			double sumasaldoDispCred = 0.0;
			double cupoCredi = 0.0;
			double restasaldoDispCred = 0.0;

			for (String suma : saldoscuentasCredi) {
				cupoCredi = sumasaldoDispCred += Double.parseDouble(suma);
				Reporter.reportEvent(5, "saldo Disponible: " + suma.replace(".", ","));
				if (!saldoDisponible.equals(suma)) {
					restasaldoDispCred = Double.parseDouble(suma) - cupoCredi;
				}
			}

			Reporter.reportEvent(5, "El saldo corresponde al cupo disponible Stratus: "
					+ saldoTotalInicial.replace(".", ",")
					+ " corresponde a la sumatoria de los saldos al cupo disponible del portal: "
					+ BigDecimal.valueOf(sumasaldoDispCred));

			double saldodispoCredSele = Double.parseDouble(saldoDisponible);
			restasaldoDispCred = Double.parseDouble(
					String.valueOf(BigDecimal.valueOf(restasaldoDispCred)).replace("-", ""));

			if (restasaldoDispCred == saldodispoCredSele) {
				Reporter.reportEvent(5, "El saldo disponible " + BigDecimal.valueOf(restasaldoDispCred)
						+ " corresponde al saldo disponible en el portal: " + saldoDis);
			} else {
				Reporter.reportEvent(5, "El saldo total en stratus " + BigDecimal.valueOf(restasaldoDispCred)
						+ " no corresponde al saldo disponible en el portal: " + saldoDis);
			}

			Reporter.reportEvent(5, "El saldo Inicial: " + saldoDispoInicial.replace(".", ","));
			saldoTotalInicial = saldoDispoInicial;
		}
	}

	/**
	 * Reporta la validación de un campo de adenda (descripción o referencia).
	 * Centraliza el patrón repetido de Reporter.reportEvent para adendas.
	 */
	private void reportarCampoAdenda(String nombreCampo, String valorActual,
			String valorEsperado, String valorDefault) {
		boolean correcto;
		if (!valorEsperado.isEmpty()) {
			correcto = valorEsperado.equals(valorActual);
		} else {
			correcto = valorDefault.equals(valorActual);
		}

		if (correcto) {
			Reporter.reportEvent(0, "Adenda correcta en " + nombreCampo);
		} else {
			Reporter.reportEvent(1, "Adenda incorrecta en " + nombreCampo);
		}
	}

	/**
	 * Reporta una validación genérica PASSED/FAIL con Reporter.write.
	 * Centraliza el patrón repetido en RevisionProOrdenesDePago / RevisionEstOrdenesDePago.
	 */
	private void reportarValidacion(String nombreCampo, String valorActual, String valorEsperado) {
		if (valorActual.equals(valorEsperado)) {
			Reporter.write("*** PASSED :: " + nombreCampo + " correcto");
			Reporter.write("*** PASSED ------ " + valorActual);
			Reporter.write("*** PASSED ------ " + valorEsperado);
		} else {
			Reporter.write("*** FAIL :: " + nombreCampo + " incorrecto");
			Reporter.write("*** FAIL ------ " + valorActual);
			Reporter.write("*** FAIL ------ " + valorEsperado);
		}
	}
