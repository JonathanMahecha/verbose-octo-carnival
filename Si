    /**
     * Termina la iteración con evidencia, reportando en el Motor de Riesgo si está activo.
     * Es el punto único de salida por error del flujo transaccional.
     */
    private void terminarIteracionXError(String msgError) throws Exception {
        if (msgError == null) msgError = "Error_1";

        Reporter.write(msgError);
        guardarEvidencia(msgError);

        if (DatosDavivienda.IS_RISKMOTOR) {
            fail("No se adiciona a MR >>> " + msgError);
            marcarFalla();
        } else {
            terminarConError(msgError);
        }

        finalizarIteracion();
    }

    /** Reporta error y marca falla sin cerrar la sesión. */
    private void terminarConError(String mensaje) {
        fail(mensaje);
        marcarFalla();
    }

    private void guardarEvidencia(String msgError) {
        String nombre = msgError.replace(" ", "")
                .replaceAll("[\\\\/:*?\"<>|¡!\\.]", "")
                .replaceAll("\\s+", "_");

        if (frontEmpresarial != null)  Evidence.save(nombre, frontEmpresarial);
        else if (loginFrontPyme != null) Evidence.save(nombre, loginFrontPyme);
    }

    private void finalizarIteracion() throws Exception {
        if (frontEmpresarial != null) {
            cerrarSesionDependiemdoPortal();
            SettingsRun.exitTestIteration();
        } else if (loginFrontPyme != null) {
            loginFrontPyme.terminarIteracion();
        } else {
            SettingsRun.exitTestIteration();
        }
    }

    private void marcarFalla() {
        SettingsRun.getTestData().setParameter(PARAM_SIGUIENTE_BLOQUE, VALOR_FALLA);
    }

