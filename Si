public String seleccionarCuentaInscri(String tipoProducto, String numeroProducto) throws Exception {

    String msg = this.waitPantallaDestino();
    if (msg != null) {
        return msg;
    }

    String tipoProdUpper = tipoProducto == null ? "" : tipoProducto.trim().toUpperCase();
    String tipoProd = "corriente"; // valor por defecto

    if (tipoProdUpper.contains("AHORRO OTROS BANCOS")) {
        tipoProd = "Cuentas ahorro otros bancos";
    } else if (tipoProdUpper.contains("AHORRO")) {
        tipoProd = "ahorro";
    } else if (tipoProdUpper.contains("CORRIENTES OTROS BANCOS")) {
        tipoProd = "Cuentas corrientes otros bancos";
    } else if (tipoProdUpper.contains("EXPRES")) {
        tipoProd = "rediexpress";
    } else if (tipoProdUpper.contains("ELECTR")) {
        tipoProd = "electronicos";
    } else if (tipoProdUpper.contains("DAVIPLATA") || tipoProdUpper.contains("DAVIPLA")) {
        tipoProd = "Daviplata";
    }

    WebElement objRadioButtonProd = null;
    String ultimo4 = Util.right(numeroProducto, 4);

    while (true) {
        Util.wait(2);

        if (!tipoProdUpper.contains("FIC")) {

            String xPathRB = xPathRBDestino
                    .replace("NUM_PROD", ultimo4)
                    .replace("TIPO_PROD", tipoProd);

            objRadioButtonProd = this.element(xPathRB);

        } else {

            String xPathRB = xPathRBDestinoFic.replace("NUM_PROD", ultimo4);
            List<WebElement> listaObjs = this.findElements(By.xpath(xPathRB));

            for (WebElement element : listaObjs) {
                String tipoProdTab = this.getText(this.element(element, locTipoPruebaFic));

                if (tipoProdTab == null) {
                    continue;
                }

                if (!Util.itemContainsAnyArrayItem(tipoProdTab.toUpperCase(), arrTipoProdNoFic)) {
                    objRadioButtonProd = element;
                    break;
                }
            }
        }

        if (objRadioButtonProd != null) {
            break;
        }

        WebElement btnSiguiente = this.element(By.xpath("//*[@id='cphCuerpo_lnkSiguiente']"));
        if (btnSiguiente == null) {
            break;
        }

        String classBtn = btnSiguiente.getAttribute("class");
        if (classBtn != null && classBtn.contains("aspNetDisabled")) {
            break;
        }

        Util.wait(2);
        btnSiguiente.click();
    }

    if (objRadioButtonProd == null) {
        Evidence.saveFullPage("Error-ProdDestino", this);
        return "Producto destino [" + tipoProducto + " - " + numeroProducto + "] NO encontrado";
    }

    this.click(objRadioButtonProd);
    Evidence.saveFullPage("selec Cuenta Inscri", this);
    this.click(locButtonSig);

    return null;
}
