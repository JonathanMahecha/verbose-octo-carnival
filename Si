public String getCodigoXNombreContained(String valor) {

    if (valor == null || valor.trim().isEmpty()) {
        return null;
    }

    String criterio = Util.removeAccents(valor.trim().toUpperCase());

    // Si ya viene un código, retornarlo si existe
    if (catalogoXCodigo.containsKey(criterio)) {
        return criterio;
    }

    // Búsqueda exacta
    String codigo = catalogoXNombre.get(criterio);
    if (codigo != null) {
        return codigo;
    }

    // Búsqueda parcial
    for (Map.Entry<String, String> entry : catalogoXNombre.entrySet()) {

        String nombreBanco = entry.getKey();

        if (nombreBanco.contains(criterio) || criterio.contains(nombreBanco)) {
            return entry.getValue();
        }
    }

    return null;
}
