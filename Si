    private WebElement waitForElement(By locator, int maxAttempts, String elemento) {
        int attempts = 0;
        WebElement el = null;

        while (attempts < maxAttempts) {
            attempts++;
            el = element(locator);
            if (el != null) {
                return el;
            }
            waitSeconds(2);
        }

        return null;
    }

