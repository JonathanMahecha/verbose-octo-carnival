private void resolverCuentaHomologadaMasiva(String[] d) throws Exception {

    if (datoNumDestCuentas == null
            || d == null
            || d.length <= 4
            || (!this.servicio.contains("Nómina")
            && !this.servicio.contains("Pago a Proveedores"))) {
        return;
    }

    String tipoDestino = d[1];
    String ultimos4 = Util.right(d[4], 4);

    if (controlDest == null) {
        controlDest = new ControllerDestinosMasivos(pageDestino);
    }

    for (String destinoMigrado : datoNumDestCuentas) {

        String[] datosMigrados = destinoMigrado.split("\\|");

        if (datosMigrados.length < 2) {
            continue;
        }

        String tipoProducto = datosMigrados[0];
        String numeroCuenta = datosMigrados[1];

        if (contiene(tipoProducto,
                "DEPÓSITOS ELECTRONICOS",
                "DEPÓSITOS ELECTRÓNICOS")) {

            tipoProducto = "DEPÓSITOS ELECTRONICOS";
        }

        if (!tipoProducto.equals(tipoDestino)) {
            continue;
        }

        if (!numeroCuenta.contains(ultimos4)) {
            continue;
        }

        DatosDavivienda.RISKMOTOR.setNumCuentaDestino(numeroCuenta);

        String homologada =
                controlDest.BuscarCuentasMigrada(
                        tipoProducto,
                        numeroCuenta);

        DatosDavivienda.RISKMOTOR
                .setNumCuentaOrigenMigrada(homologada);

        break;
    }
}
