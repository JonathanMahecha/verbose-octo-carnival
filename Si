    /** Inicializa todas las páginas comunes. */
    private void initPages(BasePageWeb parentPage, StratusProductos instanciaStra) throws Exception {
        this.instanciaStratus = instanciaStra;
        this.pageTitle = parentPage.getTitle();

        pagePortalPymes         = new PagePortalPymes(parentPage);
        pageDestino             = new PageDestino(parentPage);
