public static String[] getArrayToken(String condicion) throws Exception {

    String[] arrayToken;

    switch (condicion == null ? "" : condicion.trim().toUpperCase()) {

        case "CORRECTO":
        case "CP ERRADA":
        case "":
            arrayToken = getArrayToken();
            break;

        case "ERRADO":

            arrayToken = getArrayToken();

            if (arrayToken.length > 0
                    && arrayToken[0] != null
                    && !arrayToken[0].isEmpty()) {

                String token = arrayToken[0];

                int ultimoDigito =
                        Character.getNumericValue(token.charAt(token.length() - 1));

                ultimoDigito = (ultimoDigito + 1) % 10;

                arrayToken[0] =
                        token.substring(0, token.length() - 1)
                                + ultimoDigito;
            }

            break;

        case "CORTO":
            arrayToken = new String[] { "123" };
            break;

        case "CEROS":
            arrayToken = new String[] { "000000" };
            break;

        case "UNOS":
            arrayToken = new String[] { "111111" };
            break;

        case "ESPACIOS":
            arrayToken = new String[] { "      " };
            break;

        default:
            throw new IllegalArgumentException(
                    "Condición de token no soportada: " + condicion);
    }

    LAST_TOKEN = arrayToken[0];

    return arrayToken;
}
