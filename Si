package dav.pymes.moduloCrearTx;

import java.util.*;

import dav.CobrosMiddle.BaseMiddleCobros;
import dav.pymes.PagePortalPymes;
import dav.middlePymes.PageServicios;
import dav.Consultas_Y_Extractos.PageConsultasyExtractos;
import dav.divisas.*;
import dav.library.common.DatosEmpresarial;
import dav.library.common.NotificacionSMS;
import dav.transversal.DatosDavivienda;
import dav.transversal.MotorRiesgo;

import library.common.Util;
import library.core.BasePageWeb;
import library.reporting.Evidence;
import library.reporting.Reporter;
import library.settings.SettingsRun;
import screens.actions.consulta.StratusProductos;

public class ControllerCrearTx {

    // ===================== PAGES =====================
    private PagePortalPymes pagePortalPymes;
    private PageOrigen pageOrigen;
    private PageDestino pageDestino;
    private PageValores pageValores;
    private PageConfirmacion pageConf;
    private PagePendAprobacion pagePendApr;
    private PageConsultasyExtractos pageConsultasyExtractos;

    private StratusProductos instanciaStratus;

    // ===================== DATA =====================
    private String servicio;
    private String tipoPrueba;
    private String adenda;
    private String numAprobaciones;
    private boolean unaFirma;

    private String nombreEmpre, nitEmpre, tipoIdEm;
    private String tipoCta, numCta;
    private String uuid;

    private String descripcionsin;
    private String valorsin, valorcon;
    private String referenciasin;

    private String referencia1, referencia2;

    private String navegador;
    private String nombreAmbiente;

    private String montoReal;
    private int totalDestinos;

    // ===================== HELPERS =====================
    private String getParam(String key, String def) {
        if (SettingsRun.getTestData().parameterExist(key)) {
            String v = SettingsRun.getTestData().getParameter(key);
            if (v != null && !v.trim().isEmpty()) return v.trim();
        }
        return def;
    }

    // ===================== CONSTRUCTOR =====================
    public ControllerCrearTx(BasePageWeb parentPage) throws Exception {

        pagePortalPymes = new PagePortalPymes(parentPage);
        pageOrigen = new PageOrigen(parentPage);
        pageDestino = new PageDestino(parentPage);
        pageValores = new PageValores(parentPage);
        pageConf = new PageConfirmacion(parentPage);
        pageConsultasyExtractos = new PageConsultasyExtractos(parentPage);
        pagePendApr = new PagePendAprobacion(parentPage);

        // ===== PARAMS =====
        servicio = getParam("Servicio", "");
        tipoPrueba = getParam("Tipo prueba", "Tx En Línea");
        adenda = getParam("Adenda", "NO");
        numAprobaciones = getParam("Números de Aprobaciones", "1");
        unaFirma = "1".equals(numAprobaciones);

        navegador = getParam("Navegador", "CHROME");

        nombreEmpre = getParam("Nombre Empresa", "");
        nitEmpre = getParam("Numero ID Empresa", "");
        tipoIdEm = getParam("Tipo ID Empresa", "NIT");

        tipoCta = getParam("Tipo producto origen / Franquicia", "");
        numCta = getParam("Número producto origen", "");

        uuid = getParam("Hash", "");

        descripcionsin = getParam("Descripcion", "");
        valorsin = getParam("Valor a Pagar / Transferir", "1");
        valorcon = valorsin;

        referenciasin = getParam("Referencia", "");

        if (!servicio.contains("Nómi") && !servicio.contains("Proveedores")) {
            referencia1 = getParam("Referencia1 / Tipo Producto Destino", "");
            referencia2 = getParam("Referencia2 / Número Producto Destino", "");
        }

        if (!DatosDavivienda.IS_RISKMOTOR) {
            normalizarAmbiente();
        }
    }

    // ===================== AMBIENTE =====================
    private void normalizarAmbiente() {
        String amb = SettingsRun.getGlobalData("AMBIENTE_PYME");

        switch (amb) {
            case "1":
            case "PROYECTOS":
                nombreAmbiente = "PROYECTOS"; break;
            case "2":
            case "CONTENCION":
                nombreAmbiente = "CONTENCION"; break;
            case "3":
            case "OBSOLESCENCIA":
                nombreAmbiente = "OBSOLESCENCIA"; break;
            case "4":
            case "ONPREMISE":
                nombreAmbiente = "ONPREMISE"; break;
            default:
                Reporter.reportEvent(Reporter.MIC_FAIL, "Ambiente inválido");
        }
    }

    // ===================== INICIO =====================
    public void inicioCrearTx() throws Exception {

        String msgError;
        String pagoyTx = pagePortalPymes.getTextMid();

        String opcion = "Pagos y Transferencias";

        if (pagoyTx.contains("Pagos, Transferencias")) {
            opcion = "Pagos, Transferencias y Otros";
        }

        if (navegador.contains("CHROME")) {
            msgError = pagePortalPymes.irAOpcion("Crear Transacción", opcion, "Crear Transacción");
        } else {
            msgError = pagePortalPymes.irAOpcionMoZilla("Crear Transacción", opcion, "Crear Transacción", null, null);
        }

        if (msgError != null) terminarIteracionXError(msgError);

        msgError = pageOrigen.irAServicio(servicio);

        if (msgError != null) terminarIteracionXError(msgError);
    }

    // ===================== ORIGEN =====================
    private void seleccionarCtaOrigen(boolean isServicio) throws Exception {

        String msgError;

        if (isServicio) {
            msgError = pageOrigen.seleccionarOrigen(servicio, tipoIdEm, nitEmpre, "", tipoCta, numCta);
        } else {
            msgError = pageOrigen.seleccionarOrigen(servicio, tipoIdEm, nitEmpre, tipoCta, numCta);
        }

        if (msgError != null) terminarIteracionXError(msgError);
    }

    // ===================== VALORES =====================
    private void ingresarValores(String tipo) throws Exception {

        String descripcion = DatosDavivienda.IS_RISKMOTOR
                ? tipo + SettingsRun.getCurrentIteration()
                : descripcionsin;

        if ("MismoNit".equals(tipo)) {
            pageValores.ingresarValores(valorsin, descripcion, referenciasin);
        } else if ("CuentaNoInscrita".equals(tipo)) {
            pageValores.ingresarValoresCuentaNo(valorsin, descripcion, referenciasin);
        } else if ("CuentaInscrita".equals(tipo)) {
            pageValores.ingresarValoresCuentaIsncr(valorsin, descripcion, referenciasin);
        } else if ("PagosPropios".equals(tipo)) {
            pageValores.ingresarValoresPropios(valorsin);
        }

        String msgError = pageConf.waitPantallaConfirmar("");
        if (msgError != null) terminarIteracionXError(msgError);

        montoReal = valorsin;
        totalDestinos = 1;
    }

    // ===================== CONFIRMACION =====================
    private void accionConfirmar(boolean soloGuardar) throws Exception {

        String msgRta;

        if (soloGuardar) {
            msgRta = pageConf.guardarSinAprobar();

            if (!msgRta.contains("EXIT")) {
                terminarIteracionXError(msgRta);
            }

        } else {
            msgRta = pageConf.aprobarTx(0, true);

            if (msgRta == null || msgRta.isEmpty()) {
                terminarIteracionXError("Error en aprobación");
            }
        }
    }

    // ===================== ERRORES =====================
    private void terminarIteracionXError(String msgError) throws Exception {

        if (msgError == null) msgError = "Error desconocido";

        Reporter.write(msgError);

        Evidence.save(msgError.replace(" ", "_"), pageOrigen);

        Reporter.reportEvent(Reporter.MIC_FAIL, msgError);

        pagePortalPymes.terminarIteracion();
    }

    // ===================== TRANSACCIONES =====================

    public void crearPagoServicios(boolean soloGuardar) throws Exception {

        NotificacionSMS.loadTipoNotificacion(NotificacionSMS.TIPO_NOTIF_PYMES_PA_SERV);

        inicioCrearTx();
        seleccionarCtaOrigen(true);

        String msgError = pageDestino.ingresarReferencia(referencia1, referencia2);
        if (msgError != null) terminarIteracionXError(msgError);

        montoReal = pageValores.ingresarValor(valorsin);
        totalDestinos = 1;

        msgError = pageConf.waitPantallaConfirmar("");
        if (msgError != null) terminarIteracionXError(msgError);

        accionConfirmar(soloGuardar);
    }

    public void crearTransferenciaCtaInscrita(boolean soloGuardar) throws Exception {

        NotificacionSMS.loadTipoNotificacion(NotificacionSMS.TIPO_NOTIF_PYMES_TF_CTAINSC);

        inicioCrearTx();
        seleccionarCtaOrigen(false);

        String msgError = pageDestino.seleccionarCuentaInscri(referencia1, referencia2);
        if (msgError != null) terminarIteracionXError(msgError);

        ingresarValores("CuentaInscrita");

        accionConfirmar(soloGuardar);
    }

    public void crearPagosPropios(boolean soloGuardar) throws Exception {

        NotificacionSMS.loadTipoNotificacion(NotificacionSMS.TIPO_NOTIF_PYMES_TF_MISMONIT);

        inicioCrearTx();
        seleccionarCtaOrigen(false);

        String msgError = pageDestino.seleccionarDestinoPropios(referencia1, referencia2);
        if (msgError != null) terminarIteracionXError(msgError);

        ingresarValores("PagosPropios");

        accionConfirmar(soloGuardar);
    }
}
