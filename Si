	private void buscarYSeleccionarLugar(String datoLugar, int columnas, int filas, By btnAceptar) {
		boolean encontrado = false;

		outer:
		for (int i = 2; i <= columnas; i++) {
			for (int j = 2; j <= filas; j++) {
				String datoComparar = this.getCellValue(tabla, j, i);
				if (datoComparar.contains(datoLugar)) {
					By select = By.xpath(
							"//*[@summary='Seleccionar Centro Poblado']/tbody/tr[" + j + "]/td[" + i + "]");
					this.click(select);
					waitElement(btnAceptar, TIMEOUT_SHORT);
					this.click(btnAceptar);
					break outer;
				}
			}
		}
	}

	private void esperarYValidarBotonNuevo(By icono, By btnNuevo) throws Exception {
		By correoLabel = By.xpath("//span[contains(text(), 'Correo electrónico')]");
		int contador = 0;

		try {
			new WebDriverWait(getDriver(), 30)
					.pollingEvery(Duration.ofSeconds(1))
					.until(driver -> {
						// Si el panel de correo apareció pero el botón Nuevo no, cerrar y reintentar
						if (this.element(correoLabel) != null && this.element(btnNuevo) == null) {
							try { cerrarCampoCorreoNoCargado(icono); } catch (Exception ignored) { }
						}
						return this.element(btnNuevo) != null && this.isEnabled(btnNuevo);
					});
		} catch (org.openqa.selenium.TimeoutException e) {
			terminarIteracion();
		}
	}

