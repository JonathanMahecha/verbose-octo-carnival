        pageConf                = new PageConfirmacion(parentPage);
        pagePendApr             = new PagePendAprobacion(parentPage);
        pageAprobInter          = new PageAprobacionInter(parentPage);

        if (instanciaStra != null) {
            pageOrigen              = new PageOrigen(parentPage, instanciaStra);
            pageConsultasyExtractos = new PageConsultasyExtractos(parentPage, instanciaStra);
        } else {
            pageOrigen              = new PageOrigen(parentPage);
            pageConsultasyExtractos = new PageConsultasyExtractos(parentPage);
        }
    }

    /**
     * Carga referencias, datos de destino, divisas y comprobantes desde TestData.
     * Compartido entre ambos constructores.
     */
    private void loadReferencias(BasePageWeb parentPage) throws Exception {
        if (!this.servicio.contains("Nómi") && !this.servicio.contains("Proveedores")) {
            this.referencia1 = getParam("Referencia1 / Tipo Producto Destino");
            this.referencia2 = getParam("Referencia2 / Número Producto Destino");
        }

        if (this.servicio.contains("Pagos Automaticos") || this.servicio.contains("Servicios")) {
            this.numConvenio = getParam("Número de Convenio");
        }

        if (this.servicio.contains("Pagos Automaticos")) {
            this.diaDiaDelpago    = getParam("Día del pago");
            this.titul            = getParam("Nombre del Titular");
            this.tipoCtaSecundario = getParam("Tipo producto origen Secundario");
            this.numCtaSecundario  = getParam("Número producto origen Secundario");
        }

        if (this.servicio.contains("Cuenta No Inscrita") || this.servicio.contains("Cuenta Inscrita")) {
            this.bncoDest = getParam("Banco Destino");
            if (this.servicio.contains("Cuenta No Inscrita")) {
                this.titul  = getParam("Nombre del Titular");
                this.tipoid = getParam("Tipo Identificación del Titular");
                this.numid  = getParam("Número Identificación del Titular");
            }
        }

        if (this.servicio.contains("Avance TC")) {
            this.mesTC     = getParam("Mes Vencimiento TC");
            this.avenTC    = getParam("Año Vencimiento TC");
            this.plazoDiAv = getParam("Plazo a diferir el avance");
        }

        if (this.servicio.contains("Tx Internacionales Recibir desde el exterior")
                || this.servicio.contains("Tx Internacionales Enviar al exterior")) {
            loadDivisasParams(parentPage);
        }

        if (SettingsRun.getTestData().parameterExist("Tiempo de Consulta")
                && !SettingsRun.getTestData().getParameter("Tiempo de Consulta").trim().isEmpty()) {
            this.tipoConstaTxRealizadas = getParam("Tiempo de Consulta");
        }
        if (SettingsRun.getTestData().parameterExist("Fecha tx")
                && !SettingsRun.getTestData().getParameter("Fecha tx").trim().isEmpty()) {
            this.fecha = getParam("Fecha tx");
        }
        if (SettingsRun.getTestData().parameterExist("Hora tx")
                && !SettingsRun.getTestData().getParameter("Hora tx").trim().isEmpty()) {
            this.hora = getParam("Hora tx");
        }
        this.moneda = getParamOrDefault("Tipo Moneda", "");
    }

