	/**
	 * Espera la página de Origen y selecciona el radio button del producto indicado.
	 */
	public String seleccionarOrigen(String servicio, String tipoDocumento, String numeroDoc,
			String tipoProducto, String numeroProducto) throws Exception {

		// BUG CORREGIDO: loop infinito sin sleep reemplazado por espera con pausa
		while (element(this.locPasoPage) == null) {
			Util.wait(1);
		}

		Evidence.saveFullPage("Origen", this);
		String tipoProd = resolverTipoProd(tipoProducto);

		WebElement objRadioButtonProd = buscarRadioButtonProducto(tipoProducto, tipoProd, numeroProducto);

		if (objRadioButtonProd == null) {
			Evidence.saveFullPage("Error-ProdOrigen", this);
			return "Producto origen [" + tipoProducto + " - " + numeroProducto + "] NO encontrado";
		}

		if (!DatosDavivienda.IS_RISKMOTOR) {
			validacionSaldosStratus(servicio, tipoDocumento, numeroDoc, tipoProd, numeroProducto, true);
		}

		Util.wait(3);
		click(objRadioButtonProd);
		Evidence.saveFullPage("ProductoOrigen", this);
		Util.wait(3);
		click(this.locButtonSig);
		return null;
	}

