public String seleccionarOrigen(String servicio,
                                String tipoDocumento,
                                String numeroDoc,
                                String numConvenio,
                                String tipoProducto,
                                String numeroProducto) throws Exception {

    WebElement pasoOrigen = waitForElement(this.locPasoPage, TIMEOUT_LARGO);

    if (pasoOrigen == null) {
        return "No se encontró la pantalla de origen";
    }

    String msgError = null;

    if (element(this.xPathServicio) != null) {

        String seleccionConvenio = "- " + numConvenio;

        msgError = selectListContainsItems(
                By.xpath(this.xPathServicio),
                new String[]{seleccionConvenio}
        );

        String textoSeleccionado = getText(By.xpath(this.xPathServicio));

        if (textoSeleccionado == null || !textoSeleccionado.contains(seleccionConvenio)) {
            msgError = "No quedó seleccionado el convenio esperado";
        }
    }

    if (msgError != null) {
        return "Error en lista 'Servicio a pagar' : " + msgError;
    }

    WebElement tablaOrigen = waitForElement(this.locTitTabOr, TIMEOUT_MEDIO);

    if (tablaOrigen == null) {

        String alerta = this.pagePortalPymes.getMsgAlertIfExist(
                new String[]{"lblMasterAlerta"}
        );

        if (alerta != null) {
            return "Error en lista 'Servicio a pagar' : " + alerta;
        }
    }

    return seleccionarOrigen(
            servicio,
            tipoDocumento,
            numeroDoc,
            tipoProducto,
            numeroProducto
    );
}

public String seleccionarOrigenAuto(String numConvenio,
                                    String tipoProducto,
                                    String numeroProducto,
                                    String tipoProductoSec,
                                    String numeroProductoSec) throws Exception {

    WebElement pasoOrigen = waitForElement(this.locPasoPage, TIMEOUT_LARGO);

