    /**
     * Enruta la creación de la transacción al método correcto según el servicio
     * y gestiona la validación de back-end si corresponde.
     */
    private void ejecutarTransaccionSegunServicio(boolean guardarPrimero) throws Exception {
        final String back = globalData("VALIDACION.BACK");

        if (SERVICIOS_NOMINA_PROVEEDORES.contains(servicio)) {
            List<String> datos = controller.crearPagoNomina_Proveedores(guardarPrimero);
            if (back.contains(SI)) procesarBackFM(datos, datos.get(0));
            return;
        }

        switch (servicio) {

            // --- Servicios con lógica TDC vs crédito ---
            case "Pago de Servicios":
            case "Servicios":
                ejecutarConBackTdcOCredito(controller.crearPagoServicios(guardarPrimero),
                        back, CommonAs400.TIPO_TX_CRED_PAGOS, CommonAs400.TIPO_TX_TDC_PAGO);
                return;

            case "Pagos Automaticos":
                ejecutarConBackTdcOCredito(controller.crearPagosAutomaticos(guardarPrimero),
                        back, CommonAs400.TIPO_TX_CRED_PAGOS, CommonAs400.TIPO_TX_TDC_PAGO);
                return;

            case "Pagos Propios":
                ejecutarConBackTdcOCredito(controller.crearPagosPropios(guardarPrimero),
                        back, CommonAs400.TIPO_TX_CRED_PAGOS, CommonAs400.TIPO_TX_TDC_PAGO);
                return;

            case "Avances Tarjeta de Crédito":
            case "Avance TC":
                ejecutarConBackTdcOCredito(controller.crearAvanceTC(guardarPrimero),
                        back, CommonAs400.TIPO_TX_CRED_PAGOS, CommonAs400.TIPO_TX_TDC_AVANCES);
                return;

            // --- Transferencias entre cuentas ---
            case "Transferencias Mismo NIT":
            case "Transferencia NIT Propio":
            case "Mismo NIT":
                registrarBackSAFSiCorresponde(controller.crearTranferenciaMismoNit(guardarPrimero), back);
                return;

            case "Transferencias Cuenta Inscrita":
            case "Cuenta Inscrita":
                registrarBackSAFSiCorresponde(controller.crearTransferenciaCtaInscrita(guardarPrimero), back);
                return;

            case "Transferencias Cuenta No Inscrita":
            case "Transferencias Cuenta NO Inscrita":
            case "Cuenta No Inscrita":
                registrarBackSAFSiCorresponde(controller.crearTransferenciaCtaNoInscrita(guardarPrimero), back);
                return;

            // --- Servicios sin back-end ---
            case "ORPA":
                controller.OrdenesDePago();
                return;

            // --- Internacionales ---
            case "Tx Internacionales Recibir desde el exterior":
                controller.Recibirdinerodelexterior(guardarPrimero);
                return;

            case "Tx Internacionales Enviar al exterior":
                controller.EnviarTransferenciasInternacionales(guardarPrimero);
                return;

            case "Tx Internacionales Enviar al exterior Pendiente Aprobación":
                controller.inicioCrearTx();
                controller.EnviarTransferenciasInternacionalesPendAprobacion();
                return;

            case "Divisas Documentos y Formularios":
                flujoDivisasDocumentosYFormularios(guardarPrimero);
                return;

            case "Consulta Tx Internacionales Validar Estado":
                controller.inicioCrearTx();
                pageConsultatxInternacional = new PageConsultatxInternacional(pageLoginPyme);
                pageConsultatxInternacional.ConsultaNumtx(tipoPrueba, empresa, servicio, usuario,
                        tipoConstaTxRealizadas, ordenanteBeneficiario, tipoTranferencia, estado,
                        tipoMoneda, fechaTx, horaTx, fechaDesde, fechaHasta, valorTx);
                return;

            default:
                fail("Servicio no reconocido: " + servicio);
        }
    }

    /**
     * Ejecuta la transacción y despacha al back de Facturación (TDC) o FM (crédito)
     * según el tipo de producto en los datos devueltos.
     */
    private void ejecutarConBackTdcOCredito(List<String> datos, String back,
                                             String tipoCredito, String tipoTDC) throws Exception {
        if (!back.contains(SI)) return;
        if (TIPO_PRODUCTO_TDC.equalsIgnoreCase(datos.get(0))) {
            procesarBack(datos, tipoTDC, true);
        } else {
            procesarBack(datos, tipoCredito, false);
        }
    }

