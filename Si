    public void destroy() {
        try {
            // Se mantiene el mismo flujo original.
        } catch (Exception e) {
            if (pageInicio != null) {
                this.pageInicio.closeAllBrowsers();
            }
            if (as != null) {
                this.as.closeAs400();
            }
        }
    }

    public void dataAmbiente() {
        this.typeId = SettingsRun.getTestData().getParameter("Type ID").trim();
        this.numberId = SettingsRun.getTestData().getParameter("Number ID").trim();
        this.name = SettingsRun.getTestData().getParameter("Name").trim();
        this.dateExp = normalizeDateForEnvironment(SettingsRun.getTestData().getParameter("Date_Exp").trim());
        System.out.println("Fecha normalizada: " + this.dateExp);
    }

    public void mainController() throws Exception {
        try {
            dataAmbiente();
            ingresoAmbiente();

            String dato = SettingsRun.getGlobalData("data.crearClients360").toUpperCase();
            if (dato.equals("SI")) {
                client360Procs();
            }
        } catch (Exception e) {
            Reporter.reportEvent(Reporter.MIC_FAIL, "El cliente: " + numberId + ", no fue creado exitosamente.");
            cerrarSesiones();
            SettingsRun.exitTestIteration();
        }
    }

    public void iniProcessAs() {
        this.as = new PageDataCredit(
                SettingsRun.getGlobalData("data.as400User"),
                SettingsRun.getGlobalData("data.as400Pwd"),
                "NO OPERADOR"
        );
    }

    public void ingresoAmbiente() throws Exception {
        String[] lastName = this.name.split(" ");
        this.typeId = Util.leftComplete(this.typeId, 2, '0');

        if (SettingsRun.esIteracionInicial()) {
            iniProcessAs();
            this.as.ingresarAlCredito();
        }

        Reporter.reportEvent(
                5,
                String.format(MENSAJE_INGRESO_DATOS, this.name, this.typeId, this.numberId)
        );

        this.datosPerson = this.as.consultarObligaciones(this.typeId, this.numberId, lastName[0], this.dateExp);
        if (this.datosPerson == null) {
            Reporter.reportEvent(1, MENSAJE_EJECUCION_FALLO);
            SettingsRun.exitTestIteration();
            return;
        }

        asignarNombreCompleto(this.datosPerson[3]);

        this.fechaExp = reformatFecha(this.datosPerson[5]);
        this.fechaNac = menosVeinteAnios(this.datosPerson[5]);

        this.genero = "F".equals(this.datosPerson[2]) ? GENERO_FEMENINO : GENERO_MASCULINO;

        if ("01".equals(this.datosPerson[0])) {
            this.tipoCliente = TIPO_PERSONA_NATURAL;
        } else {
            Reporter.reportEvent(1, MENSAJE_PERSONA_NO_NATURAL);
            SettingsRun.exitTestIteration();
        }

        if (SettingsRun.esIteracionFinal()) {
            this.as.cerrarSesion();
        }
    }

    public static String menosVeinteAnios(String fechaEntrada) {
        LocalDate fecha = LocalDate.parse(fechaEntrada, INPUT_FMT);
        return fecha.minusYears(20L).format(OUTPUT_FMT);
    }

    public static String reformatFecha(String fechaEntrada) {
        LocalDate fecha = LocalDate.parse(fechaEntrada, INPUT_FMT);
        return fecha.format(OUTPUT_FMT);
    }

    private void asignarNombreCompleto(String nombreCompleto) {
        String[] divisionNombre = nombreCompleto.split(" ");
        if (divisionNombre.length == 4) {
            this.nombres = divisionNombre[0] + " " + divisionNombre[1];
            this.primerApellido = divisionNombre[2];
            this.segundoApellido = divisionNombre[3];
        } else {
            this.nombres = divisionNombre[0];
            this.primerApellido = divisionNombre[1];
            this.segundoApellido = divisionNombre[2];
        }
    }

    private String normalizeDateForEnvironment(String fecha) {
        if (fecha.matches("\\d{8}")) {
            return fecha.substring(0, 4) + "-" + fecha.substring(4, 6) + "-" + fecha.substring(6, 8);
        }

        if (fecha.matches("\\d{4}-\\d{2}-\\d{2}")) {
            return fecha;
        }

        if (fecha.matches("\\d{2}-\\d{2}-\\d{4}")) {
            String[] parts = fecha.split("-");
            return parts[2] + "-" + parts[1] + "-" + parts[0];
        }

        if (fecha.matches("\\d{2}/\\d{2}/\\d{4}")) {
            String[] parts = fecha.split("/");
            return parts[2] + "-" + parts[1] + "-" + parts[0];
        }

        throw new IllegalArgumentException("Formato de fecha inv" + fecha);
    }

    // La parte de client360Procs() la dejo igual que en tu archivo,
    // porque el contenido que recibí termina cortado en medio del método.
    private void client360Procs() throws Exception {
        VirtualKeyBoard vk = new VirtualKeyBoard();
        vk.altTab(1);
        String id = SettingsRun.getProperty("data.usuario360");
        String contrase = SettingsRun.getProperty("data.clave360");
        try {
            if (c360 == null) {
                this.c360 = new PageLogin(this.navegador);
                this.c360.maximizeBrowser();
                this.pageInicio = new PageInicioC360((BasePageWeb) this.c360);
                this.pageInicio.refresh();
                this.c360.login360(id, contrase);
                do {
                    Util.wait(3);
                    this.pageInicio.reporteAlertas();
                } while (this.pageInicio.element(LocatorsDataCredit.LOC_BIENVENIDO_MAIN_PAGE) == null);
            }
        } catch (Exception e) {
            e.printStackTrace();
        }

        Util.wait(3);
        this.pageInicio.irAModulo("Personas");
        String existe = this.pageInicio.buscarExistenciaId(this.numberId, this.tipoCliente);

        if (existe != null) {
            Reporter.reportEvent(5, MENSAJE_CLIENTE_EXISTE + this.numberId);
            Util.wait(3);
            this.pageInicio.irAModulo("Página inicial");
            this.pageInicio.reporteAlertas();
            return;
        }

        while (true) {
            Util.wait(2);
            if (this.pageInicio.element(LocatorsDataCredit.BTN_AGREGAR_PERSONA) != null) {
                this.pageInicio.agregarNuevo(LocatorsDataCredit.BTN_AGREGAR_PERSONA);
                Util.wait(1);
                this.alerta = this.pageInicio.setDatosBasicosPersonas(
                        "CEDULA DE CIUDADANIA",
                        this.numberId,
                        this.nombres,
                        this.primerApellido,
                        this.segundoApellido,
                        this.fechaNac,
                        this.fechaExp,
                        "13/01/2024"
                );

                if (this.alerta) {
                    this.pageInicio.irAModulo("Página inicial");
                    Util.wait(2);
                    this.pageInicio.irAModulo("Personas");
                    SettingsRun.exitTestIteration();
                } else {
                    this.pageInicio.setLugar(this.typeId, LocatorsDataCredit.ICONO_LUGAR_EXPEDICION,
                            LocatorsDataCredit.INPUT_LUGAR_GENERAL, LocatorsDataCredit.INPUT_SITIO_GENERAL,
                            "Ciudad", "BOGOTA", LocatorsDataCredit.BTN_ACEPTAR_GENERAL);

                    this.pageInicio.setLugar(this.typeId, LocatorsDataCredit.ICONO_LUGAR_NACIMIENTO,
                            LocatorsDataCredit.INPUT_LUGAR_GENERAL, LocatorsDataCredit.INPUT_SITIO_GENERAL,
                            "Ciudad", "BOGOTA", LocatorsDataCredit.BTN_ACEPTAR_GENERAL);

                    this.pageInicio.setTelefono(this.tipoCliente, "7306852", "BOGOTA D.C.", "PERSONAL");

                    this.pageInicio.setCorreoCelular(LocatorsDataCredit.ICONO_CORREO,
                            LocatorsDataCredit.INPUT_CORREO_UNO, LocatorsDataCredit.INPUT_CORREO,
                            "pruebasmovillabconsumo@gmail.com", LocatorsDataCredit.BTN_ACEPTAR_CORREO,
                            LocatorsDataCredit.BTN_NUEVO_CORREO);

                    this.pageInicio.setCorreoCelular(LocatorsDataCredit.ICONO_CELULAR,
                            LocatorsDataCredit.INPUT_CELULAR_UNO, LocatorsDataCredit.INPUT_CELULAR, "3144425014",
                            LocatorsDataCredit.BTN_ACEPTAR_CELULAR, LocatorsDataCredit.BTN_NUEVO_CELULAR);

                    this.pageInicio.setSubEstado();
                    Util.wait(3);
                    Reporter.reportEvent(5, MENSAJE_DATOS_BASICOS);
                    this.c360.tomarCaptura("Datos Básicos");

                    String textoEstado = this.pageInicio.extraerTxt();
                    SettingsRun.getTestData().setParameter("Estado", textoEstado);

                    this.pageInicio.irLink(LocatorsDataCredit.LOC_CAMPO_ID);
                    Util.wait(5);

                    if (this.pageInicio.existDialog()) {
                        this.pageInicio.getDriver().switchTo().alert().accept();
                    }

                    this.alerta = this.pageInicio.reporteAlertas();
                    if (this.alerta) {
                        Util.wait(2);
                        this.pageInicio.click(LocatorsDataCredit.BTN_CANCELAR_CREACION_USUARIO);
                        this.pageInicio.irAModulo("Página inicial");
                        Util.wait(2);
                        this.pageInicio.irAModulo("Personas");
                        SettingsRun.exitTestIteration();
                    } else if (!this.pageInicio.isDisplayed(LocatorsDataCredit.LOC_AUX)) {
                        this.pageInicio.irLink(LocatorsDataCredit.LOC_CAMPO_ID);
                    }

                    if (this.tipoCliente.contains(TIPO_PERSONA_NATURAL)) {
                        String msg = null;

                        if (this.pageInicio.existDialog()) {
                            msg = this.pageInicio.getMessageDialog();
                            if (msg != null && msg.contains(
                                    "La fecha de expedicidebe ser al menos 18 amayor que la fecha de nacimiento")) {
                                Reporter.reportEvent(5, msg);
                                this.pageInicio.acceptDialog();
                            }
                        }

                        if (msg == null) {
                            this.pageInicio.irAModulosPrincipales(LocatorsDataCredit.LOC_MAS_INFORMACION);
                            this.pageInicio.setMasInformacion(this.genero, "SOLTERO", "UNIVERSITARIO",
                                    "ADMINISTRACION DE NEGOCIOS", "COLOMBIA");
                            this.c360.tomarCaptura("Minformación");
                            Reporter.reportEvent(5, MENSAJE_MAS_INFORMACION);

                            this.pageInicio.irAModulosPrincipales(LocatorsDataCredit.LOC_MAS_DATOS_CONTACTO);
                            this.pageInicio.agregaNuevaDireccion("Persona Natural");
                            direccionAleatoria();

                            msg = this.pageInicio.setDireccion(
                                    direccionAleatoria(),
                                    "CORRESPONDENCIA 1 DEL NEGOCIO",
                                    "COLOMBIA",
                                    "BOGOTA, D.C.",
                                    "BOGOTA, D.C.",
                                    "BOGOTA, D.C."
                            );
                        }
                    }
                }
            }
        }
    }
