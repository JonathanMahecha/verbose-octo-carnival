import javax.swing.JOptionPane;

public static String solicitarDato(String mensaje) {

    String valor;

    do {

        valor = JOptionPane.showInputDialog(
                null,
                mensaje,
                "Ingreso de Datos",
                JOptionPane.INFORMATION_MESSAGE);

        if (valor == null) {

            JOptionPane.showMessageDialog(
                    null,
                    "Debe ingresar un valor para continuar.",
                    "Dato requerido",
                    JOptionPane.WARNING_MESSAGE);

        } else {

            valor = valor.trim();

            if (valor.isEmpty()) {

                JOptionPane.showMessageDialog(
                        null,
                        "El valor no puede estar vacío.",
                        "Dato requerido",
                        JOptionPane.WARNING_MESSAGE);
            }
        }

    } while (valor == null || valor.isEmpty());

    return valor;
}
