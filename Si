package Controllers;

import com.fasterxml.jackson.databind.ObjectMapper;
import java.nio.file.Files;
import java.nio.file.Path;
import java.nio.file.Paths;
import java.nio.charset.StandardCharsets;
import java.util.HashMap;
import java.util.Map;

public class EnviarCodigo {

    public static void main(String[] args) {
        try {
            // Leer archivo txt con tu código (compatible con Java 8)
            Path rutaEntrada = Paths.get("C:/Users/JOMAHECH/Documents/si.txt");
            String contenido = new String(
                Files.readAllBytes(rutaEntrada),
                StandardCharsets.UTF_8
            );

            // Crear estructura JSON
            Map<String, String> data = new HashMap<>();
            data.put("mensaje", contenido);

            // Convertir a JSON válido
            ObjectMapper mapper = new ObjectMapper();
            String json = mapper.writeValueAsString(data);

            // Imprimir en consola
            System.out.println(json);

            // Crear archivo de salida con el JSON
            Path rutaSalida = Paths.get("C:/Users/JOMAHECH/Documents/salida.txt");
            Files.write(rutaSalida, json.getBytes(StandardCharsets.UTF_8));

            System.out.println("Archivo creado correctamente en: " + rutaSalida);

        } catch (Exception e) {
            e.printStackTrace();
        }
    }
}
