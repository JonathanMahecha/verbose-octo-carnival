	public String cargarDestinos() throws Exception {
		this.totalDestinos = 0;
		this.valorTransaccion = 0.0D;

		if (SettingsRun.getTestData().parameterExist("Archivo Destinos")
				&& !SettingsRun.getTestData().getParameter("Archivo Destinos").trim().isEmpty()) {

			this.archivoDest = SettingsRun.getTestData().getParameter("Archivo Destinos").trim();
			String tipoCarga = SettingsRun.getTestData().getParameter("Tipo de Carga").trim();
			String filasATomar = SettingsRun.getTestData().getParameter("Filas a Tomar").trim();
			String servUpper = SettingsRun.getTestData().getParameter("Servicio").toUpperCase();

			if (!Util.directoryExist(this.archivoDest)) {
				return "El sistema no puede encontrar el archivo especificado: " + this.archivoDest;
			}

			String msgError = null;

			switch (tipoCarga) {
			case "EXCEL":
				if (filasATomar.equals("N/A")) {
					this.archivoCargar = Evidence.saveFile(this.archivoDest);
				} else {
					this.listRowExcel = Util.getListaDatos(filasATomar, ",");
					if (esNominaOProveedores(servUpper)) {
						this.archivoCargar = crearArchivoExcel_NomProv(this.archivoDest, this.listRowExcel);
					} else if (esAfc(servUpper)) {
						this.archivoCargar = crearArchivoExcel_CtasAFC(this.archivoDest, this.listRowExcel);
					} else if (esCred3ros(servUpper)) {
						this.archivoCargar = crearArchivoExcel_Cred3ros(this.archivoDest, this.listRowExcel);
					}
				}
				msgError = this.pageDestino.cargarDestinosXArchivo(tipoCarga, this.archivoCargar);
				break;

			case "PLANO":
				if (filasATomar.equals("N/A")) {
					this.archivoCargar = Evidence.saveFile(this.archivoDest);
				} else {
					this.listRowExcel = Util.getListaDatos(filasATomar, ",");
					this.archivoCargar = crearArchivoPlano_NomProv(this.archivoDest, this.listRowExcel);
				}
				msgError = this.pageDestino.cargarDestinosXArchivo(tipoCarga, this.archivoCargar);
				break;

			case "DIGITADO":
				this.listRowExcel = Util.getListaDatos(filasATomar, ",");
				if (esNominaOProveedores(servUpper)) {
					msgError = digitarDestinos_NomProv(this.archivoDest, this.listRowExcel);
				} else if (esAfc(servUpper)) {
					msgError = digitarDestinos_CtasAFC(this.archivoDest, this.listRowExcel);
				} else if (esCred3ros(servUpper)) {
					msgError = digitarDestinos_Cred3ros(this.archivoDest, this.listRowExcel);
				}
				if (msgError == null) {
					msgError = this.pageDestino.verificarContinuarCargaMasiva();
				}
				break;

			case "Archivo existente Excel":
				msgError = this.pageDestino.cargarDestinosXArchivo("EXCEL", this.archivoDest);
				break;

			case "Archivo existente Plano":
				msgError = this.pageDestino.cargarDestinosXArchivo("PLANO", this.archivoDest);
				break;
			}

			return msgError;
		} else {
			this.archivoDest = Evidence.getNbEvidenceDirectory() + File.separator + "ArchPlanoClone.txt";
			return this.pageDestino.cargarDestinosXArchivo("PLANO", this.archivoDest);
		}
	}

	private boolean esNominaOProveedores(String servicio) {
		return servicio.contains("NÓMI") || servicio.contains("NÓMINA") || servicio.contains("PROVE")
				|| servicio.contains("PROVEEDORES");
	}

	private boolean esAfc(String servicio) {
		return servicio.contains("AFC");
	}

	private boolean esCred3ros(String servicio) {
		return servicio.contains("CRÉD") || servicio.contains("CRÉDITO.3ROS");
	}

	private String digitarDestinos_NomProv(String archivoDatos, List<Integer> listRowExcel) throws Exception {
		final int EXPECTED_CELL_COUNT = 9;

		try (FileInputStream inputStream = new FileInputStream(archivoDatos);
				Workbook workbook = getWorkbook(inputStream, archivoDatos)) {

			Sheet sheet = workbook.getSheetAt(0);
			if (sheet == null) {
				Reporter.write("El archivo no contiene hojas: " + archivoDatos);
				return null;
			}

			for (int rowIndex : listRowExcel) {
				if (rowIndex <= 0) {
					continue;
				}

				Row row = sheet.getRow(rowIndex - 1);
				if (row == null) {
					continue;
				}

				String[] values = getRowCellValues(row, EXPECTED_CELL_COUNT);
				String msgError = validateAndAdicionarDestino_NomProv(values);

				if (msgError == null) {
					this.valorTransaccion += Double.valueOf(values[7]);
					this.totalDestinos++;
				} else {
					Reporter.write("Fila [" + rowIndex + "] del Excel : " + msgError);
				}
			}
		}
		return null;
	}

	private String digitarDestinos_CtasAFC(String archivoDatos, List<Integer> listRowExcel) throws Exception {
		try (FileInputStream inputStream = new FileInputStream(archivoDatos);
				Workbook workbook = getWorkbook(inputStream, archivoDatos)) {

			Sheet sheet = workbook.getSheetAt(0);

			for (int rowIndex : listRowExcel) {
				Row row = sheet.getRow(rowIndex - 1);
				if (row != null) {
					String[] values = getRowCellValues(row, 5);
					String msgError = validateAndAdicionarDestino_CtasAFC(values);

					if (msgError == null) {
						this.valorTransaccion += Double.valueOf(values[4]);
						this.totalDestinos++;
					} else {
						Reporter.write("Fila [" + rowIndex + "] del Excel : " + msgError);
					}
				}
			}
		}
		return null;
	}

	private String digitarDestinos_Cred3ros(String archivoDatos, List<Integer> listRowExcel) throws Exception {
		try (FileInputStream inputStream = new FileInputStream(archivoDatos);
				Workbook workbook = getWorkbook(inputStream, archivoDatos)) {

			Sheet sheet = workbook.getSheetAt(0);

			for (int rowIndex : listRowExcel) {
				Row row = sheet.getRow(rowIndex - 1);
				if (row != null) {
