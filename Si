    private void procesarCobrosYContadores() throws Exception {
        String tipoCobro       = param("Tipo Prueba Cobros");
        String verificarCombo  = resultsMiddle.get(0).get("Verificacion Combo");

        boolean tieneCombo = verificarCombo != null && verificarCombo.contains("Empresa tiene combo");

        if (tieneCombo && (tipoCobro.equals("COBROS CON COMBOS") || tipoCobro.equals("COBROS SIN COMBOS"))) {
            int totalTx = Integer.parseInt(resultsMiddle.get(0).get("Cantidad Tx Acumuladas"));
            if (totalTx > 0) {
                validarContadoresEnMiddle(verificarCombo);
                reportarSumaCobros(true);
            } else {
                info("No se ha aplicado sumatoria de tx porque no se aplicó ningún descuento");
            }
        } else {
            reportarSumaCobros(false);
        }
    }

    /** Reporta la suma de cobros aplicados e indica si hay contador de combo. */
    private void reportarSumaCobros(boolean tieneContador) throws Exception {
        if (!tieneContador) {
            info("*** Cobros realizados en esta transacción - Los cobros sin combos no aplican contador");
        } else {
            info("*** Cobros realizados en esta transacción");
        }

        double suma = 0;
        for (int i = 0; i < validacionDescuento.length; i++) {
            suma += validacionDescuento[i];
            info("Valor de cobro " + (i + 1) + ": " + validacionDescuento[i]);
        }
        info("*** Total cobros realizados: " + suma);

        if (!tieneContador) SettingsRun.exitTestIteration();
    }

    private void validarContadoresEnMiddle(String verificarCombo) throws Exception {
        DatosEmpresarial.loadLoginDataFija("0",
                globalData("MIDDLE.tipoDoc"),
                globalData("MIDDLE.numeroDeId"),
                globalData("MIDDLE.clavePersonal"),
                globalData("MIDDLE.tipoToken"),
                globalData("MIDDLE.numeroToken"));

        pageLoginPyme = new PageLoginPymes();
        pageLoginPyme.loginMiddle();
        pageLoginPyme.selecionambienteClose(SI);

        controllerValiPymeMiddle = new ControllerValiPymeMiddle(pageLoginPyme);
        controllerMiddleCobros   = new ControllerMiddleCobros(pageLoginPyme);
        controllerMiddleCobros.contadorFinal(ControllerCrearTx.getTotalContador(), verificarCombo);
        pageLoginPyme.CerrarSesionMiddle();
    }

