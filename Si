	public void setTemporalTime(Date fechaTx) { this.fechaTxTemp = fechaTx; }

	public void setTime() throws Exception {
		String today = "";
		String hour = "";
		if (this.fechaTxTemp != null) {
			today = DXCUtil.dateToString(this.fechaTxTemp, "yyyy-mm-dd");
			hour = DXCUtil.hourToString(this.fechaTxTemp, "HH:mm:ss");
		}
		set(MR_FECHA, today);
		set(MR_HORA, hour);
	}

