    /**
     * Retorna el tipo de producto normalizado a partir del texto recibido.
     *
     * @param tipoProdUpper Texto con el tipo de producto (ej. "Cuenta de Ahorros").
     * @return Cadena normalizada: "Cuenta Ahorros", "Cuenta Corriente", "Tarjeta Crédito" o "No Aplica".
     */
    public String TipoProd(String tipoProdUpper) {
        String u = tipoProdUpper.toUpperCase();
        if (u.contains("AHORRO"))   return "Cuenta Ahorros";
        if (u.contains("CORRIENTE")) return "Cuenta Corriente";
        if (u.contains("CRÉDITO") || u.contains("CREDITO")) return "Tarjeta Crédito";
        return "No Aplica";
    }

