	/**
	 * Selecciona origen con convenio de servicio (Pagos de Servicios).
	 */
	public String seleccionarOrigen(String servicio, String tipoDocumento, String numeroDoc,
			String numConvenio, String tipoProducto, String numeroProducto) throws Exception {

		// BUG CORREGIDO: loop sin sleep
		while (element(this.locPasoPage) == null) {
			Util.wait(1);
		}

		// Seleccionar convenio en el dropdown de servicio
		if (element(this.xPathServicio) != null) {
			String selecc = "- " + numConvenio;
			selectListContainsItems(By.xpath(this.xPathServicio), new String[]{ selecc });

			String textoSeleccionado = getText(By.xpath(this.xPathServicio));

			// BUG CORREGIDO: condición invertida – si no se seleccionó el convenio, retornar error
			if (!textoSeleccionado.contains(selecc)) {
				return "Error en lista 'Servicio a pagar': convenio [" + numConvenio
						+ "] no seleccionado. Valor actual: " + textoSeleccionado;
			}
		}

		// Esperar tabla de orígenes con límite de tiempo
		// BUG CORREGIDO: contador > 240 → contador < 240 (el loop nunca esperaba antes)
		WebElement objTablaOrigenes = null;
		int contador = 1;
		do {
			Util.wait(1);
			contador++;
			objTablaOrigenes = element(this.locTitTabOr);
		} while (objTablaOrigenes == null && contador < 240);

		String msgError = this.pagePortalPymes.getMsgAlertIfExist(new String[]{ "lblMasterAlerta" });
		if (msgError != null) {
			return "Error en lista 'Servicio a pagar' : " + msgError;
		}

		return seleccionarOrigen(servicio, tipoDocumento, numeroDoc, tipoProducto, numeroProducto);
	}

	/**
	 * Selecciona origen en el flujo de pagos automáticos con convenio.
	 */
	public String seleccionarOrigenAuto(String numConvenio, String tipoProducto, String numeroProducto,
			String tipoProductoSec, String numeroProductoSec) throws Exception {

		// BUG CORREGIDO: loop sin sleep
		while (element(this.locPasoPage) == null) {
			Util.wait(1);
		}

		// Seleccionar convenio en el dropdown de automáticos
		if (element(this.xPathServicioAutomaticos) != null) {
			// BUG CORREGIDO: se captura el resultado correctamente
			String msgSeleccion = selectListContainsItems(By.xpath(this.xPathServicioAutomaticos),
					new String[]{ numConvenio });

			// BUG CORREGIDO: condición era "msgError == null || !msgError.isEmpty()" (retornaba error cuando
			// no había error). Correcto: retornar error solo si hay mensaje de error real.
			if (msgSeleccion != null && !msgSeleccion.isEmpty()) {
				return "Error en lista 'Servicio a pagar' : " + msgSeleccion;
			}
		}

		// Esperar tabla de orígenes
		// BUG CORREGIDO: contador > 120 → contador < 120
		WebElement objTablaOrigenes = null;
		int contador = 1;
		do {
			Util.wait(1);
			contador++;
			objTablaOrigenes = element(this.locTitTabOrAut);
			if (contador >= 120) {
				Reporter.reportEvent(1, "TimeOut");
				if (objTablaOrigenes == null) {
					Reporter.reportEvent(1, "No se presento el Titulo");
				}
			}
		} while (objTablaOrigenes == null && contador < 120);

		String msgError = this.pagePortalPymes.getMsgAlertIfExist(new String[]{ "lblMasterAlerta" });
		if (msgError != null) {
			return "Error en lista 'Servicio a pagar' : " + msgError;
		}

		msgError = seleccionarOrigenAutomatico(tipoProducto, numeroProducto, "1");
		Util.wait(2);

		if (!tipoProductoSec.isEmpty() && !numeroProductoSec.isEmpty()) {
			msgError = seleccionarOrigenAutomatico(tipoProductoSec, numeroProductoSec, "2");
		}

		click(this.locButtonSig);
		return msgError;
	}

