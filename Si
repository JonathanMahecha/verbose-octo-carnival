public String getNombreBanco(String valor) {

    if (valor == null || valor.trim().isEmpty()) {
        return null;
    }

    String buscar = Util.removeAccents(valor)
            .toUpperCase()
            .trim();

    // Caso 1: viene un código
    for (Map.Entry<String, String> entry : catalogoXNombre.entrySet()) {

        if (entry.getValue().equals(buscar)) {
            return entry.getKey();
        }
    }

    // Caso 2: viene el nombre exacto
    if (catalogoXNombre.containsKey(buscar)) {
        return buscar;
    }

    // Caso 3: viene una parte del nombre
    for (String nombreBanco : catalogoXNombre.keySet()) {

        if (nombreBanco.contains(buscar)
                || buscar.contains(nombreBanco)) {

            return nombreBanco;
        }
    }

    return null;
}
