    /** Cierra la sesión del primer aprobador e itera por los aprobadores restantes. */
    public void aprobarConFirmasRestantes(int totalFirmas, boolean aprobarDesdeDetalle) throws Exception {
        pageLoginPyme.CerrarSesionFront();

        for (int i = 2; i <= totalFirmas; i++) {
            Frontfirmas(i);
            procesarAprobacionSegunServicio(i, totalFirmas, aprobarDesdeDetalle);
            pageLoginPyme.CerrarSesionFront();

            if (i == totalFirmas && DatosDavivienda.IS_RISKMOTOR) {
                validarIngresoMotorRiesgoSegunServicio();
            }
        }
    }

    private void procesarAprobacionSegunServicio(int firmaActual, int totalFirmas,
                                                  boolean aprobarDesdeDetalle) throws Exception {
        boolean esUltima        = (firmaActual == totalFirmas);
        boolean esInternacional = servicio.contains("Internacionales");
        boolean esPagosAuto     = servicio.contains("Pagos Automaticos");

        if (esPagosAuto) {
            new PageTransaccionesProgramadas(pageLoginPyme).ConsultaPagosAutomatico();
        } else if (esInternacional) {
            Util.wait(10);
            controller.aprobarTxPendienteIntern(true);
            if (esUltima) ejecutarConsultaTransaccionesInternacionales();
        } else {
            controller = new ControllerCrearTx(pageLoginPyme);
            if (SI.equals(realizarMR)) controller.SetPrioridaMr(riesgo);
            Util.wait(10);
            controller.aprobarTxPendiente(aprobarDesdeDetalle);
            if (esUltima) {
                controller.validacionSaldosStratus();
                ejecutarConsultaYExtractos();
            }
        }
    }

    private void ejecutarConsultaYExtractos() throws Exception {
        pageConsultasyExtractos = new PageConsultasyExtractos(pageLoginPyme);
        pageConsultasyExtractos.ConsultayExtractos(servicio, paramTrimmed("Navegador"),
                tipoIDEmpresa, numeroIDEmpresa, tipoIdentificacion, Idusuario,
                paramTrimmed("Tipo producto origen / Franquicia"),
                paramTrimmed("Número producto origen"), true, instanciaStratus);
    }

    private void ejecutarConsultaTransaccionesInternacionales() throws Exception {
        pageConsultatxInternacional = new PageConsultatxInternacional(pageLoginPyme);
        sincronizarFechaHora();
        estado = param("Estado");
        pageConsultatxInternacional.ConsultaNumtx(tipoPrueba, empresa, servicio, usuario,
                tipoConstaTxRealizadas, ordenanteBeneficiario, tipoTranferencia, estado,
                tipoMoneda, fechaTx, horaTx, fechaDesde, fechaHasta, valorTx);
        pageConsultatxInternacional.getDriver().switchTo().defaultContent();
    }

    /** Rellena fechaTx y horaTx desde el Excel si aún están vacíos. */
    private void sincronizarFechaHora() {
        if (isEmpty(fechaTx) || isEmpty(horaTx)) {
            fechaTx = param("Fecha tx");
            horaTx  = param("Hora tx");
        }
    }

    private void validarIngresoMotorRiesgoSegunServicio() throws Exception {
        if (SERVICIOS_NOMINA_PROVEEDORES.contains(servicio)) {
            controller.validarIngresoMRDestinosMasivo();
        } else {
            controller.validarIngresoMR();
        }
    }

