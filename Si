	/**
	 * Patrón click-celda / write-input repetido en toda la clase.
	 */
	private void clickAndWrite(By tdLocator, By inputLocator, String value) {
		this.click(tdLocator);
		this.write(inputLocator, value);
	}

	private WebElement waitForModuleElement(String modulo) {
		WebElement btModulo = fluentWaitForElement(By.xpath("//a[@title='" + modulo + "']"), TIMEOUT_MODULO);
		// Fallback al método original con cadena selector del framework
		if (btModulo == null) {
			btModulo = this.element("a", "title:=" + modulo);
		}
		return btModulo;
	}

	/**
	 * Reemplaza el loop manual: while(element==null) { wait; contador++; }
	 * Unifica los dos sabores originales (-1 y maxAttempts > 0).
	 */
	private void waitForElementWithTimeout(By locator, int maxAttempts) {
		int seconds = (maxAttempts > 0)
				? maxAttempts * DEFAULT_WAIT_SECONDS
				: TIMEOUT_DEFAULT;
		fluentWaitForElement(locator, seconds);
	}

	/**
	 * Reemplaza: while(!element.isEnabled()) { wait(3); }
	 */
	private void waitUntilEnabled(By locator) {
		try {
			new WebDriverWait(getDriver(), TIMEOUT_DEFAULT)
					.until(ExpectedConditions.elementToBeClickable(locator));
		} catch (Exception ignored) { }
	}

