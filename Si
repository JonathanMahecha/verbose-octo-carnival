    /** Valida y actualiza el código CIIU de la empresa en Cliente 360. */
    public void ValidarCCIU(String numeroIDEmpresa) throws Exception {
        pageInicioC360.irAModulo(PageInicioC360.MOD_PAGINA_INICIAL);

        String reportMsg = pageEmpresasC360.buscarEmpresaC360(numeroIDEmpresa);
        if (!reportMsg.isEmpty()
                && !reportMsg.contains("El cliente no ha actualizado")
                && !reportMsg.contains("ACTUALIZADO")) {
            pageInicioC360.terminarIteracion(Reporter.MIC_NOEXEC, "[ERROR DATA] " + reportMsg);
            return;
        }

        pass("Se ha encontrado la empresa con el número de identificación [" + numeroIDEmpresa + "]");

        pageInicioC360.guardar();
        pageInicioC360.existDialog();
        Util.wait(2);

        if (!pageInicioC360.existDialog()) {
            pageInicioC360.cerrarSesion();
            pageInicioC360 = null;
            return;
        }

        String msgPopup = pageInicioC360.getMessageDialog();
        pageInicioC360.acceptDialog();

        if (!isEmpty(msgPopup) && msgPopup.contains("Dígito de verificación no válido")) {
            info("No se realizó la actualización de los datos en Cliente 360: " + msgPopup);
            pageInicioC360.closeAllBrowsers();
            pageInicioC360 = null;
        }
    }

