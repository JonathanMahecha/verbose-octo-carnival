public String getNombreBanco(String valorBuscar) {

    if (valorBuscar == null || valorBuscar.trim().isEmpty()) {
        return null;
    }

    String valorNormalizado = Util.removeAccents(valorBuscar)
                                  .trim()
                                  .toUpperCase();

    for (Map.Entry<String, String> entry : catalogoXNombre.entrySet()) {

        String nombreBanco = Util.removeAccents(entry.getKey())
                                 .trim()
                                 .toUpperCase();

        String codigoBanco = entry.getValue()
                                  .trim()
                                  .toUpperCase();

        if (nombreBanco.equals(valorNormalizado)
                || nombreBanco.contains(valorNormalizado)
                || valorNormalizado.contains(nombreBanco)
                || codigoBanco.equals(valorNormalizado)) {

            return entry.getKey();
        }
    }

    return null;
}
