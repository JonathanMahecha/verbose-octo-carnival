package dav.pymes.moduloCrearTx;

import java.util.*;

import org.openqa.selenium.By;

import dav.pymes.PagePortalPymes;
import dav.Consultas_Y_Extractos.PageConsultasyExtractos;
import dav.transversal.DatosDavivienda;
import library.common.Util;
import library.core.BasePageWeb;
import library.reporting.Evidence;
import library.reporting.Reporter;
import library.settings.SettingsRun;
import screens.actions.consulta.StratusProductos;

public class ControllerCrearTx {

    // ================== PAGES ==================
    private PagePortalPymes portal;
    private PageOrigen origen;
    private PageDestino destino;
    private PageValores valores;
    private PageConfirmacion confirmacion;
    private PageConsultasyExtractos consultas;

    // ================== VARIABLES ==================
    private String servicio;
    private String tipoPrueba;
    private String adenda;
    private String numAprobaciones;
    private boolean unaFirma;

    private String tipoCta;
    private String numCta;

    private String referencia1;
    private String referencia2;

    private String valor;
    private String descripcion;

    private String saldoInicial;
    private String saldoFinal;

    private StratusProductos stratus;

    // ================== CONSTRUCTOR ==================
    public ControllerCrearTx(BasePageWeb parent) throws Exception {

        portal = new PagePortalPymes(parent);
        origen = new PageOrigen(parent);
        destino = new PageDestino(parent);
        valores = new PageValores(parent);
        confirmacion = new PageConfirmacion(parent);
        consultas = new PageConsultasyExtractos(parent);

        loadData();
    }

    // ================== DATA ==================
    private void loadData() {

        servicio = get("Servicio");
        tipoPrueba = get("Tipo prueba", "Tx En Línea");
        adenda = get("Adenda", "NO");

        numAprobaciones = get("Números de Aprobaciones", "1");
        unaFirma = numAprobaciones.equals("1");

        tipoCta = get("Tipo producto origen / Franquicia");
        numCta = get("Número producto origen");

        referencia1 = get("Referencia1 / Tipo Producto Destino");
        referencia2 = get("Referencia2 / Número Producto Destino");

        valor = get("Valor a Pagar / Transferir", "1");
        descripcion = get("Descripcion", "TX");
    }

    private String get(String key) {
        return get(key, null);
    }

    private String get(String key, String def) {
        if (SettingsRun.getTestData().parameterExist(key)) {
            String v = SettingsRun.getTestData().getParameter(key);
            if (v != null && !v.trim().isEmpty()) return v.trim();
        }
        return def;
    }

    // ================== FLUJO BASE ==================
    private void flujoBase(boolean soloGuardar, Runnable accionDestino) throws Exception {

        irACrearTx();

        seleccionarOrigen();

        accionDestino.run();

        String msg = confirmacion.waitPantallaConfirmar("");
        if (msg != null) error(msg);

        confirmar(soloGuardar);

        if (!DatosDavivienda.IS_RISKMOTOR && stratus != null && unaFirma) {
            validarSaldos();
        }
    }

    // ================== NAVEGACION ==================
    private void irACrearTx() throws Exception {

        String menu = portal.getTextMid();

        String opcion = menu.contains("Pagos") ? "Pagos, Transferencias y otros" : "Pagos y Transferencias";

        String msg = portal.irAOpcion("Crear Transacción", opcion, "Crear Transacción");

        if (msg != null) error(msg);

        msg = origen.irAServicio(servicio);

        if (msg != null) error(msg);
    }

    private void seleccionarOrigen() throws Exception {

        String msg = origen.seleccionarOrigen(servicio, null, null, tipoCta, numCta);

        if (msg != null) error(msg);
    }

    // ================== CONFIRMACION ==================
    private void confirmar(boolean soloGuardar) throws Exception {

        String rta;

        if (soloGuardar) {
            rta = confirmacion.guardarSinAprobar();
        } else {
            rta = confirmacion.aprobarTx(0, true);
        }

        if (rta == null || rta.isEmpty()) {
            error("Respuesta vacía");
        }

        Reporter.write("Resultado TX: " + rta);
    }

    // ================== ERRORES ==================
    private void error(String msg) throws Exception {

        Reporter.reportEvent(Reporter.MIC_FAIL, msg);
        Evidence.save("ERROR", portal);
        portal.terminarIteracion();
    }

    // ================== TX ==================

    public void crearPagoServicios(boolean soloGuardar) throws Exception {

        flujoBase(soloGuardar, () -> {
            try {
                String err = destino.ingresarReferencia(referencia1, referencia2);
                if (err != null) error(err);

                valores.ingresarValor(valor);

            } catch (Exception e) {
                throw new RuntimeException(e);
            }
        });
    }

    public void crearTransferencia(boolean soloGuardar) throws Exception {

        flujoBase(soloGuardar, () -> {
            try {
                String err = destino.seleccionarDestino(referencia1, referencia2);
                if (err != null) error(err);

                valores.ingresarValores(valor, descripcion, "");

            } catch (Exception e) {
                throw new RuntimeException(e);
            }
        });
    }

    public void crearPagoMasivo(boolean soloGuardar) throws Exception {

        flujoBase(soloGuardar, () -> {
            try {
                valores.ingresarDescripcion("Masivo");
            } catch (Exception e) {
                throw new RuntimeException(e);
            }
        });
    }

    // ================== VALIDACION ==================
    private void validarSaldos() throws Exception {

        double inicial = parse(saldoInicial);
        double fin = parse(saldoFinal);

        double diff = Math.abs(fin - inicial);

        Reporter.reportEvent(Reporter.MIC_INFO, "Saldo inicial: " + inicial);
        Reporter.reportEvent(Reporter.MIC_INFO, "Saldo final: " + fin);
        Reporter.reportEvent(Reporter.MIC_INFO, "Diff: " + diff);

        if (diff > 1) {
            Reporter.reportEvent(Reporter.MIC_WARNING, "Diferencia detectada");
        } else {
            Reporter.reportEvent(Reporter.MIC_PASS, "Validación OK");
        }
    }

    private double parse(String v) {
        try {
            return Double.parseDouble(v.replace(",", ""));
        } catch (Exception e) {
            return 0;
        }
    }
}
