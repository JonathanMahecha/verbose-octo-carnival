public String obtenerFechaHoraPortal() {

    String fecha = "";
    String hora = "";

    try {

        WebElement fechaElement = element(
                By.xpath("//span[@id='cphCuerpo_lblFecha']")
        );

        WebElement horaElement = element(
                By.xpath("//span[@id='cphCuerpo_lblHora']")
        );

        if (fechaElement != null && fechaElement.isDisplayed()) {
            fecha = getText(fechaElement);
        }

        if (horaElement != null && horaElement.isDisplayed()) {
            hora = getText(horaElement);
        }

    } catch (Exception e) {

        Reporter.reportEvent(
                1,
                "No se pudo obtener fecha/hora del portal"
        );
    }

    return fecha + " " + hora;
}

private double convertirMonedaADouble(String valor) {

    if (valor == null || valor.trim().isEmpty()) {
        return 0;
    }

    try {

        return Double.parseDouble(
                valor.replace("$", "")
                     .replace(".", "")
                     .replace(",", ".")
                     .trim()
        );

    } catch (Exception e) {

        Reporter.reportEvent(
                1,
                "Error convirtiendo valor monetario: " + valor
        );

        return 0;
    }
}

private String limpiarTextoFinanciero(String valor) {

    if (valor == null) {
        return "";
    }

    return valor.replace("$", "")
                .replace(".", "")
                .replace(",", "")
                .trim();
}

private boolean textoSeguroContiene(String origen,
                                    String comparar) {

    return origen != null
            && comparar != null
            && origen.contains(comparar);
}

private boolean textoSeguroIgual(String origen,
                                 String comparar) {

    return origen != null
            && comparar != null
            && origen.equals(comparar);
}

