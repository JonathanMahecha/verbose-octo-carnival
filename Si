                               .trim();

    String numFIC = obtenerNumeroFicCompleto(tipFIC);
    Date fechaTx = obtenerFechaTx(datos);
    double valorTxD = Double.parseDouble(valorTx);

    DataSheetBack.TO_MAIL = SettingsRun.getGlobalData("SAF.correoDataBack");

    new DataSheetBackSAF().setRegistro(servicio, tipoDoc, numDoc, numFIC, valorTxD, fechaTx, "");
}

private void procesarBackFACT(List<String> datos) throws Exception {

    String[] datosTitular = { tipoIDEmpresa, numeroIDEmpresa };
    String[] arrayVents = { MovimientoStratus.VENT_INDIC };

    String tipo = datos.get(0);
    String numFIC = SettingsRun.getTestData()
                               .getParameter("Número producto origen")
                               .trim();

    Date fechaTx = obtenerFechaTx(datos);

    if (numFIC.length() <= 4) {
        instanciaStratus = LoginStratus();
        instanciaStratus.getDatosPantallaSaldos(tipoIDEmpresa, numeroIDEmpresa, tipo, numFIC);
        numFIC = instanciaStratus.getNumProdCompleto();
    }

    List<MovimientoStratus> movimientos = instanciaStratus.getAllMovimientosEnRango(
            "TARJETA_CREDITO",
            numFIC,
            arrayVents,
            fechaTx,
            2,
            datosTitular
    );

    String talon = obtenerTalonMovimiento(movimientos);
    Reporter.reportEvent(Reporter.MIC_INFO, "Talon encontrado: " + talon);

    double valorTxD = Double.parseDouble(valorTx);

    DataSheetBack.TO_MAIL = SettingsRun.getGlobalData("SAF.correoDataBack");

    new DataSheetBackFACT().setRegistro(
            CommonAs400.TIPO_TX_TDC_PAGO,
            "Pyme",
            numFIC,
            valorTxD,
            0.0,
            CommonAs400.MONEDA_TDC_COP,
            fechaTx,
            null,
            talon,
            false
    );
}

private String obtenerNumeroFicCompleto(String tipFIC) throws Exception {

    String numFIC = SettingsRun.getTestData()
                               .getParameter("Número producto origen")
                               .trim();

    if (numFIC.length() > 4) {
        return numFIC;
    }

    instanciaStratus = LoginStratus();
    instanciaStratus.getDatosPantallaSaldos(tipoIDEmpresa, numeroIDEmpresa, tipFIC, numFIC);

    return instanciaStratus.getNumProdCompleto();
}

private Date obtenerFechaTx(List<String> datos) throws Exception {
    return new SimpleDateFormat("dd/MM/yyyy - HH:mm")
            .parse(datos.get(1) + " - " + datos.get(2));
}

private String obtenerTalonMovimiento(List<MovimientoStratus> movimientos) {

    if (movimientos == null || movimientos.isEmpty()) {
        return "";
    }

    for (MovimientoStratus movimiento : movimientos) {
        String raw = movimiento.toString()
                               .replace("[INDIC: ", "")
                               .replace("]", "")
                               .trim();

        String[] partes = raw.split("\\|");
        if (partes.length >= 4) {
            return partes[3].trim();
        }
    }

    return "";
}

