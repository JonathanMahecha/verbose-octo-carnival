    private WebElement waitForElement(By locator, int timeout) throws Exception {
        int count = 0;
        WebElement element;
        do {
            Util.wait(1);
            element = element(locator);
            count++;
        } while (element == null && count < timeout);

        return element;
    }

    private String normalizarTipoProducto(String tipoProducto, boolean automatico) {
        if (tipoProducto == null) return "";

        String upper = tipoProducto.toUpperCase();

        if (upper.contains("AHORROS")) return "ahorro";
        if (upper.contains("CORRIENTE")) return "corriente";
        if (upper.contains("DIPLUS")) return "diplus";

        if (upper.contains("EXPRES") || upper.contains("REDIEXPRESS")) {
            if (upper.contains("OMPANITA")) return "ompanita";
            if (upper.contains("EMP PYME 22")) return "emp pyme 22";
            return "rediexpress";
        }

        if (upper.contains("AGROPECUARIA")) return "Tarjetas agropecuaria";
        if (upper.contains("DINERS")) return "Tarjeta Diners Empresarial";
        if (upper.contains("CLMASTERCARD") || upper.contains("CLASICA MASTERCARD")) return "ClMastercard";
        if (upper.contains("MASTERCARD")) return "Empresarial mastercard";
        if (upper.contains("VISA")) return "Empresarial visa";

        if (upper.contains("FAMILIARES")) {
            return automatico
                    ? "Tarjeta crsociedades familiares"
                    : "Tarjeta Credito Sociedades Familiares";
        }

        if (upper.contains("GARANTIZADA PLATINUM VISA")) return "Garantizada Platinum Visa";
        if (upper.contains("TARJETA VISA SIGNATURE")) return "Tarjeta Visa Signature";

        return tipoProducto;
    }

    private WebElement buscarProductoOrigen(String tipoProducto, String numeroProducto, String posicion, boolean automatico) throws Exception {

        String tipoNormalizado = normalizarTipoProducto(tipoProducto, automatico);
        String ultimosDigitos = Util.right(numeroProducto, 4);

        if (!tipoProducto.toUpperCase().contains("FIC")) {

            String xpath = automatico
                    ? xPathRBOrigenAuto.replace("NUM_PROD", ultimosDigitos)
                                       .replace("TIPO_PROD", tipoNormalizado)
                                       .replace("POS", posicion)
                    : xPathRBOrigen.replace("NUM_PROD", ultimosDigitos)
                                    .replace("TIPO_PROD", tipoNormalizado);

            return element(xpath);
        }

        String xpathFic = automatico
                ? xPathRBOrigenFicAuto.replace("NUM_PROD", ultimosDigitos)
                : xPathRBOrigenFic.replace("NUM_PROD", ultimosDigitos);

        List<WebElement> lista = findElements(By.xpath(xpathFic));

        for (WebElement radio : lista) {
            String tipoTabla = getText(element(radio, this.locTipoPruebaFic));

            if (!Util.itemContainsAnyArrayItem(tipoTabla.toUpperCase(), arrTipoProdNoFic)) {
                return radio;
            }
        }

        return null;
    }
