    /**
     * Ubica la pantalla en la opción "Crear Transacción" del menú
     * "Pagos, Transferencias..." y selecciona el servicio configurado.
     */
    public void inicioCrearTx() throws Exception {
        String pagoyTx = this.pagePortalPymes.getTextMid();
        String seccion = resolverSeccionMenu(pagoyTx);

        String msgError = esChromeNav()
                ? pagePortalPymes.irAOpcion("Crear Transacción", seccion, "Crear Transacción")
                : pagePortalPymes.irAOpcionMoZilla("Crear Transacción", seccion, "Crear Transacción", null, null);

        if (msgError != null) this.terminarIteracionXError(msgError);

        msgError = pageOrigen.irAServicio(this.servicio);

        if (msgError != null && this.servicio.contains("Cuenta Inscrita")) {
            msgError = pageOrigen.irAServicio("Hacia un tercero con Productos inscritos");
        }
        if (msgError != null && this.servicio.contains("Cuenta No Inscrita")) {
            msgError = pageOrigen.irAServicio("Hacia un tercero con Productos NO inscritos");
        }

        if (msgError != null) this.terminarIteracionXError(msgError);

        this.riesgo = this.prioridaRiesgo;
    }

    /**
     * Resuelve el texto de la sección de menú según el texto del portal.
     */
    private String resolverSeccionMenu(String pagoyTx) {
        if (pagoyTx.contains("Pagos, Transferencias y otros"))
            return "Pagos, Transferencias y otros";
        if (pagoyTx.contains("Pagos, Transferencias y Otros"))
            return "Pagos, Transferencias y Otros";
        if (pagoyTx.contains("Pagos, Transferencias e Inscripciones"))
            return "Pagos, Transferencias e Inscripciones";
        if (pagoyTx.contains("Pagos, Transferencias e inscripciones"))
            return "Pagos, Transferencias e inscripciones";
        return "Pagos y Transferencias";
    }

