	// ============================================================

	private String procesarAprobacionesMultiples(boolean primeroGuardar) throws Exception {
		if (this.estado == null) this.estado = "Todas";

		if (this.estado.contains("Pendiente de Aprobación")) {
			if (primeroGuardar) aprobarTxPendienteIntern(true);
		} else {
			boolean requiereAprobacion = primeroGuardar && this.servicio.contains("Internacionales")
					&& !this.servicio.contains("Aprobación");
			boolean requiereAprobacionMR = primeroGuardar && this.servicio.contains("Internacionales") && IS_RISKMOTOR;

			if (requiereAprobacion || requiereAprobacionMR) aprobarTxPendienteIntern(true);
		}

		return ejecutarFlujoPorNumeroFirmas(primeroGuardar);
	}

	private String ejecutarFlujoPorNumeroFirmas(boolean primeroGuardar) throws Exception {
		this.numAprobaciones = param("Números de Aprobaciones");
		int numFirmas = Integer.parseInt(this.numAprobaciones);

		if (numFirmas == 1) {
			return procesarUnicaFirma(primeroGuardar);
		} else {
			return procesarMultiplesFirmas(numFirmas, primeroGuardar);
		}
	}

	private String procesarMultiplesFirmas(int numFirmas, boolean primeroGuardar) throws Exception {
		cerrarSesionDependiemdoPortal();
		String msg = null;

		for (int i = 2; i <= numFirmas; i++) {
			loginPorFirmas(i);

			if (this.servicio.contains("Internacionales")) {
				Util.wait(5);
				aprobarTxPendienteIntern(primeroGuardar);

				if (i == numFirmas) msg = ejecutarConsultaFinal();
			}

			cerrarSesionDependiemdoPortal();
		}
		return msg;
	}

	private String procesarUnicaFirma(boolean primeroGuardar) throws Exception {
		boolean esInternacionalODivisas = this.servicio.contains("Internacionales")
				|| this.servicio.contains("Divisas");
		boolean noEsAprobacionNiValidar = !this.servicio.contains("Aprobación")
				&& !this.servicio.contains("Validar");

		if (!esInternacionalODivisas || !noEsAprobacionNiValidar) return null;

		this.pageConsultatxInternacional = new PageConsultatxInternacional(this.pageDivisas);
		validarFechaHora();
		this.estado = param("Estado");

		String msg = this.pageConsultatxInternacional.ConsultaNumtx(
				this.tipoPrueba, this.nombreEmpre, this.servicio,
				tipoConstaTxRealizadas, this.ordenanteBeneficiario, this.tipoTranferencia,
				this.estado, this.tipoMoneda, this.fechaTx, this.horaTx,
				this.fechaDesde, this.fechaHasta, this.valorsin);

		if (msg != null) fail(msg);

		if (STRATUS != null) this.pageConsultatxInternacional.ValidacionesStratusConsulta();

		this.pageConsultatxInternacional.getDriver().switchTo().defaultContent();
		return msg;
	}

	private String ejecutarConsultaFinal() throws Exception {
		this.pageConsultatxInternacional = new PageConsultatxInternacional(this.pageDivisas);
		validarFechaHora();
		this.estado = param("Estado");

		String msg = this.pageConsultatxInternacional.ConsultaNumtx(
				this.tipoPrueba, this.nombreEmpre, this.servicio,
				tipoConstaTxRealizadas, this.ordenanteBeneficiario, this.tipoTranferencia,
				this.estado, this.tipoMoneda, this.fechaTx, this.horaTx,
				this.fechaDesde, this.fechaHasta, this.valorsin);

		this.pageConsultatxInternacional.getDriver().switchTo().defaultContent();
		return msg;
	}

