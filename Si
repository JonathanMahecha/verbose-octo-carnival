private void procesarAutenticacionBiometrica() throws Exception {
    String handleOriginal = getDriver().getWindowHandle();

    try {
        By tabAutenticacion = By.xpath("//button[contains(@title, 'Autenticación')]");
        WebElement btnAuth = element(tabAutenticacion);

        if (btnAuth == null) {
            return;
        }

        mouseClick(btnAuth);

        realizarAutenticacion();

        String txtValid = getText(By.xpath("//*[@class='ait-reader-text bypass-contact']"));
        if (txtValid == null || !txtValid.contains("autenticado correctamente")) {
            Reporter.reportEvent(Reporter.MIC_FAIL, "Error en el servicio de autenticación alterno.");
            closeCurrentBrowser();
            SettingsRun.exitTest();
            return;
        }

        cerrarVentanaAutenticacion(handleOriginal);
        volverAMasInformacion();

    } catch (Exception e) {
        Reporter.reportEvent(Reporter.MIC_FAIL, "Error procesando autenticación biométrica: " + e.getMessage());
        throw e;
    }
}

private void realizarAutenticacion() throws Exception {
    By iframeAuth = By.xpath("(//iframe)[1]");
    waitElements(5, element(iframeAuth));
    changeFrame(iframeAuth);

    By txtProceso = By.xpath("//span[contains(text(), 'Realice el proceso de autenticación biométrica (Escaneo de la cédula)')]");
    waitElements(5, element(txtProceso));

    By btnMetodoAlterno = By.xpath("//button[contains(text(),'Método Alterno')]");
    waitElements(10, element(btnMetodoAlterno));
    mouseClick(element(btnMetodoAlterno));

    configurarMetodoAutenticacion();
}

private void configurarMetodoAutenticacion() throws Exception {
    waitForElement(element(By.xpath("//select[@id='typeMethodo']")), 5, "");
    selectListItem(element(By.xpath("//select[@id='typeMethodo']")), "Cliente con contraseña");
    click(element(By.xpath("(//input[@name='no_si'])[1]")));

    waitForElementInteractable(element(By.xpath("//button[contains(text(), 'Autenticar')]")), 5, "");
    click(element(By.xpath("//button[contains(text(), 'Autenticar')]")));

    waitForElementInteractable(element(By.xpath("//button[contains(text(), 'Autenticar')]")), 5, "");
    click(element(By.xpath("//button[contains(text(), 'Autenticar')]")));
    Util.wait(2);
}

private void cerrarVentanaAutenticacion(String handleOriginal) {
    Set<String> handles = getDriver().getWindowHandles();

    for (String handle : handles) {
        if (!handle.equals(handleOriginal)) {
            getDriver().switchTo().window(handle);
            getDriver().close();
            break;
        }
    }

    getDriver().switchTo().window(handleOriginal);
}

private void volverAMasInformacion() throws Exception {
    try {
        By iframeAuth = By.xpath("(//iframe)[1]");
        waitForElement(element(iframeAuth), 5, "");
        changeFrame(iframeAuth);

        By btnVerMas = By.xpath("//button[@class='ait-btn-green']");
        waitForElementInteractable(element(btnVerMas), 5, "");
        click(element(btnVerMas));

        WebDriverWait wait = new WebDriverWait(getDriver(), 10);
        Alert alert = wait.until(ExpectedConditions.alertIsPresent());
        alert.accept();

        if (alert != null) {
            waitForElementInteractable(element(btnVerMas), 5, "");
            click(element(btnVerMas));
        }

        changeToDefaultFrame();
        Util.wait(1);

    } catch (Exception e) {
        System.out.println();
    }
}
