    /**
     * Procesa la validación de back-end para transacciones de Facturación o FM.
     *
     * @param datos         lista con [tipoProducto, fecha, hora] devuelta por el controller
     * @param tipoMovimiento constante de tipo de movimiento (CommonAs400.TIPO_TX_*)
     * @param esFACT        {@code true} para DataSheetBackFACT, {@code false} para DataSheetBackFM
     */
    private void procesarBack(List<String> datos, String tipoMovimiento, boolean esFACT) throws Exception {
        String[] datosTitular = {tipoIDEmpresa, numeroIDEmpresa};
        String[] arrayVents   = {MovimientoStratus.VENT_INDIC};

        String tipo   = datos.get(0);
        String numFIC = paramTrimmed("Número producto origen");
        Date   fechaTxD = obtenerFechaTx(datos);

        if (numFIC.length() <= 4) {
            instanciaStratus = LoginStratus();
            instanciaStratus.getDatosPantallaSaldos(tipoIDEmpresa, numeroIDEmpresa, tipo, numFIC);
            numFIC = instanciaStratus.getNumProdCompleto();
        }

        List<MovimientoStratus> movimientos = instanciaStratus.getAllMovimientosEnRango(
                "TARJETA_CREDITO", numFIC, arrayVents, fechaTxD, 2, datosTitular);

        String talon    = extraerTalonMovimiento(movimientos);
        double valorTxD = Double.parseDouble(valorTx);

        info("Talon encontrado: " + talon);
        DataSheetBack.TO_MAIL = globalData("SAF.correoDataBack");

        if (esFACT) {
            new DataSheetBackFACT().setRegistro(tipoMovimiento, "Pyme", numFIC, valorTxD, 0.0,
                    CommonAs400.MONEDA_TDC_COP, fechaTxD, null, talon, false);
        } else {
            new DataSheetBackFM().setRegistro(tipoMovimiento, "Pyme", numFIC, valorTxD, 0.0,
                    fechaTxD, null, talon, "NoTxATM", false);
        }
    }

    private String obtenerNumeroFicCompleto(String tipFIC) throws Exception {
        String numFIC = paramTrimmed("Número producto origen");
        if (numFIC.length() > 4) return numFIC;

        instanciaStratus = LoginStratus();
        instanciaStratus.getDatosPantallaSaldos(tipoIDEmpresa, numeroIDEmpresa, tipFIC, numFIC);
        return instanciaStratus.getNumProdCompleto();
    }

    private Date obtenerFechaTx(List<String> datos) throws Exception {
        return new SimpleDateFormat("dd/MM/yyyy - HH:mm")
                .parse(datos.get(1) + " - " + datos.get(2));
    }

    /** Extrae el talón del primer movimiento válido de la lista. */
    private String extraerTalonMovimiento(List<MovimientoStratus> movimientos) {
        if (movimientos == null || movimientos.isEmpty()) return "";

        for (MovimientoStratus m : movimientos) {
            String raw  = m.toString().replace("[INDIC: ", "").replace("]", "").trim();
            String[] partes = raw.split("\\|");
            if (partes.length >= 4) return partes[3].trim();
        }
        return "";
    }

    private void aprobarTransaccionSegunTipo(boolean guardarPrimero, boolean aprobarDesdeDetalle) throws Exception {
        if (!guardarPrimero) return;

        boolean esInternacional = servicio.contains("Internacionales");
