private void validarDescripcion(String descripcionEsperada,
                                String descripcionReal,
                                String descripcionVaciaEsperada) {

    if (!descripcionEsperada.isEmpty()) {

        if (descripcionEsperada.equals(descripcionReal)) {

            Reporter.reportEvent(0, "Adenda correcta en Descripción");

        } else {

            Reporter.reportEvent(1, "Adenda incorrecta en Descripción");
        }

    } else if (descripcionReal.equals(descripcionVaciaEsperada)) {

        Reporter.reportEvent(0, "Adenda correcta en Descripción");

    } else {

        Reporter.reportEvent(1, "Adenda incorrecta en Descripción");
    }
}

private void validarReferencia(String referenciaEsperada,
                               String referenciaReal) {

    if (!referenciaEsperada.isEmpty()) {

        if (referenciaEsperada.equals(referenciaReal)) {

            Reporter.reportEvent(0, "Adenda correcta en Referencia");

        } else {

            Reporter.reportEvent(1, "Adenda incorrecta en Referencia");
        }

    } else if ("000000000000000000000000".equals(referenciaReal)) {

        Reporter.reportEvent(0, "Adenda correcta en Referencia");

    } else {

        Reporter.reportEvent(1, "Adenda incorrecta en Referencia");
    }
}

public void TranferenciaPortalAdenda(String descripcion,
                                     String detalleVacio) throws Exception {

    String servicio = SettingsRun.getTestData()
            .getParameter("Servicio")
            .trim();

    String numAprobacion = SettingsRun.getTestData()
            .getParameter("NAprobacion")
            .trim();

    this.pageInicioMiddle.irAOpcion(
            "Transacciones Realizadas en el Portal PYME",
            "Consultas",
            new String[]{"Transacciones a Través del Portal"}
    );

    Util.wait(2);

    if (element(this.btnConsultasExtractos) != null) {
        click(this.btnConsultasExtractos);
    }

    waitForElement(this.btnDatosAdenda, TIMEOUT_MEDIO);

    click(this.btnDatosAdenda);

    waitForElement(this.tableTxAdenda, TIMEOUT_MEDIO);

    String xpathAprobacion = this.xPathLinkNumAprobacion
            .replace("NUM_APROBACION", numAprobacion);

    boolean encontrado = false;

    try {

        click(element(xpathAprobacion));
        encontrado = true;

    } catch (Exception e) {

        Reporter.reportEvent(
                0,
                "Registro no encontrado con número de aprobación " + numAprobacion
        );
    }

    Evidence.saveAllScreens("AdendaPortal", this);

    if (!encontrado) {

        Reporter.reportEvent(1, "No se encuentra el registro de la transacción");
        return;
    }

    Util.wait(4);

    if (!servicio.equals("Pago a Proveedores") && !servicio.equals("N")) {

        TransferenciaPortalDetalleReferencia(detalleVacio);
        return;
    }

    int fila = 2;
    boolean continuar = true;

    while (continuar) {

        this.pageInicioMiddle.irAOpcion(
                "Transacciones Realizadas en el Portal PYME",
                "Consultas",
                new String[]{"Transacciones a Través del Portal"}
        );

        waitForElement(this.btnDatosAdenda, TIMEOUT_MEDIO);

        click(element(xpathAprobacion));

        String xpathProveedor = this.xPathLinkNomProv
                .replace("NUM_REGISTRO", String.valueOf(fila));

        String xpathNombre = this.xPathDataNomProv
                .replace("NUM_REGISTRO", String.valueOf(fila));

        Util.wait(4);

        if (element(xpathProveedor) != null) {

            String nombreProveedor = getText(element(By.xpath(xpathNombre)));

            Reporter.reportEvent(
                    0,
                    "......" + nombreProveedor + "......"
            );

            click(By.xpath(xpathProveedor));

            Util.wait(4);

            TransferenciaPortalDetalleReferencia(detalleVacio);

            fila++;

        } else {

            continuar = false;
        }
    }
}
public String[] ExtraerDatosDe2doExcel(int fila) throws Exception {

    String rutaArchivo = SettingsRun.getTestData()
            .getParameter("Archivo Destinos");

    String[] valoresFila = new String[14];

    try (
            FileInputStream fis = new FileInputStream(new File(rutaArchivo));
            XSSFWorkbook workbook = new XSSFWorkbook(fis)
    ) {

        XSSFSheet sheet = workbook.getSheetAt(0);
        XSSFRow row = sheet.getRow(fila - 1);

        if (row == null) {
            return valoresFila;
        }

        for (int i = 0; i < 13; i++) {

            Cell cell = row.getCell(i);

            valoresFila[i] = (cell != null)
                    ? cell.toString()
                    : "";
        }

    } catch (IOException e) {

        Reporter.reportEvent(
                1,
                "Error leyendo archivo Excel: " + e.getMessage()
        );
    }

    return valoresFila;
}

public void RevisionProOrdenesDePago(String numProcesoPago,
                                     String nomProcesoPago,
                                     String cantidadPagos,
                                     String valorPagos,
                                     String convenioPago) throws Exception {

    Date fechaActual = new Date();

    String hoy = Util.dateToString(
            Util.dateAdd(fechaActual, 5, 0),
            "dd/mm/yyyy"
    );

    String manana = Util.dateToString(
            Util.dateAdd(fechaActual, 5, 1),
            "dd/mm/yyyy"
    );

    click(By.xpath("//*[@id=\"formMenu:consultas\"]"));
    click(By.xpath("//*[@id=\"formMenu:conProcPago\"]"));

    waitForElement(this.btnBuscarEstadoProceso, TIMEOUT_MEDIO);

    Evidence.save("Ventana de proceso de pago", this);

    click(this.btnBuscarEstadoProceso);

    String xpathProceso = this.xpathNumProcesoPago
            .replace("NUM_PROCESO_PAGO", numProcesoPago);

    int fila = buscarFilaProceso(xpathProceso);

    if (fila == -1) {

        Reporter.reportEvent(
                1,
                "No se encontró proceso de pago " + numProcesoPago
        );

        return;
    }

    xpathProceso = xpathProceso.replace("NUM", String.valueOf(fila));

    validarCampo(xpathProceso + "/td[1]",
            numProcesoPago,
            "Número del proceso");

    validarCampo(xpathProceso + "/td[2]",
            hoy,
            "Fecha de creación");

    validarCampo(xpathProceso + "/td[3]",
            manana,
            "Fecha vencimiento");

    validarCampo(xpathProceso + "/td[4]",
            nomProcesoPago,
            "Nombre del proceso");

    validarCampo(xpathProceso + "/td[5]",
            "No Enviado",
            "Estado");

    validarCampo(xpathProceso + "/td[6]",
            cantidadPagos,
            "Cantidad de pagos");

    validarCampoContiene(xpathProceso + "/td[8]",
            convenioPago,
            "Convenio");

    String valorPortal = getText(element(xpathProceso + "/td[7]"))
            .replace("$", "")
            .replace(",", "")
            .replace(".", "");

    if (valorPortal.contains(valorPagos)) {

        Reporter.write("*** PASSED :: Valor total correcto");

    } else {

        Reporter.write("*** FAIL :: Valor total incorrecto");
    }

    Evidence.save("Registro proceso pago encontrado", this);
}

private int buscarFilaProceso(String xpathBase) throws Exception {

    for (int i = 1; i <= 3; i++) {

        String xpath = xpathBase.replace("NUM", String.valueOf(i));

        if (element(xpath) != null) {
            return i;
        }
    }

    return -1;
}

private void validarCampo(String xpath,
                          String valorEsperado,
                          String descripcion) throws Exception {

    String valorReal = getText(element(xpath));

    if (valorEsperado.equals(valorReal)) {

        Reporter.write("*** PASSED :: " + descripcion + " correcto");
        Reporter.write("*** PASSED ------ " + valorReal);

    } else {

        Reporter.write("*** FAIL :: " + descripcion + " incorrecto");
        Reporter.write("*** FAIL ------ " + valorReal);
        Reporter.write("*** FAIL ------ " + valorEsperado);
    }
}

private void validarCampoContiene(String xpath,
                                  String valorEsperado,
                                  String descripcion) throws Exception {

    String valorReal = getText(element(xpath));

    if (valorReal.contains(valorEsperado)) {

        Reporter.write("*** PASSED :: " + descripcion + " correcto");
        Reporter.write("*** PASSED ------ " + valorReal);

    } else {

        Reporter.write("*** FAIL :: " + descripcion + " incorrecto");
        Reporter.write("*** FAIL ------ " + valorReal);
        Reporter.write("*** FAIL ------ " + valorEsperado);
    }
}

