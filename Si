public void esperarArchivo(String ruta, int timeoutSegundos) throws InterruptedException {

    Path path = Paths.get(ruta);
    int intentos = timeoutSegundos * 2;

    while (intentos > 0) {
        if (Files.exists(path)) {
            System.out.println("✅ Archivo detectado");
            return;
        }

        Thread.sleep(500);
        intentos--;
    }

    throw new RuntimeException("❌ El archivo no apareció en el tiempo esperado");
}
