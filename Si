	private static final int TIMEOUT_SHORT          = 10;  // espera corta (popups, botones)
	private static final int TIMEOUT_ELEMENT_POLL   = 15;  // reemplaza loops de 15 intentos
	private static final int TIMEOUT_POPUP          = 9;   // 3 intentos × 3 s originales
	private static final int TIMEOUT_MODULO         = 60;  // módulos de navegación
	private static final int POLL_INTERVAL_MS       = 500; // intervalo de sondeo FluentWait

	// Constantes legadas (mantenidas para compatibilidad con llamadas internas)
	private static final int MAX_WAIT_ATTEMPTS    = 20;
