        NotificacionSMS.loadTipoNotificacion(NotificacionSMS.TIPO_NOTIF_PYMES_PA_SERV);

        this.inicioCrearTx();
        this.seleccionarCtaOrigenPagosAuto();

        String msgError = pageDestino.ingresarReferenciaAutom(this.referencia1, this.referencia2, this.titul);
        if (msgError != null) this.terminarIteracionXError(msgError);

        String correo = (this.referenciasin == null || this.referenciasin.isEmpty())
                ? "davivienda@proveedores.davivienda.com"
