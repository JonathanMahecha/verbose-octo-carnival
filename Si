	/**
	 * Lee los datos de una fila del archivo Excel de destinos.
	 */
	public String[] ExtraerDatosDe2doExcel(int fila) throws Exception {
		String rutaArchivoOrpa = SettingsRun.getTestData().getParameter("Archivo Destinos");
		String[] valoresFila   = new String[14];

		try (FileInputStream fis = new FileInputStream(new File(rutaArchivoOrpa));
			 XSSFWorkbook workbook = new XSSFWorkbook(fis)) {

			XSSFSheet sheet   = workbook.getSheetAt(0);
			XSSFRow   xSSFRow = sheet.getRow(fila - 1);

			for (int i = 0; i < 13; i++) {
				Cell cell = xSSFRow.getCell(i);
				valoresFila[i] = (cell != null) ? cell.toString() : "";
			}
		} catch (IOException e) {
			e.printStackTrace();
		}

		return valoresFila;
	}

	/**
	 * Consulta saldos en Stratus antes/después de la transacción para validación cruzada.
	 */
	public void validacionSaldosStratus(String servicio, String tipoDocumento, String numeroDoc,
			String tipoCta, String numCta, boolean saldoOrigen) throws Exception {

		if (this.instanciaStratus == null) return;

		String saldoDis       = null;
		String saldoDisponible = null;
		List<String> saldoscuentasCredi = new ArrayList<>();

		if (saldoOrigen) {
			saldoDis       = obtenerSaldoDisponiblePortal(servicio, tipoCta, numCta);
			saldoDisponible = (saldoDis != null)
					? saldoDis.replace("$ ", "").replace(".", "").replace(",", ".")
					: null;

			if (!tipoCta.contains("CREDITO")) {
				List<WebElement> listaCrediexpress = findElements(By.xpath(
						this.saldoDisXpath
								.replace("NUMCUENTA", Util.right(numCta, 4))
								.replace("TIPOCUENTA", "Crediexpress")));
				for (WebElement saldoCredi : listaCrediexpress) {
					saldoscuentasCredi.add(
							saldoCredi.getText().replace("$ ", "").replace(".", "").replace(",", "."));
				}
			}
		}

		// Resolver tipo de cuenta para Stratus
		String datoValidar = Util.left(numCta, 3);
		if ((tipoCta.contains("DIPLUS") || tipoCta.contains("diplus")) && datoValidar.equals("056")) {
			String[] datosCrediplus = this.instanciaStratus.getCtaCobroCrediplus(numCta);
			tipoCta = datosCrediplus[0].contains("AH") ? "CC" : datosCrediplus[0];
		} else if ((tipoCta.contains("DIPLUS") || tipoCta.contains("diplus")) && !datoValidar.equals("056")) {
			String[] datosCrediplus = this.instanciaStratus.getCtaCobroCrediplus(numCta);
			tipoCta = datosCrediplus[0];
			numCta  = datosCrediplus[1];
		}

		if (tipoCta.contains("ompanita") || tipoCta.contains("emp pyme 22")) {
			tipoCta = "CREDITO";
		}

		String[] saldosDisponibles = this.instanciaStratus.getDatosPantallaSaldos(
				tipoDocumento, numeroDoc, tipoCta, numCta);

		if (saldosDisponibles == null) return;

		if (saldosDisponibles[0].contains("OFICINA RECAUDO O RADICACION NO EXISTE")
				|| saldosDisponibles[0].contains("TARJETA NO EXISTE")) {
			Reporter.reportEvent(5, "El Nro de cuenta: " + numCta + " " + saldosDisponibles[0]);
			return;
		}

		actualizarSaldosStratus(tipoCta, saldosDisponibles, saldoOrigen);

		if (saldoOrigen) {
			validarSaldoConPortal(tipoCta, numCta, saldoDis, saldoDisponible, saldoscuentasCredi);
		}
	}

