}

private void escribirDatosIngresosPersonas(String tipoActLaboral, String fechaInicio,
                                           String valorMensual, String tipoIngresos,
                                           String tipoContrato) {
    click(tdTipoActLaboral);
    Util.wait(2);

    if (element(inputTipoActLaboral) != null) {
        write(inputTipoActLaboral, tipoActLaboral);
    }

    click(TdFechaInicio);
    write(inputFechaInicio, fechaInicio);

    click(tdValorMensual);
    write(inputValorMensual, valorMensual);

    click(tdTipIngresoso);
    write(inputTipIngresoso, tipoIngresos);

    Util.wait(1);

    click(tdTipoContacto);
    Util.wait(1);
    write(inputTipoContrato, tipoContrato);
}

private void procesarActividadEconomicaPersonas(String detActEconomica) {
    Util.wait(1);

    By celdaActividad = By.xpath("//td[contains(@id,'Actividad_Economica_Description')]");
    click(celdaActividad);

    Util.wait(1);
    clearInputbox(By.xpath("//td[contains(@id,'Actividad_Economica_Description')]//input"));
    write(By.xpath("//td[contains(@id,'Actividad_Economica_Description')]//input"), detActEconomica);

    Util.wait(1);
    click(By.xpath("//td[contains(@id,'DAV_Ingresos')]"));
    Util.wait(2);

    if (isDisplayed(By.xpath("//span[contains(text(), 'Aceptar')]"))) {
        click(By.xpath("//span[contains(text(), 'Aceptar')]"));
    }

    Util.wait(1);

    if (element(actividadAceptar) != null) {
        click(actividadAceptar);
    }

    manejarDialogosCargoOcupacion();
}

private void manejarDialogosCargoOcupacion() {
    if (existDialog()) {
        String msg = getMessageDialog();
        if (msg != null && (msg.contains("Cargo/Ocupación") || msg.contains("recibe máximo 100 caracteres"))) {
            Reporter.reportEvent(Reporter.MIC_INFO, msg);
            acceptDialog();
        }
    }
}

private void procesarNitEmpresa(String nitEmpresa) {
    Util.wait(2);

    if (element(actividadAceptar) != null) {
        click(actividadAceptar);
    }

    if (element(tdNitEmpresa) != null && isDisplayed(tdNitEmpresa)) {
        mouseOver(tdNitEmpresa);
        mouseClick();
    }

    click(tdNitEmpresa);
    write(inputNitEmpresa, nitEmpresa);
    Util.wait(3);

    if (element(acetarNitEmpresa) != null) {
        click(acetarNitEmpresa);
    }

    if (element(tdCargoOcupacion) != null) {
        click(tdCargoOcupacion);
    }

    Util.wait(2);

    if (element(acetarNitEmpresa) != null) {
        click(acetarNitEmpresa);
    }
}

private void finalizarIngresosPersonas(String cargoOcupacion, String descripcion, String nombreEmpresa) {
    if (element(tdCargoOcupacion) != null) {
        click(tdCargoOcupacion);
    }

    Util.wait(1);

