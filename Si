public String setDireccion(String direccion,
                           String claseDireccion,
                           String pais,
                           String departamento,
                           String ciudad,
                           String municipio) throws Exception {

    this.changeToDefaultFrame();

    WebElement popup = waitForPopup();

    if (popup == null) {
        return "No fue posible visualizar el popup de Dirección";
    }

    waitForElementWithTimeout(inputDireccion, -1);

    this.write(inputDireccion, direccion);
    this.write(inputClaseDireccion, claseDireccion);
    this.write(inputPais, pais);
    this.write(inputDepartamento, departamento);
    this.write(inputCiudad, ciudad);
    this.write(inputMunicipio, municipio);

    WebElement btnCrear = this.element(btonCrear);

    if (btnCrear == null) {
        return "No fue posible encontrar el botón Crear";
    }

    btnCrear.click();

    Util.wait(1);

    if (this.reporteAlertas()) {
        return "Revise hoja de datos, los valores ingresados para la dirección no existen en C360";
    }

    return null;
}
