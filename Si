import java.util.Arrays;
import java.util.List;

public List<String> extraerDatosTransaccion() {
    waitElements(4, element(By.xpath("//*[contains(@id,'cphCuerpo_lblFecha')]")));

    String tipo = safeGetText(By.xpath("//*[contains(@id,'TipoProducto')]"));
    String fecha = safeGetText(By.xpath("//*[contains(@id,'cphCuerpo_lblFecha')]"));
    String hora = safeGetText(By.xpath("//*[contains(@id,'cphCuerpo_lblHora')]"));

    return Arrays.asList(tipo, fecha, hora);
}
