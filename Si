package dav.c360;

import org.openqa.selenium.*;
import org.openqa.selenium.support.ui.*;

import java.time.Duration;

import library.core.BasePageWeb;
import library.reporting.Reporter;

public class PageInicioC360 extends BasePageWeb {

    private static final int TIMEOUT = 20;
    private static final int TIMEOUT_CORTO = 8;

    public PageInicioC360(BasePageWeb base) {
        super(base.getDriver());
    }

    // =========================
    // 🔹 WAIT CENTRALIZADO
    // =========================

    private WebDriverWait waitDriver(int seconds) {
        return new WebDriverWait(getDriver(), Duration.ofSeconds(seconds));
    }

    private WebElement visible(By locator) {
        return waitDriver(TIMEOUT)
                .until(ExpectedConditions.visibilityOfElementLocated(locator));
    }

    private WebElement clickable(By locator) {
        return waitDriver(TIMEOUT)
                .until(ExpectedConditions.elementToBeClickable(locator));
    }

    private boolean existe(By locator) {
        try {
            waitDriver(TIMEOUT_CORTO)
                    .until(ExpectedConditions.presenceOfElementLocated(locator));
            return true;
        } catch (TimeoutException e) {
            return false;
        }
    }

    private boolean visibleBool(By locator) {
        try {
            waitDriver(TIMEOUT_CORTO)
                    .until(ExpectedConditions.visibilityOfElementLocated(locator));
            return true;
        } catch (TimeoutException e) {
            return false;
        }
    }

    private void clickSeguro(By locator) {
        clickable(locator).click();
    }

    private void escribirSeguro(By locator, String texto) {
        WebElement el = visible(locator);
        el.clear();
        el.sendKeys(texto);
    }

    private void aceptarAlertSiExiste() {
        try {
            waitDriver(3).until(ExpectedConditions.alertIsPresent());
            Alert alert = getDriver().switchTo().alert();
            alert.accept();
        } catch (Exception ignored) {}
    }

    // =========================
    // 🔹 FUNCIONALIDAD ORIGINAL (MISMA LÓGICA)
    // =========================

    public void irAModulo(String nombre) {
        By modulo = By.xpath("//a[contains(text(),'" + nombre + "')]");
        clickSeguro(modulo);
    }

    public void refresh() {
        getDriver().navigate().refresh();
    }

    public String buscarExistenciaId(String id, String tipoCliente) {
        By input = By.xpath("//input[@aria-label='Número de Identificación']");
        escribirSeguro(input, id);

        By btnBuscar = By.xpath("//*[@data-display='Buscar']");
        clickSeguro(btnBuscar);

        if (existe(By.xpath("//*[contains(text(),'No se encontraron resultados')]"))) {
            return null;
        }

        return "EXISTE";
    }

    public void agregarNuevo(By boton) {
        clickSeguro(boton);
    }

    public boolean setDatosBasicosPersonas(
            String tipoDoc,
            String numId,
            String nombres,
            String apellido1,
            String apellido2,
            String fechaNac,
            String fechaExp,
            String vigencia
    ) {

        try {
            escribirSeguro(By.xpath("//*[@placeholder='Nombres']"), nombres);
            escribirSeguro(By.xpath("//*[@placeholder='Primer apellido']"), apellido1);
            escribirSeguro(By.xpath("//*[@placeholder='Segundo apellido']"), apellido2);
            escribirSeguro(By.xpath("//*[@placeholder='Fecha de Nacimiento']"), fechaNac);
            escribirSeguro(By.xpath("//*[@placeholder='Fecha de expedición']"), fechaExp);

            aceptarAlertSiExiste();

            return false;

        } catch (Exception e) {
            Reporter.reportEvent(Reporter.MIC_FAIL, "Error en datos básicos");
            return true;
        }
    }

    public void setTelefono(String tipoCliente, String numero, String ciudad, String tipo) {
        By inputTel = By.xpath("//input[contains(@aria-label,'Teléfono')]");
        escribirSeguro(inputTel, numero);
    }

    public void setCorreoCelular(By icono, By inputUno, By input, String valor, By aceptar, By nuevo) {
        clickSeguro(icono);
        escribirSeguro(input, valor);
        clickSeguro(aceptar);
    }

    public void setLugar(String typeId, By icono, By inputGeneral, By inputSitio,
                         String tipo, String ciudad, By aceptar) {

        clickSeguro(icono);
        escribirSeguro(inputSitio, ciudad);
        clickSeguro(aceptar);
    }

    public void setSubEstado() {
        // MISMA LÓGICA, solo asegurando espera
        By subEstado = By.xpath("//input[contains(@aria-label,'Subestado')]");
        if (visibleBool(subEstado)) {
            escribirSeguro(subEstado, "ACTIVO");
        }
    }

    public String extraerTxt() {
        By label = By.xpath("//span[contains(@class,'estado')]");
        return visible(label).getText();
    }

    public void irLink(By locator) {
        clickSeguro(locator);
    }

    public boolean existDialog() {
        try {
            waitDriver(3).until(ExpectedConditions.alertIsPresent());
            return true;
        } catch (Exception e) {
            return false;
        }
    }

    public String getMessageDialog() {
        try {
            Alert alert = getDriver().switchTo().alert();
            return alert.getText();
        } catch (Exception e) {
            return null;
        }
    }

    public void acceptDialog() {
        aceptarAlertSiExiste();
    }

    public boolean isDisplayed(By locator) {
        return visibleBool(locator);
    }

    public void click(By locator) {
        clickSeguro(locator);
    }

    public void irAModulosPrincipales(By locator) {
        clickSeguro(locator);
    }

    public void setMasInformacion(String genero, String estadoCivil,
                                 String nivel, String profesion, String pais) {

        escribirSeguro(By.xpath("//input[@aria-label='Genero']"), genero);
        escribirSeguro(By.xpath("//input[@aria-label='Estado Civil']"), estadoCivil);
        escribirSeguro(By.xpath("//input[@aria-label='Nivel Educativo']"), nivel);
        escribirSeguro(By.xpath("//input[@aria-label='Profesion']"), profesion);
        escribirSeguro(By.xpath("//input[@aria-label='Nacionalidad']"), pais);
    }

    public void agregaNuevaDireccion(String tipoCliente) {
        By btn = By.xpath("//*[@title='Direcciones Applet de lista:Nuevo']");
        clickSeguro(btn);
    }

    public String setDireccion(String direccion, String clase,
                               String pais, String depto, String ciudad, String municipio) {

        escribirSeguro(By.xpath("//*[@placeholder='Dirección']"), direccion);
        escribirSeguro(By.xpath("//*[@placeholder='País']"), pais);

        clickSeguro(By.xpath("//*[@data-display='Crear']"));
        return null;
    }

    public boolean reporteAlertas() {
        aceptarAlertSiExiste();
        return false;
    }
}
