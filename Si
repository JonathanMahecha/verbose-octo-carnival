	/**
	 * Valida la adenda de una transferencia realizada a través del portal.
	 */
	public void TranferenciaPortalAdenda(String descripcion, String detalleVacio) throws Exception {
		this.pageInicioMiddle.irAOpcion("Transacciones Realizadas en el Portal PYME",
				"Consultas", new String[]{ "Transacciones a Traves del Portal" });

		String servicio       = SettingsRun.getTestData().getParameter("Servicio").trim();
		// BUG CORREGIDO: nombre de parámetro truncado "NAprobaci" → "NAprobacion"
		String numAprobacion  = SettingsRun.getTestData().getParameter("NAprobacion").trim();

		this.xPathLinkNumAprobacion = this.xPathLinkNumAprobacion.replace("NUM_APROBACION", numAprobacion);

		int j = 0;
		do {
			j++;
			Util.wait(2);
		} while (element(this.btnConsultasExtractos) == null && j < 6);

		try {
			click(this.btnConsultasExtractos);
		} catch (Exception ignored) { }

		// BUG CORREGIDO: empty do-while loops sin sleep → añadido Util.wait(1)
		while (element(this.btnDatosAdenda) == null) {
			Util.wait(1);
		}
		click(this.btnDatosAdenda);

		while (element(this.tableTxAdenda) == null) {
			Util.wait(1);
		}

		boolean encontrado = false;
		try {
			Util.wait(2);
			click(element(this.xPathLinkNumAprobacion));
			encontrado = true;
		} catch (Exception e) {
			Reporter.reportEvent(0, "Registro no encontrado con numero de aprobacion " + numAprobacion);
		}

		Evidence.saveAllScreens("1", this);
		Reporter.reportEvent(0, "------Cuenta Origen------");
		Util.wait(4);

		// BUG CORREGIDO: strings truncados "N" → "Nomina" / "Pago a Proveedores"
		boolean esNominaOProveedores = servicio.equals("Pago a Proveedores") || servicio.equals("Nomina");

		if (encontrado && !esNominaOProveedores) {
			Evidence.saveAllScreens("2", this);
			TransferenciaPortalDetalleReferencia(detalleVacio);

		} else if (encontrado && esNominaOProveedores) {
			int i = 2;
			do {
				this.pageInicioMiddle.irAOpcion("Transacciones Realizadas en el Portal PYME",
						"Consultas", new String[]{ "Transacciones a Traves del Portal" });

				while (element(this.btnDatosAdenda) == null) {
					Util.wait(1);
				}

				click(element(this.xPathLinkNumAprobacion));

				String xPathLinkNomProveedores = this.xPathLinkNomProv.replace("NUM_REGISTRO", String.valueOf(i));
				String xPathDataNomProveedores = this.xPathDataNomProv.replace("NUM_REGISTRO", String.valueOf(i));
				Util.wait(4);

				if (element(xPathLinkNomProveedores) != null) {
					WebElement locDataNomProveedores = element(By.xpath(xPathDataNomProveedores));
					Reporter.reportEvent(0, "......" + locDataNomProveedores.getText() + "......");
					Util.wait(4);
					click(By.xpath(xPathLinkNomProveedores));
					Util.wait(4);
					TransferenciaPortalDetalleReferencia(detalleVacio);
				} else {
					encontrado = false;
				}
				i++;
			} while (encontrado);

		} else {
			Reporter.reportEvent(1, "No se encuentra el registro de la transaccion");
		}
	}

