	/** Obtiene un parámetro de test data de forma segura, devuelve "" si es null. */
	private static String param(String key) {
		String value = SettingsRun.getTestData().getParameter(key);
		return value != null ? value.trim() : "";
	}

	/** Falla la iteración si el error no es null. */
	private void validarError(String error) throws Exception {
		if (error != null) fail(error);
	}

	/** Reporta fallo y termina la iteración. */
	private void fail(String msg) throws Exception {
		Reporter.reportEvent(Reporter.MIC_FAIL, msg);
		marcarFalla();
		guardarEvidenciaError(msg);
		finalizarIteracion();
	}

	private void marcarFalla() {
		SettingsRun.getTestData().setParameter(PARAM_SIGUIENTE_BLOQUE, VALOR_FALLA);
	}

	private void guardarEvidenciaError(String msgError) {
		String evidenceName = msgError
				.replace(" ", "").replaceAll("[\\\\/:*?\"<>|¡!\\.]", "").replaceAll("\\s+", "_");

		if (frontEmpresarial != null)   Evidence.save(evidenceName, frontEmpresarial);
		else if (loginFrontPyme != null) Evidence.save(evidenceName, loginFrontPyme);
	}

	private void finalizarIteracion() throws Exception {
		if (frontEmpresarial != null) {
			cerrarSesionDependiemdoPortal();
			SettingsRun.exitTestIteration();
		} else if (loginFrontPyme != null) {
			loginFrontPyme.terminarIteracion();
		} else {
			SettingsRun.exitTestIteration();
		}
	}

	private static boolean isEmptySafe(String s) {
		return s == null || s.trim().isEmpty();
	}

	private boolean contieneAlgunMensaje(String msgRta, String[] mensajes) {
		for (String m : mensajes) {
			if (msgRta.contains(m)) return true;
		}
		return false;
	}

	private boolean requiereContratacion() {
