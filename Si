        this.nombreEmpre      = getParamIfExists("Nombre Empresa");
        this.nitEmpre         = getParamIfExists("Numero ID Empresa");
        this.tipoIdEm         = getParamOrDefault("Tipo ID Empresa",          "NIT");
        this.tipoCta          = getParamIfExists("Tipo producto origen / Franquicia");
        this.numCta           = getParamIfExists("Número producto origen");
