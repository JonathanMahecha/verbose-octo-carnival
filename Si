            || !Objects.equals(emp,     lastEmpresa)
            || !Objects.equals(numAprob, lastNumAprobaciones)
            || !Objects.equals(tipoAb,  lastTipoAbono)
            || !Objects.equals(ctaIns,  lastCtaInscrita);
    }

