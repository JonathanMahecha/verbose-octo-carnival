    private static final DateTimeFormatter INPUT_FMT = DateTimeFormatter.ofPattern("yyyy/MM/dd");
    private static final DateTimeFormatter OUTPUT_FMT = DateTimeFormatter.ofPattern("dd/MM/yyyy");

    private static final String NAVEGADOR = "CHROME";
    private static final String TIPO_PERSONA_NATURAL = "Persona Natural";
    private static final String GENERO_FEMENINO = "FEMENINO";
    private static final String GENERO_MASCULINO = "MASCULINO";
    private static final String MENSAJE_PERSONA_NO_NATURAL = "La cedula no es persona natural";
    private static final String MENSAJE_EJECUCION_FALLO = "La ejecucion fallo, se continua con la siguiente iteracion";
    private static final String MENSAJE_CLIENTE_EXISTE = "Este numero de Identificacion ya esta registrado en Cliente 360: ";
    private static final String MENSAJE_DATOS_BASICOS = "Completado: Datos Básicos";
    private static final String MENSAJE_MAS_INFORMACION = "Completado: Más información";
    private static final String MENSAJE_INGRESO_DATOS = "Datos ingresados: \n [ Nombre: %s] \n [ Type ID: %s] \n [ Numero ID: %s]";

    String typeId;
