    /** Verifica si el WebDriver tiene al menos una ventana abierta. */
    public boolean hayVentanasAbiertas() {
        try {
            return !pageLoginPyme.getDriver().getWindowHandles().isEmpty();
        } catch (Exception e) {
            return false;
        }
    }

    /**
     * Espera hasta que haya exactamente 2 ventanas abiertas (timeout: 30 s).
     *
     * @return {@code true} si la condición se cumplió dentro del tiempo límite
     */
    public boolean esperarNumeroDeVentanas() {
        return new WebDriverWait(pageLoginPyme.getDriver(), 30)
                .until(ExpectedConditions.numberOfWindowsToBe(2));
    }

    private boolean esServicioDivisas(String svc) {
        return "Tx Internacionales Recibir desde el exterior".equals(svc)
            || "Tx Internacionales Enviar al exterior".equals(svc);
    }

    // =========================================================================
    // CIERRE Y LIMPIEZA
    // =========================================================================

    /** Cierra navegadores, Stratus y el Motor de Riesgo al finalizar las pruebas. */
    public void launchClose() {
        try {
            if (pageLoginPyme != null && hayVentanasAbiertas()) {
                pageLoginPyme.closeAllBrowsers();
            }

            if (SettingsRun.esIteracionFinal()) {
                if (instanciaStratus != null) instanciaStratus.closeStratus();

                SettingsRun.CREATE_FINAL_EVIDENCES_WHEN_NOPDF = false;
                if (DatosDavivienda.RISKMOTOR != null) {
                    DatosDavivienda.RISKMOTOR.cerrarMotorRiesgo();
                }

                // Segunda pasada para asegurar cierre completo
                if (pageLoginPyme != null && hayVentanasAbiertas()) {
                    pageLoginPyme.closeAllBrowsers();
                }
                if (instanciaStratus != null) instanciaStratus.closeStratus();
            }
        } catch (Exception e) {
            fail("Error en cierre: " + e.getMessage());
        }
    }

    @Override
    public void destroy() {
        launchClose();
    }
