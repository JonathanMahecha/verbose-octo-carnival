	// ============================================================
	// FLUJO PYME
	// ============================================================

	private BasePageWeb flujoPyme() throws Exception {
		normalizarAmbiente(SettingsRun.getGlobalData("data.ambienteMiddlePyme", "PROYECTOS_NUBE"));

		// Contratación Middle Pyme si se requiere
		if (requiereContratacion()) {
			String msgMiddle = inicializarYEjecutarMiddlePyme();
			validarError(msgMiddle != null ? "No se pudo Inicializar Middle: " + msgMiddle : null);
			setearNombreColumnasMiddlesEmpresa();
			ContratacionMiddlePyme();
		}

		// Login Front Pyme
		DatosEmpresarial.loadLoginData("Cliente Empresarial", "Tipo Identificación", "Id usuario",
				"Clave personal o CVE", "Tipo Token", "Semilla / Valor Estático / Celular");
		String[] data = DatosEmpresarial.getLoginData();
		Reporter.reportEvent(Reporter.MIC_INFO, "Login Front Pyme: " + Util.arrayToString(data, " - "));

		loginFrontPyme = new PageLoginPymes1(navegador, SettingsRun.RESULT_DIR + File.separator + "Temp");

		String error = loginFrontPyme.loginFront();
		cambiarAVentanaEmergente();
		validarError(error);

		loginFrontPyme.selecionambienteClose("NO");
		Util.wait(3);

		// Seleccionar empresa
		pageOrigenPyme = new PageOrigen1(loginFrontPyme);
		validarError(pageOrigenPyme.seleccionarEmpresa(nombreEmpre));

		// Configurar parámetros generales y actualizar datos CIIU si aplica
		configurarParametrosGeneralesPyme();
		actualizarDatosEmpresaPymeSiRequiere();

		// Inicializar páginas de Divisas con la sesión Pyme
		inicializarPaginasDivisas(loginFrontPyme);

		return loginFrontPyme;
	}

	// ============================================================
	// FLUJO EMPRESARIAL
	// ============================================================

	private BasePageWeb flujoEmpresarial() throws Exception {
		normalizarAmbiente(SettingsRun.getGlobalData("AMBIENTE_EMPRESARIAL"));
		setearNombreColumnasMiddlesEmpresa();

		// Contratación Middle Empresarial si se requiere
		if (requiereContratacion()) {
			ContratacionMiddleEmpresarial();
		}

		if (loginFrontEmpresarial == null || cerroSesion) {
			loginFrontEmpresarial = new PageLoginFrontEmpresarial(navegador,
					SettingsRun.RESULT_DIR + File.separator + "Temp");

			validarError(realizarLoginEmpresarial());
			CommonFrontEmpresarial.ESTA_LOGUEADO = true;

			frontEmpresarial = new PageFrontEmpresarial(loginFrontEmpresarial);
			validarError(frontEmpresarial.seleccionarEmpresa(nombreEmpre));

			actualizarDatosEmpresaSiRequiere();
			inicializarPaginasDivisas(frontEmpresarial);

			String msgDivisas = seleccionarTransferenciasInternacionales();
			validarError(msgDivisas);

			cerroSesion = false;
		}

		return frontEmpresarial;
	}

	// ============================================================
	// PROCESAMIENTO DE SERVICIO
	// Equivalente a procesarHoja() del nuevo framework.
	// Se mantiene como método de instancia porque requiere el estado cargado.
	// ============================================================

	public String transar() throws Exception {
		boolean primeroGuardar = TP_PEND_APR.equals(this.tipoPrueba);

		procesarServicio(primeroGuardar);

		return procesarAprobacionesMultiples(primeroGuardar);
	}

	private void procesarServicio(boolean primeroGuardar) throws Exception {
		switch (this.servicio) {

			case "Tx Internacionales Recibir desde el exterior":
				Recibirdinerodelexterior(primeroGuardar);
				break;

			case "Tx Internacionales Enviar al exterior":
				EnviarTransferenciasInternacionales(primeroGuardar);
				break;

			case "Tx Internacionales Enviar al exterior Pendiente Aprobación":
				if (esPyme()) inicioCrearTx();
				EnviarTransferenciasInternacionalesPendAprobacion();
				break;

			case "Divisas Documentos y Formularios":
				ejecutarDivisasDocumentosYFormularios();
				break;

			case "Consulta Tx Internacionales Validar Estado":
				ejecutarConsultaValidarEstado();
				break;

			default:
				fail("Servicio no soportado en flujo Divisas: " + this.servicio);
		}
	}

