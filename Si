public String getCodigoBanco(String valor) {

    if (valor == null || valor.trim().isEmpty()) {
        return null;
    }

    String buscar = Util.removeAccents(valor)
            .toUpperCase()
            .trim();

    // Si ya es un código existente
    if (catalogoXNombre.containsValue(buscar)) {
        return buscar;
    }

    // Coincidencia exacta por nombre
    String codigo = catalogoXNombre.get(buscar);

    if (codigo != null) {
        return codigo;
    }

    // Coincidencia parcial
    for (Map.Entry<String, String> entry : catalogoXNombre.entrySet()) {

        String nombreBanco = entry.getKey();

        if (nombreBanco.contains(buscar)
                || buscar.contains(nombreBanco)) {

            return entry.getValue();
        }
    }

    return null;
}
