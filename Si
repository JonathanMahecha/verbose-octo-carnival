    private WebElement waitForModuleElement(String modulo) {
        WebElement btModulo = element("a", "title:=" + modulo);
        int attempts = 0;

        while (btModulo == null && attempts < MAX_WAIT_ATTEMPTS) {
            waitSeconds(1);
            btModulo = element("a", "title:=" + modulo);
            attempts++;
        }
        return btModulo;
    }

    private void waitForElementWithTimeout(By locator, int maxAttempts) {
        int contador = 0;
        int attempts = (maxAttempts > 0) ? maxAttempts : MAX_WAIT_ATTEMPTS;

        while (element(locator) == null && contador < attempts) {
            waitSeconds(DEFAULT_WAIT_SECONDS);
            contador++;
        }
    }

    private void waitUntilEnabled(By locator) {
        WebElement el = element(locator);
        while (el != null && !el.isEnabled()) {
            waitSeconds(1);
            el = element(locator);
        }
    }

    private WebElement waitForPopup() {
        int intentos = 0;
        WebElement objetoPopup;

        do {
            intentos++;
            objetoPopup = element(locPopUpGeneral);
            if (objetoPopup == null && intentos <= POPUP_MAX_ATTEMPTS) {
                waitSeconds(POPUP_WAIT_SECONDS);
            }
        } while (objetoPopup == null && intentos <= POPUP_MAX_ATTEMPTS);

        return objetoPopup;
    }

