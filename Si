        this.descripcionsin   = getParamOrDefault("Descripcion",              "");
        this.desdeElDetalle   = getParamOrDefault("Desde_el_Detalle",         "NO");

        String valorRaw = getParamOrDefault("Valor a Pagar / Transferir", "1");
