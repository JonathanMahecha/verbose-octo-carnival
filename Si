package Controllers;

import java.io.File;
import java.util.Date;

import Actions.*;
import dav.library.common.DatosEmpresarial;
import library.common.Util;
import library.core.BasePageWeb;
import library.core.Controller;
import library.data.DataDrivenExcel;
import library.reporting.Reporter;
import library.settings.SettingsRun;
import pages.CorporativoPage;
import pages.actions.FrontEmpresarial.*;
import pages.actions.FrontPyme.*;

public class Controller_Breb_B implements Controller {

	// ============================================================
	public enum PortalType {
		PYME, EMPRESARIAL, CORPORATIVO
	}

	private static Controller_Breb_B instance;
	private final PortalType portalType;

	public static Controller_Breb_B getInstance(PortalType portalType) {
		if (instance == null || instance.portalType != portalType) {
			instance = new Controller_Breb_B(portalType);
		}
		return instance;
	}

	private Controller_Breb_B(PortalType portalType) {
		this.portalType = portalType;
	}

	// ============================================================
	private PageLoginFrontPyme loginPyme;
	private PageLoginFrontEmpresarial loginEmp;
	private CorporativoPage loginCorp;

	public static BasePageWeb base;

	private String tipoCli, clientEmpr, tipoID, idUsu, clavPersonal, tipoToke, semillaValo;
	private String nombEmpre, tipoIdEmpre, numeroIdEmpre;
	private String nombreAmbiente;

	private String navegador = "CHROME";
	private boolean cerroSesion = false;

	// ============================================================
	@Override
	public void inicializarSesion() throws Exception {
		cargarDatosGenerales();

		switch (portalType) {
			case PYME:
				flujoPyme();
				break;
			case EMPRESARIAL:
				flujoEmpresarial();
				break;
			case CORPORATIVO:
				flujoCorporativo();
				break;
			default:
				break;
		}

		salirFlujo();
	}

	// ============================================================
	private void flujoPyme() throws Exception {
		loginPyme = loginFrontPyme();
		base = loginPyme;

		seleccionarEmpresaPyme();
		loginPyme.ingresarModuloBre();
		procesarHoja(DataDrivenExcel.MAIN_SHEET);
	}

	private void flujoEmpresarial() throws Exception {
		loginEmp = loginEmpresarial();
		base = loginEmp;

		seleccionarEmpresaEmpresarial();
	}

	private void flujoCorporativo() throws Exception {
		loginCorp = loginCorporativo();
		base = loginCorp;

		procesarHoja(DataDrivenExcel.MAIN_SHEET);
	}

	// ============================================================
	private PageLoginFrontPyme loginFrontPyme() throws Exception {
		normalizarAmbiente(nombreAmbiente);

		DatosEmpresarial.loadLoginData(
				"Cliente empresarial",
				"Tipo identificacion",
				"Id usuario",
				"Clave personal o CVE",
				"Tipo token",
				"Semilla / Valor estatico / Celular");

		String[] data = DatosEmpresarial.getLoginData();

		log("Login Front: " + Util.arrayToString(data, " - "));

		PageLoginFrontPyme page = new PageLoginFrontPyme(navegador);
		Date inicio = new Date();

		String error = page.realizarLogin(data[0], data[1], data[2], data[4], data[3], data[5]);
		if (error != null) {
			fail(error);
		}

		Reporter.reportTimer("Login", inicio, new Date());
		return page;
	}

	// ============================================================
	private PageLoginFrontEmpresarial loginEmpresarial() throws Exception {
		normalizarAmbiente(nombreAmbiente);

		if (loginEmp == null || cerroSesion) {
			String evidenceDir = SettingsRun.RESULT_DIR + File.separator + "Temp";
			loginEmp = new PageLoginFrontEmpresarial(navegador, evidenceDir);

			String error = loginEmp.realizarLogin(clientEmpr, tipoID, idUsu, clavPersonal, tipoToke, semillaValo);
			if (error != null) {
				fail(error);
			}
		}

		return loginEmp;
	}

	private CorporativoPage loginCorporativo() throws Exception {
		normalizarAmbiente(nombreAmbiente);

		if (loginCorp == null || cerroSesion) {
			loginCorp = new CorporativoPage(navegador);
			loginCorp.hacerLogin(clientEmpr, tipoID, idUsu, clavPersonal, semillaValo);
			Util.wait(1);

			String error = loginCorp.selectEmpresa(nombEmpre);
			if (error != null) {
				fail(error);
			}
		}
		return loginCorp;
	}

	// ============================================================
	private void seleccionarEmpresaPyme() throws Exception {
		PageFrontPyme page = new PageFrontPyme(base);

		Util.wait(1);
		String error = page.seleccionarEmpresa(nombEmpre);
		if (error != null) {
			fail(error);
		}
	}

	private void seleccionarEmpresaEmpresarial() throws Exception {
		PageFrontEmpresarial page = new PageFrontEmpresarial(base);

		String error = page.seleccionarEmpresa(nombEmpre);
		if (error != null) {
			fail(error);
		}
	}

	// ============================================================
	private void procesarHoja(String hoja) throws Exception {
		switch (hoja) {
			case "Registros":
				new Page_Registro_Breb_b(base).registrarLlave(
						param("Tipo de registros"),
						param("Nombre de la llave a vincular"),
						param("Actividad comercial"),
						param("Ciudad"),
						param("Direccion"),
						param("Complemento direccion"),
						param("Numero celular"),
						param("Correo"),
						param("Informacion complementaria"),
						param("Tipo producto origen / Franquicia"),
						param("Numero producto origen"),
						param("Tipo de llave registro"));
				break;

			case "Consultas":
				new Page_Consultar_llaves_Breb_b(base).consultarLlave(
						param("Tipo de busqueda"),
						param("Llave a buscar"),
						param("Filtros"),
						false,
						param("Tipo cliente"));
				break;

			case "Modificar":
				new Page_Modificar_Llaves_Bre_b(base).modificarLlave(
						param("Llave a buscar"),
						param("Numero de cuenta a modificar"),
						param("Semilla / Valor estatico / Celular"),
						param("Tipo token"),
						param("Tipo cliente"));
				break;

			case "Eliminación":
				new Page_Eliminar_Llaves_Bre_b(base).eliminarLlave(
						param("Llave a buscar"),
						param("Tipo cliente"));
				break;

			case "Bloqueo_Activaciones":
				new Page_Bloqueo_activacion_Breb_b(base).desBloqLlave(
						param("Llave a buscar"),
						param("Tipo de movimiento"),
						param("Tipo cliente"));
				break;

			default:
				log("Hoja no soportada: " + hoja);
				break;
		}
	}

	// ============================================================
	private void cargarDatosGenerales() {
		tipoCli = param("Tipo cliente");
		clientEmpr = param("Cliente empresarial");
		tipoID = param("Tipo identificacion");
		idUsu = param("Id usuario");
		clavPersonal = param("Clave personal o CVE");
		tipoToke = param("Tipo token");
		semillaValo = param("Semilla / Valor estatico / Celular");

		tipoIdEmpre = param("Tipo id empresa");
		numeroIdEmpre = param("Numero id empresa");
		nombEmpre = param("Nombre empresa");

		if ("Pyme".equals(tipoCli)) {
			nombreAmbiente = SettingsRun.getGlobalData("data.ambienteFrontPyme", "PROYECTOS_NUBE");
		}

		if ("Empresarial".equals(tipoCli)) {
			// Se conserva la lógica original sin asignación de ambiente.
		}

		if ("Corporativo".equals(tipoCli)) {
			nombreAmbiente = SettingsRun.getGlobalData("data.ambienteFrontCorporativo", "AMBIENTE2");
		}
	}

	// ============================================================
	private String mapearAmbiente(String codigo) {
		if (codigo == null || codigo.trim().isEmpty()) {
			return "";
		}

		codigo = codigo.trim().toUpperCase();

		if ("Pyme".equals(tipoCli)) {
			if ("1".equals(codigo) || "POST_NUBE".equals(codigo)) return "POST_NUBE";
			if ("2".equals(codigo) || "CONTENCION_NUBE".equals(codigo)) return "CONTENCION_NUBE";
			if ("3".equals(codigo) || "PROYECTOS_NUBE".equals(codigo)) return "PROYECTOS_NUBE";
			if ("4".equals(codigo) || "PROYECTOS_SO".equals(codigo)) return "PROYECTOS_SO";
		}

		if ("Empresarial".equals(tipoCli)) {
			// Se conserva la lógica original sin mapeo.
		}

		if ("Corporativo".equals(tipoCli)) {
			if ("1".equals(codigo) || "AMBIENTE1".equals(codigo)) return "AMBIENTE1";
			if ("2".equals(codigo) || "AMBIENTE2".equals(codigo)) return "AMBIENTE2";
		}

		return "";
	}

	private void normalizarAmbiente(String ambiente) {
		String normalizado = mapearAmbiente(ambiente);

		if (normalizado.isEmpty()) {
			Reporter.reportEvent(Reporter.MIC_WARNING, "No se pudo normalizar ambiente: " + ambiente);
			return;
		}

		Reporter.reportEvent(Reporter.MIC_HEADER, "Ambiente seleccionado: " + normalizado);
		DatosEmpresarial.AMBIENTE_TEST = normalizado;
	}

	// ============================================================
	private String param(String key) {
		String v = SettingsRun.getTestData().getParameter(key);
		return v == null ? "" : v.trim();
	}

	private void fail(String msg) {
		Reporter.reportEvent(Reporter.MIC_FAIL, msg);
		throw new RuntimeException(msg);
	}

	private void log(String msg) {
		Reporter.reportEvent(Reporter.MIC_INFO, msg);
	}

	public void salirFlujo() throws Exception {
		Util.wait(1);
		if (base != null) {
			base.closeAllBrowsers();
		}
		SettingsRun.exitTestIteration();
	}

	@Override
	public void destroy() {
		if (base != null) {
			base.closeAllBrowsers();
		}

		try {
			SettingsRun.exitTestIteration();
		} catch (Exception e) {
			e.printStackTrace();
		}
	}
}
