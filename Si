    private void flujoContratacionCompleta() throws Exception {
        if (loginMiddleYMarcarAmbiente() != null) return;

        controllerValiPymeMiddle = new ControllerValiPymeMiddle(pageLoginPyme);
        numAprobaciones = requireParam(param("Números de Aprobaciones"), "Números de Aprobaciones");
        ejecutarValidacionFirmasMiddle(Integer.parseInt(numAprobaciones));

        if (SI.equals(cobros)) {
            controllerMiddleCobros = new ControllerMiddleCobros(pageLoginPyme);
            resultsMiddle = controllerMiddleCobros.consultarCombos();
        }

        boolean esDaviplata = "DAVIPLATA".equals(paramTrimmed("Referencia1 / Tipo Producto Destino"));
        if (!esDaviplata) pageLoginPyme.CerrarSesionMiddle();

        if (SI.equals(cobros) && NO.equals(realizarMR)) LoginStratus();

        Front();

        if (!esDaviplata) pageLoginPyme.CerrarSesionMiddle();
    }

    private void flujoSoloContratar() throws Exception {
        if (loginMiddleYMarcarAmbiente() != null) return;

        controllerValiPymeMiddle = new ControllerValiPymeMiddle(pageLoginPyme);
        numAprobaciones = requireParam(param("Números de Aprobaciones"), "Números de Aprobaciones");
        ejecutarValidacionFirmasMiddle(Integer.parseInt(numAprobaciones));
        pageLoginPyme.CerrarSesionMiddle();
    }

    private void flujoSoloFront() throws Exception {
        if (NO.equals(realizarMR) && SI.equals(cobros)) {
            prepararCobrosParaFlujoSoloFront();
        }
        Front();
        launchClose();
    }

    private void prepararCobrosParaFlujoSoloFront() throws Exception {
        if (SI.equals(stratus)) LoginStratus();

        PageLoginPymes middlePage = new PageLoginPymes();
        String msgError = middlePage.loginMiddle();
        PageLoginPymes.selecionambienteClose(SI);

        if (msgError != null) return;

        controllerValiPymeMiddle  = new ControllerValiPymeMiddle(middlePage);
        controllerMiddleCobros    = new ControllerMiddleCobros(middlePage);
        resultsMiddle             = controllerMiddleCobros.consultarCombos();
        middlePage.CerrarSesionMiddle();

        if (SI.equals(stratus)) {
            String segmento = resultsMiddle.get(0).get("Segmento");
            segmentosStratus = new DXCStratus(instanciaStratus).irTablaValores(segmento);
        }
    }

    private void flujoInforme() throws Exception {
        if (loginMiddleYMarcarAmbiente() != null) return;

        controllerValiPymeMiddle = new ControllerValiPymeMiddle(pageLoginPyme);
        numAprobaciones = requireParam(param("Números de Aprobaciones"), "Números de Aprobaciones");
        controllerValiPymeMiddle.ValidacionInformeTransInternacional();
    }

    /**
     * Hace login en Middle y selecciona el ambiente.
     *
     * @return mensaje de error si falló, {@code null} si fue exitoso
     */
    private String loginMiddleYMarcarAmbiente() throws Exception {
        pageLoginPyme = new PageLoginPymes();
        String msgError = pageLoginPyme.loginMiddle();
        pageLoginPyme.selecionambienteClose(SI);
        return msgError;
    }

    private void ejecutarValidacionFirmasMiddle(int totalFirmas) throws Exception {
        for (int i = 1; i <= totalFirmas; i++) {
            controllerValiPymeMiddle.ValidacionMiddlefirmas(i);
        }
    }

