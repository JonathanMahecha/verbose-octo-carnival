    /** Ejecuta las pruebas completas según la configuración del Excel. */
    public void doingTest() throws Exception {
        configurarNivelDeRiesgoActivo();
        cargarCredencialesMiddle();
        cargarParametrosComunes();

        Util.wait(1);
        ejecutarFlujoPorContratacion();
        cerrarNavegadorSiEsNecesario();
        launchClose();
    }

    private void configurarNivelDeRiesgoActivo() {
        if (!SI.equals(realizarMR)) return;

        riesgoBc = requireParam(param("Nivel de Riesgo BC"), "Nivel de Riesgo BC");

        if (!SERVICIOS_INTERNACIONALES.contains(servicio)) {
            riesgoEfm = requireParam(param("Nivel de Riesgo SAS EFM"), "Nivel de Riesgo SAS EFM");
            riesgo    = globalData("MOTOR.tipoMotor").contains("EFM") ? riesgoEfm : riesgoBc;
        } else {
            riesgo = riesgoBc;
        }
    }

    private void cargarCredencialesMiddle() throws Exception {
        DatosEmpresarial.loadLoginDataFija("0",
                globalData("MIDDLE.tipoDoc"),
                globalData("MIDDLE.numeroDeId"),
                globalData("MIDDLE.clavePersonal"),
                globalData("MIDDLE.tipoToken"),
                globalData("MIDDLE.numeroToken"));

        String[] creds = DatosEmpresarial.getLoginData();

        if (SI.equals(contratacion) || SOLO.equals(contratacion)) {
            info("*** Datos de Logueo Middle: [" + Util.arrayToString(creds, " - ") + "]");
        }

        numCliEmp = creds[0];
        tipoDoc   = creds[1];
        numDoc    = creds[2];
        clave     = creds[3];
        tipoTok   = creds[4];
        datoTok   = creds[5];

        PageLoginPymes.datosMidell(numCliEmp, tipoDoc, numDoc, clave, tipoTok, datoTok);
        PageUsuariosEmpresa.datosMidellToke(datoTok);
    }

    private void cargarParametrosComunes() {
        servicio           = requireParam(param("Servicio"),             "Servicio");
        tipoPrueba         = requireParam(param("Tipo prueba"),          "Tipo prueba");
        desde_el_Detalle   = requireParam(param("Desde_el_Detalle"),     "Desde_el_Detalle");
        empresa            = requireParam(param("Nombre Empresa"),       "Nombre Empresa");
        Idusuario          = requireParam(param("Id usuario"),           "Id usuario");
        tipoIdentificacion = requireParam(param("Tipo Identificación"),  "Tipo Identificación");
        tipoIDEmpresa      = requireParam(param("Tipo ID Empresa"),      "Tipo ID Empresa");
        numeroIDEmpresa    = requireParam(param("Numero ID Empresa"),    "Numero ID Empresa");
    }

    private void ejecutarFlujoPorContratacion() throws Exception {
        switch (contratacion) {
            case SI:           flujoContratacionCompleta(); break;
            case SOLO:         flujoSoloContratar();        break;
            case NO:           flujoSoloFront();            break;
            case MODO_INFORME: flujoInforme();              break;
            default:
                fail("Valor de CONTRATACION no reconocido: " + contratacion);
        }
    }

    private void cerrarNavegadorSiEsNecesario() {
        if (pageLoginPyme != null && hayVentanasAbiertas()) {
            pageLoginPyme.closeAllBrowsers();
        }
    }

    // =========================================================================
    // FLUJOS DE CONTRATACIÓN (MIDDLE)
