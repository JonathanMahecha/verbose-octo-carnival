    /**
     * Crea una transacción de Pago de Nómina o Proveedores.
     * Si {@code soloGuardar} es {@code true}, solo guarda sin aprobar.
     */
    public void crearPagoNomina_Proveedores(boolean soloGuardar) throws Exception {
        NotificacionSMS.loadTipoNotificacion(NotificacionSMS.TIPO_NOTIF_PYMES_PA_NOMPROV);

        this.inicioCrearTx();
        this.seleccionarCtaOrigen(false);

        if (controlDest == null)
            controlDest = new ControllerDestinosMasivos(pageDestino);

        String msgError = controlDest.cargarDestinos();
        if (msgError != null) this.terminarIteracionXError(msgError);

        if (SettingsRun.getTestData().parameterExist("Tipo de Carga")
                && !SettingsRun.getTestData().getParameter("Tipo de Carga").trim().isEmpty()) {
            if (this.servicio.contains("Nómina") || this.servicio.contains("Pago a Proveedores"))
                datoNumDestCuentas = controlDest.CuentasMasivas();
        }

        this.montoReal    = String.valueOf(controlDest.getValorTransaccion());
        this.totalDestinos = controlDest.getTotalDestinos();

        String descripcion = DatosDavivienda.IS_RISKMOTOR
                ? "PagoNomProv" + SettingsRun.getCurrentIteration()
                : this.descripcionsin;

        pageValores.ingresarDescripcion(descripcion);

        msgError = pageConf.waitPantallaConfirmar(this.pageTitle);
        if (msgError != null) this.terminarIteracionXError(msgError);

        this.accionConfirmar(soloGuardar);

        if (!DatosDavivienda.IS_RISKMOTOR && instanciaStratus != null && this.unaFirma)
            validacionSaldosStratus();

        if (soloGuardar && "SI".equals(adenda))
            this.aprobarTxPendiente(soloGuardar);

        if ("SI".equals(adenda)) {
            Reporter.reportEvent(Reporter.MIC_PASS, "*********Transferencia del Portal (Adenda)*********");
            String tipoAdenda = this.servicio.equals("Nómina") ? "Pago de Nóminas" : "Pago a Proveedores";
            this.pageOrigen.TranferenciaPortalAdenda(tipoAdenda, tipoAdenda);

            Reporter.reportEvent(Reporter.MIC_PASS, "*********Movimientos y Extractos (Adenda)*********");
            String descAdenda = this.servicio.equals("Nómina")
                    ? "Descuento para pago de Nomina"
                    : "Descuento por Pago a Proveedores";
            String tipoAdenda2 = this.servicio.equals("Nómina") ? "PAGO DE NOMINA" : "PAGO DE PROVEEDORES";
            this.Adenda(descAdenda, null, tipoAdenda2);
        }
    }

    /**
     * Crea una transacción de Pago de Servicios públicos.
     * Si {@code soloGuardar} es {@code true}, solo guarda sin aprobar.
     */
    public void crearPagoServicios(boolean soloGuardar) throws Exception {
        NotificacionSMS.loadTipoNotificacion(NotificacionSMS.TIPO_NOTIF_PYMES_PA_SERV);

        this.inicioCrearTx();
        this.seleccionarCtaOrigen(true);

        String msgError = pageDestino.ingresarReferencia(this.referencia1, this.referencia2);
        if (msgError != null) this.terminarIteracionXError(msgError);

        this.montoReal    = pageValores.ingresarValor(this.valorsin);
        this.totalDestinos = 1;
        SettingsRun.getTestData().setParameter("Valor a Pagar / Transferir", this.montoReal);

        msgError = pageConf.waitPantallaConfirmar(this.pageTitle);
        if (msgError != null) this.terminarIteracionXError(msgError);

        this.accionConfirmar(soloGuardar);

        if (!DatosDavivienda.IS_RISKMOTOR && instanciaStratus != null && this.unaFirma)
            validacionSaldosStratus();
    }

    /**
