    /** Ejecuta el flujo completo de pruebas en el portal Front. */
    public void Front() throws Exception {
        validarArchivosNecesariosSegunServicio();

        if (NO.equals(realizarMR) && SI.equals(globalData("VALIDAR.STRATUS"))) {
            instanciaStratus = LoginStratus();
            if (SI.equals(cobros)) cargarSegmentosStratusSiNoExisten();
        }

        DXCUtil.Movercursor();
        cargarDatosLoginFrontYReportar();

        numAprobaciones = requireParam(param("Números de Aprobaciones"), "Números de Aprobaciones");
        info("*** Números de firmas: [" + numAprobaciones + "]");

        if (SI.equals(realizarMR)) reportarInformacionRiesgo();
        reportarTipoPruebaYContexto();

        realizarLoginFrontConReintentos();
        if (!cambiarAVentanaEmergente()) return;

        ejecutarFlujoPorTipoDePrueba();
    }

    private void validarArchivosNecesariosSegunServicio() throws Exception {
        if (SERVICIOS_NOMINA_PROVEEDORES.contains(servicio)) {
            validarArchivoDestinos();
        } else if (esServicioQueRequiereDocumentos()) {
            validarArchivosDocumentos();
        }
    }

    private boolean esServicioQueRequiereDocumentos() {
        return SERVICIOS_INTERNACIONALES.contains(servicio)
                || "Divisas Documentos y Formularios".equals(servicio);
    }

    private void validarArchivoDestinos() throws Exception {
        String archivoDest = param("Archivo Destinos");
        if (!DXCUtil.ArchivoExist(archivoDest)) {
            Reporter.reportEvent(Reporter.MIC_NOEXEC, "No se encuentra el archivo destino: " + archivoDest);
            cerrarYSalir();
        }
    }

    private void validarArchivosDocumentos() throws Exception {
        String cargueDocu = param("Cargue Archivo Documentos");
        if (isEmpty(cargueDocu)) return;

        boolean todosExisten = true;
        for (String path : cargueDocu.split(",")) {
            if (!DXCUtil.ArchivoExist(path)) {
                info("No se encuentra archivo de cargue: " + path);
                todosExisten = false;
            }
        }
        if (!todosExisten) {
            Reporter.reportEvent(Reporter.MIC_NOEXEC, "No se encuentra archivo(s) de cargue: " + cargueDocu);
            cerrarYSalir();
        }
    }

    private void cargarSegmentosStratusSiNoExisten() throws Exception {
        String rutaArchivo = SettingsRun.getParentResultDir() + "Archivo_Segmentos.txt";

        if (DXCUtil.ArchivoExist(rutaArchivo) && DXCUtil.archivoCreadoOModificadoHoy(rutaArchivo)) {
            if (controllerDestinosMasivos == null) {
                controllerDestinosMasivos = new ControllerDestinosMasivos(null);
            }
            segmentosStratus = controllerDestinosMasivos.LeerArchivoPlano();
            return;
        }

        info("Validacion Segmento en Stratus");
        HashMap<String, Double> segs = new DXCStratus(instanciaStratus).irTablaValores("PYMES");
        if (controllerDestinosMasivos == null) {
            controllerDestinosMasivos = new ControllerDestinosMasivos(null);
        }
        controllerDestinosMasivos.CrearArchivoPlano_Segmentos(segs);
        segmentosStratus = segs;
    }

    private void cargarDatosLoginFrontYReportar() throws Exception {
        DatosEmpresarial.loadLoginData("Cliente Empresarial", "Tipo Identificación",
                "Id usuario", "Clave personal o CVE", "Tipo Token",
                "Semilla / Valor Estático / Celular");

        String[] datos = DatosEmpresarial.getLoginData();
        info("*** Navegador: [" + paramTrimmed("Navegador") + "]");
        info("*** Datos de Logueo Front: [" + Util.arrayToString(datos, " - ") + "]");
    }

    private void reportarInformacionRiesgo() {
        if (isEmpty(riesgoBc) && isEmpty(riesgoEfm)) return;

        if (globalData("MOTOR.tipoMotor").contains("EFM")) {
            info("*** Tipo de Motor de riesgo : [SAS " + globalData("MOTOR.tipoMotor") + "]");
        } else {
            info("*** Motor de riesgo : [" + globalData("tipoMotor") + "]");
        }
        info("*** Riesgo BC: [" + riesgoBc + "]");
        if (!SERVICIOS_INTERNACIONALES.contains(servicio)) {
            info("*** Riesgo EFM: [" + riesgoEfm + "]");
        }
    }

    private void reportarTipoPruebaYContexto() {
        boolean esTransaccional = TIPO_PRUEBA_EN_LINEA.equals(tipoPrueba)
                || TIPO_PRUEBA_PENDIENTE_APROBACION.equals(tipoPrueba);

        if (esTransaccional && !SOLO.equals(contratacion)) {
            info("*** Tipo Prueba: [" + tipoPrueba + "]");
