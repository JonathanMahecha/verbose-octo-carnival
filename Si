    // APROBAR TRANSACCIÓN PENDIENTE
    // =========================================================================

    /** Aprueba una transacción que está en estado "Pendiente de Aprobación". */
    public String aprobarTxPendienteIntern(boolean desdeDetalle) throws Exception {
        sincronizarFechaHora();
        pageAprobInter.inicioAprobaciones(tipoPrueba, servicio, fecha, hora, tipoMoneda);

        int retosFalla = DatosDavivienda.IS_RISKMOTOR
                ? Integer.parseInt(param("Ingresos Fallidos")) : 0;

        String msgRta = pageConf.aprobarTx(retosFalla, desdeDetalle);

        if (msgRta != null && !contieneAlgunMensaje(msgRta, MENSAJES_VALIDOS_APROBACION_PENDIENTE)) {
            terminarIteracionXError(msgRta);
        }

        if (DatosDavivienda.IS_RISKMOTOR) {
            estadoTx = msgRta;
            SetEstado(msgRta);
            if (msgRta != null && Util.itemContainsAnyArrayItem(msgRta, ARR_MSG_BUSCAR_ESTADO)) {
                estadoTx = "Transferencia Realizada";
