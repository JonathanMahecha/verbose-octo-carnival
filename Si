private String ingresarDatosInicialesFront(String numCliEmp,
                                           String tipoDoc,
                                           String numDoc) throws Exception {

    Evidence.save("LoginFront", this);

    final String SCRIPT_RELOAD = "window.location.reload(true);";

    waitElements(15, this.element(cmNumDocu));

    boolean isFront =
            DatosEmpresarial.PORTAL_FRONT_PYME.equals(this.portalCargado);

    if (isFront) {

        this.getJse().executeScript(SCRIPT_RELOAD);

        waitElements(10, this.element(cmCliente));

        this.write(this.element(cmCliente + cmTexto), numCliEmp);

        String msgError = this.selectListItem(
                this.element(cmTipoId + cmSelect),
                tipoDoc);

        if (msgError != null && !msgError.isEmpty()) {

            this.closeAllBrowsers();

            Reporter.writeErr(
                    "No se encuentra el tipo de documento: " + msgError,
                    true);

            return msgError;
        }

        this.write(this.element(cmNumDocu + cmTexto), numDoc);

        Util.presionarTecla("TAB");
    }

    String msgAlerta = null;

    if (isFront && !this.isDisplayed(this.element(cmClavePV))) {

        this.click(cmBtIngr);

        Evidence.save("Datos Iniciales", this);

        int intentos = 15;

        while (intentos-- > 0) {

            if (this.isDisplayed(this.element(cmClavePV))) {
                break;
            }

            msgAlerta = this.getMsgAlertIfExist(
                    "LbMensaje",
                    "mensajeModal");

            if (msgAlerta != null) {
                break;
            }

            Util.wait(1);
        }

        if (msgAlerta != null) {

            Evidence.save("ErrorData", this);

            if (this.isDisplayed(cmBtAcept)) {
                this.click(cmBtAcept);
            }
        }
    }

    return msgAlerta;
}
