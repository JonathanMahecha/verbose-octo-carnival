    private final By locCancelarCreacionPersona = By.xpath("//*[@title='Detalle del Personas Applet de formulario']/form/div/span/div/div[3]/button[2]");
    private final By locCancelarCreacionEmpresa = By.xpath("//*[@title='Cuenta Applet de formulario']/form/div/span/div/div[3]/button[2]");

    private final By inputNom = By.xpath("//*[@placeholder=\"Nombres\"]");
    private final By inputPrimerAp = By.xpath("//*[@placeholder='Primer apellido']");
    private final By inputSegunAp = By.xpath("//*[@placeholder='Segundo apellido']");
    private final By inputFechaExp = By.xpath("//*[@placeholder='Fecha de expedición']");
    private final By inputFechaNac = By.xpath("//*[@placeholder='Fecha de Nacimiento']");
