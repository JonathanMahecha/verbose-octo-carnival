                SettingsRun.getGlobalData("data.numIdEmp").trim(),
                SettingsRun.getGlobalData("data.numClieEmp").trim(),
                SettingsRun.getGlobalData("data.clavepersonalEmp").trim(),
                SettingsRun.getGlobalData("data.tokenEstaticoEmp").trim());
    }

    /** Cierra la sesión de Middle según el portal activo. */
    public void cierreSesionMiddle() {
        if (esPyme()) {
            if (loginFrontPyme != null) loginFrontPyme.CerrarSesionMiddle();
        } else {
            if (middleEmpresarial != null) {
                middleEmpresarial.cierreSesion();
                CommonMiddleEmpresarial.ESTA_LOGUEADO = false;
            }
        }
    }

