private String getNbLinkServicio(String servicio) {
    if (servicio == null) return "NO HAY LINK DISPONIBLE";

    String s = quitarTildes(servicio).toLowerCase();

    for (Map.Entry<List<String>, String> entry : REGLAS.entrySet()) {
        for (String keyword : entry.getKey()) {
            if (s.contains(keyword)) {
                return entry.getValue();
            }
        }
    }

    return "NO HAY LINK DISPONIBLE";
}
