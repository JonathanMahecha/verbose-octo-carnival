    private String direccionAleatoria() {
        for (int i = 0; i < 10; i++) {
            int num1 = this.random.nextInt(100) + 1;
            int num2 = this.random.nextInt(100) + 1;
            int num3 = this.random.nextInt(10) + 1;
            this.direccion = "CLL " + num1 + " " + num2 + " " + num3;
        }
        return this.direccion;
    }

