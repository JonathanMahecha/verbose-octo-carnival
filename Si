for (String desMigrada : datoNumDestCuentas) {

    if (desMigrada == null || desMigrada.trim().isEmpty())
        continue;

    if (desMigrada.startsWith("tipoProdDestino"))
        continue;

    String[] d2 = desMigrada.split("\\|");

    if (d2.length < 3)
        continue;

    if (contiene(d2[0], "DEPÓSITOS ELECTRONICOS", "DEPÓSITOS ELECTRÓNICOS"))
        d2[0] = "DEPÓSITOS ELECTRONICOS";

    if (d.length > 4
            && d2[0].equals(d[1])
            && d2[1].contains(Util.right(d[4], 4))) {

        DatosDavivienda.RISKMOTOR.setNumCuentaDestino(d2[1]);

        if (controlDest == null)
            controlDest = new ControllerDestinosMasivos(pageDestino);

        String homologada =
                controlDest.BuscarCuentasMigrada(d2[0], d2[1]);

        DatosDavivienda.RISKMOTOR.setNumCuentaOrigenMigrada(homologada);

        break;
    }
}
