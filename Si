public WebElement waitForElementInteractable(
        WebElement element,
        int timeoutSeconds,
        String descripcion) {

    try {

        WebDriverWait wait =
                new WebDriverWait(getDriver(), timeoutSeconds);

        return wait.until(
                ExpectedConditions.elementToBeClickable(element));

    } catch (Exception e) {

        if (descripcion != null && !descripcion.isEmpty()) {
            Reporter.reportEvent(
                    Reporter.MIC_FAIL,
                    "Elemento no interactuable: " + descripcion);
        }

        return null;
    }
}
