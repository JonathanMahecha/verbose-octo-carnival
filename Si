    /** Ejecuta el flujo de "Enviar transferencia al exterior". */
    public void EnviarTransferenciasInternacionales(boolean soloGuardar) throws Exception {
        NotificacionSMS.TIPO_NOTIFICACION = NotificacionSMS.TIPO_NOTIF_PYMES_TRANS_ENVIADAS;
        normalizarTipoCuenta();

        if (esPyme()) Util.wait(2);
        inicioCrearTx();

        if (!pageEnviarTransInternacional.switchToFrameDivisas()) return;

        Util.wait(2);
        String msg = pageEnviarTransInternacional.seleccionarTransferencia("Enviar");
        if (!isEmpty(msg)) { terminarIteracionXError(msg); return; }

        ejecutarFlujoEnviar(soloGuardar);
    }

    private void ejecutarFlujoEnviar(boolean soloGuardar) throws Exception {
        String msg = pageEnviarTransInternacional.closeActiveIntAlert();
        if (!isEmpty(msg) && !msg.contains("Para enviar o recibir transferencias")) {
            terminarIteracionXError(msg); return;
        }

        msg = pageEnviarTransInternacional.seleccionarCuenta(
                servicio, tipoIdEm, nitEmpre, tipoCta, numCta);
        if (!isEmpty(msg)) { terminarIteracionXError(msg); return; }

        String numeral1 = Util.left(param("Numeral cambiario 1"), 4);
        String numeral2 = Util.left(param("Numeral cambiario 2"), 4);

        msg = pageEnviarTransInternacional.ingresarValores(
                tipoMoneda, valorcon, concepto, numeral1, numeral2,
                valorNumeral1, valorNumeral2, tipoEnvio);
        if (!isEmpty(msg)) { terminarIteracionXError(msg); return; }

        msg = procesarTipoDeEnvio();
        if (!isEmpty(msg)) { terminarIteracionXError(msg); return; }

        finalizarEnvio(soloGuardar);
    }

    /**
     * Despacha al flujo correcto según si el envío es nuevo o frecuente.
     *
     * @return mensaje de error, o vacío/null si todo fue bien
     */
    private String procesarTipoDeEnvio() throws Exception {
        if ("Nuevo Envio".equals(tipoEnvio)) {
            String msg = pageEnviarTransInternacional.ingresarBeneficiario(
                    nombreBene, paisDestino, ciudadDestino, direccionBene,
                    cuentaBene, infoPago, referenciaPago, tipoEnvio);
            if (!isEmpty(msg)) return msg;
            return pageEnviarTransInternacional.datosDestino(
                    tipoCodigo, numeroCodigo, intermediario, tipoCodigoInter, numeroCodigoInter);
        }

        if ("Envio Frecuente".equals(tipoEnvio)) {
            String msg = pageEnviarTransInternacional.SeleccionarBeneficiario(
                    nombreBene, paisDestino, cuentaBene, FechaEnvioFrecuente);
            if (!isEmpty(msg)) return msg;

            msg = pageEnviarTransInternacional.ValidarBeneficiario(
                    nombreBene, paisDestino, ciudadDestino, direccionBene,
                    cuentaBene, infoPago, referenciaPago);
            if (!isEmpty(msg)) return msg;

            return pageEnviarTransInternacional.ValidaciondatosSelecDestino(
                    tipoCodigo, numeroCodigo, intermediario, tipoCodigoInter, numeroCodigoInter);
        }

        return null; // Tipo no reconocido — se ignora silenciosamente
    }

    private void finalizarEnvio(boolean soloGuardar) throws Exception {
        String msg = pageEnviarTransInternacional.cotizacion();
        if (!isEmpty(msg)) { terminarIteracionXError(msg); return; }

        msg = pageEnviarTransInternacional.confirmacion(intermediario);
        if (!isEmpty(msg)) { terminarIteracionXError(msg); return; }

        accionConfirmarInternacional(soloGuardar);
        validarSaldosStratusSiCorresponde(pageEnviarTransInternacional);
        pageDivisas.setTime(pageConf.getFechaHoraTx());
    }

    // =========================================================================
    // SALDOS STRATUS
    // =========================================================================

    /**
     * Valida saldos en Stratus cuando no hay Motor de Riesgo activo.
     * Acepta tanto {@link PageRecibirTransferenciasInternacionales} como
     * {@link PageEnviarTransInternacional} sin instanceof.
     */
    private void validarSaldosStratusSiCorresponde(PageRecibirTransferenciasInternacionales page)
            throws Exception {
        if (DatosDavivienda.IS_RISKMOTOR || DatosDavivienda.STRATUS == null) return;
        page.validacionSaldosStratus(tipoIdEm, nitEmpre, referencia1, referencia2, false);
        transferirSaldosStratus(
                page.getSaldoTotalInicialOrigen(), page.getSaldoDispoInicialOrigen(),
                page.getSaldoTotalFinalOrigen(),   page.getSaldoTotalFinalOrigen());
    }

    private void validarSaldosStratusSiCorresponde(PageEnviarTransInternacional page)
            throws Exception {
        if (DatosDavivienda.IS_RISKMOTOR || DatosDavivienda.STRATUS == null) return;
        String tipoProd = normalizarTipoProductoStratus(tipoCta);
        page.validacionSaldosStratus(servicio, tipoIdEm, nitEmpre, tipoProd, numCta, false);
        transferirSaldosStratus(
                page.getSaldoTotalInicialOrigen(), page.getSaldoDispoInicialOrigen(),
                page.getSaldoTotalFinalOrigen(),   page.getSaldoTotalFinalOrigen());
    }

    private void transferirSaldosStratus(String ini, String dis, String fin, String disFin) {
        pageConsultatxInternacional.setSaldoTotalInicial(ini);
        pageConsultatxInternacional.setSaldoDisInicial(dis);
        pageConsultatxInternacional.setSaldoTotalFinal(fin);
        pageConsultatxInternacional.setSaldoDisponibleFinal(disFin);
    }

    private void normalizarTipoCuenta() {
        String upper = this.tipoCta.toUpperCase();
        if (upper.contains("AHORRO"))    this.tipoCta = "CUENTA AHORROS";
        else if (upper.contains("CORRIENTE")) this.tipoCta = "CUENTA CORRIENTE";
    }

    private String normalizarTipoProductoStratus(String tipoCta) {
        String upper = tipoCta.toUpperCase();
        if (upper.contains("AHORROS"))   return "AHORROS";
        if (upper.contains("CORRIENTE")) return "CORRIENTE";
        return " ";
    }

