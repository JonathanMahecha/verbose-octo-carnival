private String resolverSeccionMenu(String pagoYTx) throws Exception {
    try {
        if (pagoYTx == null) {
            return "Pagos y Transferencias";
        }

        String texto = pagoYTx.toLowerCase();

        if (texto.contains("transferencias") && texto.contains("otros")) {
            return "Pagos, Transferencias y Otros";
        }

        if (texto.contains("transferencias") && texto.contains("inscripciones")) {
            return "Pagos, Transferencias e Inscripciones";
        }

        return "Pagos y Transferencias";

    } catch (Exception e) {
        Reporter.reportEvent(Reporter.MIC_FAIL, "Falla en el login del portal, por favor verificar.");
        SettingsRun.exitTestIteration();
        throw e;
    }
}
