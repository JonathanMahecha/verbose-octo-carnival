		}

		Util.wait(3);
		Evidence.save("Ventana en Estado de Pago", this, new WebElement[0]);
		click(this.btnBuscarEstadoProceso);
		Reporter.write("*** WARNING ------ **************ESTADO DE LA ORDEN DE PAGO****************");
		Util.wait(3);

		for (int i = 1; i < Integer.parseInt(cantidadPagos) + 1; i++) {
