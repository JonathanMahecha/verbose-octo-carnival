private boolean cambiarAVentanaEmergente() throws Exception {
    Util.wait(5);

    WebDriver driver = pageLoginPyme.getDriver();
    String ventanaOrigen = driver.getWindowHandle();
    List<String> ventanas = new ArrayList<>(driver.getWindowHandles());

    if (ventanas.size() < 2) {
        reportFail("No se abrio la segunda pestaña");
        SettingsRun.exitTestIteration();
        return false;
    }

    for (String handle : ventanas) {
        Util.wait(1);
        Reporter.reportEvent(Reporter.MIC_INFO, handle);

        driver.switchTo().window(handle);

        WebElement nota = pageLoginPyme.element(By.xpath("//*[contains(@id,'bugnotes')]"));
        if (pageLoginPyme.isDisplayed(nota)) {
            driver.close();

            List<String> ventanasAbiertas = new ArrayList<>(driver.getWindowHandles());
            if (ventanasAbiertas.isEmpty()) {
                reportFail("No quedaron ventanas abiertas despues de cerrar la emergente");
                SettingsRun.exitTestIteration();
                return false;
            }

            String ventanaSiguiente = ventanasAbiertas.contains(ventanaOrigen)
                    ? ventanaOrigen
                    : ventanasAbiertas.get(0);

            driver.switchTo().window(ventanaSiguiente);
            continue;
        }

        WebElement empresa = pageLoginPyme.element(By.xpath("//select[@id='dropMasterEmpresa']"));
        if (pageLoginPyme.isDisplayed(empresa)) {
            return true;
        }
    }

    if (driver.getWindowHandles().contains(ventanaOrigen)) {
        driver.switchTo().window(ventanaOrigen);
    }

    return false;
}
