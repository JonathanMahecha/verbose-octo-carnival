		reportarValidacion("Fecha Vencimiento",
				element(this.xpathNumProcesoPago + "/td[3]").getText(), ma);
		reportarValidacion("Fecha de Creacion",
				element(this.xpathNumProcesoPago + "/td[2]").getText(), today);
		reportarValidacion("Fecha de Aprobacion",
				element(this.xpathNumProcesoPago + "/td[10]").getText(), today);
