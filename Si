public class ControllerCrearTx {

    // ================= PAGES =================
    PagePortalPymes pagePortalPymes;
    PageOrigen pageOrigen;
    PageDestino pageDestino;
    PageValores pageValores;
    PageConfirmacion pageConf;
    PagePendAprobacion pagePendApr;
    PageConsultasyExtractos pageConsultasyExtractos;

    PageDivisas pageDivisas;
    PageRecibirTransferenciasInternacionales pageRecibirTransferenciasInternacionales;
    PageConsultatxInternacional pageConsultatxInternacional;
    PageAprobacionInter pageAprobInter = null;
    PageEnviarTransInternacional pageEnviarTransInternacional;
    PageDocumentos_Y_Formularios pageDocumentos_Y_Formularios;

    BaseMiddleCobros baseMiddleCobros = null;
    ControllerDestinosMasivos controlDest = null;
    StratusProductos instanciaStratus;

    // ================= VARIABLES =================
    public static String numAprobaciones = null;
    boolean unaFirma;
    String servicio;
    String nombreAmbiente = null;
    public static String tipoPrueba = null;

    String descripcionsin;
    String valorsin, valorcon;
    String referenciasin, referenciacon;

    String numerodereferenciaExterna;

    String riesgo, prioridaRiesgo, userAgent;
    public static String[] cuentasDesMotor = null, datoNumDestCuentas = null;

    public static String numeroTx = null;

    String valorTx;
    String bancoDesTx;
    String estadoTx;
    String montoReal;

    // ================= HELPERS =================
    private String getParam(String key, String def) {
        if (SettingsRun.getTestData().parameterExist(key)) {
            String val = SettingsRun.getTestData().getParameter(key);
            if (val != null && !val.trim().isEmpty()) {
                return val.trim();
            }
        }
        return def;
    }

    // ================= CONSTRUCTOR =================
    public ControllerCrearTx(BasePageWeb parentPage) throws Exception {

        this.pagePortalPymes = new PagePortalPymes(parentPage);
        this.pageOrigen = new PageOrigen(parentPage);
        this.pageDestino = new PageDestino(parentPage);
        this.pageValores = new PageValores(parentPage);
        this.pageConf = new PageConfirmacion(parentPage);
        this.pageConsultasyExtractos = new PageConsultasyExtractos(parentPage);
        this.pagePendApr = new PagePendAprobacion(parentPage);
        this.pageAprobInter = new PageAprobacionInter(parentPage);

        // ===== PARAMETROS =====
        this.servicio = getParam("Servicio", "");
        this.tipoPrueba = getParam("Tipo prueba", "Tx En Línea");
        this.adenda = getParam("Adenda", "NO");
        this.numAprobaciones = getParam("Números de Aprobaciones", "1");
        this.unaFirma = "1".equals(this.numAprobaciones);

        this.riesgoBc = getParam("Nivel de Riesgo BC", "");
        this.riesgoEfm = getParam("Nivel de Riesgo SAS EFM", "");
        this.navegador = getParam("Navegador", "CHROME");

        this.nombreEmpre = getParam("Nombre Empresa", "");
        this.nitEmpre = getParam("Numero ID Empresa", "");
        this.tipoIdEm = getParam("Tipo ID Empresa", "NIT");

        this.tipoCta = getParam("Tipo producto origen / Franquicia", "");
        this.numCta = getParam("Número producto origen", "");

        this.uuid = getParam("Hash", "");
        this.descripcionsin = getParam("Descripcion", "");

        this.valorsin = getParam("Valor a Pagar / Transferir", "1");
        this.valorcon = this.valorsin;

        this.referenciasin = getParam("Referencia", "");
        this.desdeElDetalle = getParam("Desde_el_Detalle", "NO");

        if (!servicio.contains("Nómi") && !servicio.contains("Proveedores")) {
            this.referencia1 = getParam("Referencia1 / Tipo Producto Destino", "");
            this.referencia2 = getParam("Referencia2 / Número Producto Destino", "");
        }

        if (!DatosDavivienda.IS_RISKMOTOR) {
            normalizarAmbiente();
        }
    }

    private void normalizarAmbiente() {
        String amb = SettingsRun.getGlobalData("AMBIENTE_PYME");

        switch (amb) {
            case "1":
            case "PROYECTOS":
                nombreAmbiente = "PROYECTOS"; break;
            case "2":
            case "CONTENCION":
                nombreAmbiente = "CONTENCION"; break;
            case "3":
            case "OBSOLESCENCIA":
                nombreAmbiente = "OBSOLESCENCIA"; break;
            case "4":
            case "ONPREMISE":
                nombreAmbiente = "ONPREMISE"; break;
            default:
                Reporter.reportEvent(Reporter.MIC_FAIL, "Ambiente inválido");
        }
    }

    public void inicioCrearTx() throws Exception {

        String msgError;
        String pagoyTx = pagePortalPymes.getTextMid();

        String opcion = "Pagos y Transferencias";

        if (pagoyTx.contains("Pagos, Transferencias")) {
            opcion = "Pagos, Transferencias y Otros";
        }

        if (navegador.contains("CHROME")) {
            msgError = pagePortalPymes.irAOpcion("Crear Transacción", opcion, "Crear Transacción");
        } else {
            msgError = pagePortalPymes.irAOpcionMoZilla("Crear Transacción", opcion, "Crear Transacción", null, null);
        }

        if (msgError != null) terminarIteracionXError(msgError);

        msgError = pageOrigen.irAServicio(servicio);

        if (msgError != null) terminarIteracionXError(msgError);
    }

    private void seleccionarCtaOrigen(boolean isServPublico) throws Exception {

        String msgError;

        if (isServPublico) {
            msgError = pageOrigen.seleccionarOrigen(servicio, tipoIdEm, nitEmpre, "", tipoCta, numCta);
        } else {
            msgError = pageOrigen.seleccionarOrigen(servicio, tipoIdEm, nitEmpre, tipoCta, numCta);
        }

        if (msgError != null) terminarIteracionXError(msgError);
    }

    private void ingresarValores(String tipo) throws Exception {

        String descripcion = DatosDavivienda.IS_RISKMOTOR
                ? tipo + SettingsRun.getCurrentIteration()
                : descripcionsin;

        if ("MismoNit".equals(tipo))
            pageValores.ingresarValores(valorsin, descripcion, referenciasin);

        if ("CuentaNoInscrita".equals(tipo))
            pageValores.ingresarValoresCuentaNo(valorsin, descripcion, referenciasin);

        if ("CuentaInscrita".equals(tipo))
            pageValores.ingresarValoresCuentaIsncr(valorsin, descripcion, referenciasin);

        if ("PagosPropios".equals(tipo))
            pageValores.ingresarValoresPropios(valorsin);

        String msgError = pageConf.waitPantallaConfirmar("");
        if (msgError != null) terminarIteracionXError(msgError);

        montoReal = valorsin;
        totalDestinos = 1;
    }
    private void accionConfirmar(boolean soloGuardar) throws Exception {

        String msgRta;

        if (soloGuardar) {
            msgRta = pageConf.guardarSinAprobar();

            if (msgRta == null || !msgRta.contains("EXIT")) {
                terminarIteracionXError(msgRta);
            }

        } else {
            msgRta = pageConf.aprobarTx(0, true);

            if (msgRta == null || msgRta.isEmpty()) {
                terminarIteracionXError("Error en aprobación");
            }
        }
    }

    private void terminarIteracionXError(String msgError) throws Exception {

        if (msgError == null) msgError = "Error desconocido";

        Reporter.write(msgError);

        Evidence.save(msgError.replace(" ", "_"), pageOrigen);

        Reporter.reportEvent(Reporter.MIC_FAIL, msgError);

        pagePortalPymes.terminarIteracion();
    }
    public void crearPagoServicios(boolean soloGuardar) throws Exception {

        NotificacionSMS.loadTipoNotificacion(NotificacionSMS.TIPO_NOTIF_PYMES_PA_SERV);

        inicioCrearTx();
        seleccionarCtaOrigen(true);

        String msgError = pageDestino.ingresarReferencia(referencia1, referencia2);
        if (msgError != null) terminarIteracionXError(msgError);

        montoReal = pageValores.ingresarValor(valorsin);
        totalDestinos = 1;

        msgError = pageConf.waitPantallaConfirmar("");
        if (msgError != null) terminarIteracionXError(msgError);

        accionConfirmar(soloGuardar);
    }

    public void crearTransferenciaCtaInscrita(boolean soloGuardar) throws Exception {

        NotificacionSMS.loadTipoNotificacion(NotificacionSMS.TIPO_NOTIF_PYMES_TF_CTAINSC);

        inicioCrearTx();
        seleccionarCtaOrigen(false);

        String msgError = pageDestino.seleccionarCuentaInscri(referencia1, referencia2);
        if (msgError != null) terminarIteracionXError(msgError);

        ingresarValores("CuentaInscrita");

        accionConfirmar(soloGuardar);
    }

    public void crearPagosPropios(boolean soloGuardar) throws Exception {

        NotificacionSMS.loadTipoNotificacion(NotificacionSMS.TIPO_NOTIF_PYMES_TF_MISMONIT);

        inicioCrearTx();
        seleccionarCtaOrigen(false);

        String msgError = pageDestino.seleccionarDestinoPropios(referencia1, referencia2);
        if (msgError != null) terminarIteracionXError(msgError);

        ingresarValores("PagosPropios");

        accionConfirmar(soloGuardar);
    }
}
