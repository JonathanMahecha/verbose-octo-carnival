    /** Ejecuta el flujo de "Recibir dinero del exterior". */
    public void Recibirdinerodelexterior(boolean soloGuardar) throws Exception {
        validarCamposRecibir();

        if (esPyme()) inicioCrearTx();

        if (!pageRecibirTransferenciasInternacionales.switchToFrameDivisas()) return;

        String msg = pageRecibirTransferenciasInternacionales.seleccionarTransferencia("Recibir");
        if (!isEmpty(msg)) { terminarIteracionXError(msg); return; }

        ejecutarFlujoRecibir(soloGuardar);
    }

    private void validarCamposRecibir() {
        String numCambiario1 = Util.left(param("Numeral cambiario 1"), 4);
        String numCambiario2 = Util.left(param("Numeral cambiario 2"), 4);

        List<String> faltantes = new ArrayList<>();
        if (isEmpty(numerodereferenciaExterna)) faltantes.add("Numero de referencia Externa");
        if (isEmpty(tipoMoneda))               faltantes.add("Tipo Moneda");
        if (isEmpty(concepTx))                 faltantes.add("Concepto de la transferencia");
        if (isEmpty(numCambiario1))            faltantes.add("Numeral cambiario 1");
        if (isEmpty(numCambiario2))            faltantes.add("Numeral cambiario 2");
        if (isEmpty(valorNumeral1))            faltantes.add("Valor numeral cambiario 1");
        if (isEmpty(valorNumeral2))            faltantes.add("Valor numeral cambiario 2");

        if (!faltantes.isEmpty()) {
            terminarConError("Los siguientes campos están vacíos: " + String.join(", ", faltantes));
        }
    }

    private void ejecutarFlujoRecibir(boolean soloGuardar) throws Exception {
        String numCambiario1 = Util.left(param("Numeral cambiario 1"), 4);
        String numCambiario2 = Util.left(param("Numeral cambiario 2"), 4);

        String msg = pageRecibirTransferenciasInternacionales.TxInternacionalesOrigen(
                numerodereferenciaExterna, tipoMoneda, concepTx,
                numCambiario1, numCambiario2, valorNumeral1, valorNumeral2);
        if (msg != null) { terminarIteracionXError(msg); return; }

        msg = pageRecibirTransferenciasInternacionales.seleccionarCuenta(
                tipoIdEm, nitEmpre, referencia1, referencia2);
        if (msg != null) { terminarIteracionXError(msg); return; }

        msg = pageRecibirTransferenciasInternacionales.Cotizacion();
        if (msg != null) { terminarIteracionXError(msg); return; }

        msg = pageRecibirTransferenciasInternacionales.Confirmacion();
        if (msg != null) { terminarIteracionXError(msg); return; }

        accionConfirmarInternacional(soloGuardar);
        validarSaldosStratusSiCorresponde(pageRecibirTransferenciasInternacionales);
        pageRecibirTransferenciasInternacionales.setTime(pageConf.getFechaHoraTx());
    }

