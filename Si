    /**
     * Realiza el flujo de adenda en "Movimientos y Extractos por Producto".
     *
     * @param descripcionTxOrigen  Descripción del movimiento en la cuenta origen.
     * @param descripcionTxDestino Descripción en la cuenta destino; {@code null} si no aplica.
     * @param detalleVacio         Texto de detalle vacío para la consulta.
     */
    private void Adenda(String descripcionTxOrigen, String descripcionTxDestino, String detalleVacio)
            throws Exception {
        pagePortalPymes.irAOpcion(
                "Movimientos y Extractos por Producto", "Consultas", "Movimientos y Extractos");

        String xPathRBSelect = "//select[@id='cphCuerpo_ddlproducto']";
        String xPathPO       = Util.right(this.numCta,     4);
        String xPathPD       = Util.right(this.referencia2, 4);

        Util.wait(5);

        this.pageOrigen.SeleccionarOrigenDetinoAdenda(xPathRBSelect, xPathPO);
        Reporter.reportEvent(Reporter.MIC_PASS, "------Cuenta Origen------");
        this.pageOrigen.NotaDebitoAdenda(descripcionTxOrigen, detalleVacio);

        Util.wait(6);

        if (descripcionTxDestino != null) {
            this.pageOrigen.SeleccionarOrigenDetinoAdenda(xPathRBSelect, xPathPD);
            Reporter.reportEvent(Reporter.MIC_PASS, "------Cuenta Destino------");
            this.pageOrigen.NotaDebitoAdenda(descripcionTxDestino, detalleVacio);
        }

        this.pagePortalPymes.terminarIteracion();
    }

    // ============================[Manejo de errores]=============================

    private void terminarIteracionXError(String msgError) throws Exception {
        if (msgError == null) msgError = "Error_1";

        Reporter.write(msgError);
        Evidence.save(
                msgError.replace(" ", "").replaceAll("[\\\\/:*?\"<>|¡!\\.]", "").replaceAll("\\s+", "_"),
                pageOrigen);

        if (DatosDavivienda.IS_RISKMOTOR) {
            Reporter.reportEvent(Reporter.MIC_FAIL, "No se adiciona a MR >>> " + msgError);
            Reporter.write("No se adiciona a MR >>> " + msgError);
        } else {
            Reporter.write("En construcción XQ no sé si es error >>> " + msgError);
            Reporter.reportEvent(Reporter.MIC_FAIL, msgError);
        }
        this.pagePortalPymes.terminarIteracion();
    }

    private void terminarIteracionXErrorMotor(String msgError) throws Exception {
        if (msgError == null || msgError.trim().isEmpty()) msgError = "Error_1";

        Reporter.write(msgError);
        Evidence.save(msgError.replace(" ", ""), pagePortalPymes);

        if (DatosDavivienda.IS_RISKMOTOR) {
            this.riesgo = this.prioridaRiesgo;
            if ("Alto".equals(this.riesgo)) {
                Reporter.reportEvent(Reporter.MIC_PASS, "Se adiciona a MR >>> " + msgError);
                Reporter.write("Se adiciona a MR >>> " + msgError);
            } else {
                Reporter.reportEvent(Reporter.MIC_FAIL, "Se adiciona a MR para su validación >>> " + msgError);
                Reporter.write("Se adiciona a MR para su validación >>> " + msgError);
            }
        } else {
            Reporter.write("En construcción XQ no sé si es error >>> " + msgError);
            Reporter.reportEvent(Reporter.MIC_FAIL, msgError);
        }
        this.pagePortalPymes.terminarIteracion();
    }

    // ============================[Confirmación TX]===============================

    /**
     * Ejecuta la acción de guardar o aprobar la transacción y valida el resultado.
     *
     * @param soloGuardar {@code true} para guardar sin aprobar; {@code false} para aprobar.
     */
    private void accionConfirmar(boolean soloGuardar) throws Exception {
        this.estadoTx = null;

        if (soloGuardar) {
            String msgRta = pageConf.guardarSinAprobar();

            boolean esDestinoMasivo = this.desdeElDetalle.equals("NO")
                    && (this.servicio.contains("Nómina") || this.servicio.contains("Pago a Proveedores")
                        || this.servicio.contains("AFC") || this.servicio.contains("Crédito.3ros"));

            if (esDestinoMasivo && DatosDavivienda.IS_RISKMOTOR && pagePortalPymes.CuentaDesMotor() != null)
                this.cuentasDesMotor = pagePortalPymes.CuentaDesMotor();

            if (msgRta.contains(PageConfirmacion.MSG_EXITO_DECL4)
                    || (!msgRta.contains(PageConfirmacion.MSG_EXITO_GUARD)
                        && !msgRta.contains(PageConfirmacion.MSG_EXITO_PAGO)
                        && !msgRta.contains(PageConfirmacion.MSG_EXITO_ENV_OTP)
                        && !msgRta.contains(PageConfirmacion.MSG_EXITO_APROB))) {
                this.terminarIteracionXError(msgRta);
            }

        } else {
            int numRetosFalla = resolverNumRetosFallidos();

            if (DatosDavivienda.IS_RISKMOTOR
                    && (this.servicio.contains("Nómina") || this.servicio.contains("Pago a Proveedores"))
                    && pagePortalPymes.CuentaDesMotor() != null) {
                this.cuentasDesMotor = pagePortalPymes.CuentaDesMotor();
            }

            String msgRta = pageConf.aprobarTx(numRetosFalla, true);

            if (DatosDavivienda.IS_RISKMOTOR) {
                this.estadoTx = msgRta;
                this.SetEstado(msgRta);

                if (Util.itemContainsAnyArrayItem(msgRta, arrMsgBuscarEstado)) {
                    this.estadoTx = "Transferencia Realizada";
                    Reporter.reportEvent(Reporter.MIC_INFO, msgRta);
                } else if (Util.itemContainsAnyArrayItem(msgRta, this.arrMsgTxDeclinada)) {
                    Reporter.reportEvent(Reporter.MIC_INFO, msgRta);
                    this.estadoTx = "DECLINADA";

                    this.valorTx = pageConf.getValorFinalTx();
                    if (this.valorTx != null)
                        SetActivityAmount(this.valorTx.replace("$", "").replace(" ", ""));

                    this.bancoDesTx = pageConf.getBancoDesTx();
                    if (this.bancoDesTx != null) SetBancoDesTx(this.bancoDesTx);

                    this.numeroTx = pageConf.getNumeroDocumento();

                    if (esDestinoMasivo())
                        this.validarIngresoMRDestinosMasivo();
                    else
                        this.validarIngresoMR();

                    this.pagePortalPymes.terminarIteracion();
                }
            } else {
                this.numeroTx = pageConf.getNumeroDocumento();
            }

            if (msgRta.contains(PageConfirmacion.MSG_EXITO_DECL4)
                    || (!msgRta.contains(PageConfirmacion.MSG_EXITO_GUARD)
                        && !msgRta.contains(PageConfirmacion.MSG_EXITO_PAGO)
                        && !msgRta.contains(PageConfirmacion.MSG_EXITO_ENV_OTP)
                        && !msgRta.contains(PageConfirmacion.MSG_EXITO_APROB))) {
                this.terminarIteracionXError(msgRta);
            }
        }

        // Extraer número de documento
        if (DatosDavivienda.IS_RISKMOTOR) {
            this.bancoDesTx = pageConf.getBancoDesTx();
            if (this.bancoDesTx != null) SetBancoDesTx(this.bancoDesTx);

            this.valorTx = pageConf.getValorFinalTx();
            if (this.valorTx != null)
                SetActivityAmount(this.valorTx.replace("$", "").replace(" ", ""));
        }

        this.numeroTx = pageConf.getNumeroDocumento();

        if (this.numeroTx == null) {
            if (DatosDavivienda.IS_RISKMOTOR) {
                if (esDestinoMasivo())
                    this.validarIngresoMRDestinosMasivo();
                else
                    this.validarIngresoMR();
            }
            this.terminarIteracionXError("No se encontró el Número de Documento de la transacción");
        }

        this.pageConsultasyExtractos.SetNumApr(this.numeroTx);
        tipoPrueba = getParamOrDefault("Tipo prueba", "Tx En Línea");
        SettingsRun.getTestData().setParameter("Número Aprobación", this.numeroTx);
    }

    /** @return {@code true} cuando el servicio es de destinos masivos. */
    private boolean esDestinoMasivo() {
        return this.servicio.contains("Nómina") || this.servicio.contains("Pago a Proveedores")
                || this.servicio.contains("AFC") || this.servicio.contains("Crédito.3ros");
    }

    /** Resuelve el número de reintentos fallidos configurado para el Motor de Riesgo. */
    private int resolverNumRetosFallidos() {
        if (!DatosDavivienda.IS_RISKMOTOR) return 0;
        String dato = SettingsRun.getTestData().getParameter("Ingresos Fallidos").trim();
        return (dato == null || dato.isEmpty()) ? 0 : Integer.valueOf(dato);
    }

    // ============================[Validación cobros]=============================

    /**
     * Calcula los descuentos a aplicar por tipo de destino y estado de la transacción.
     */
    public double[] validacionDescuentoTx(
            List<HashMap<String, String>> resultsMiddle,
            HashMap<String, Double> cobrosStratus,
            String[] estadotxFinal,
            boolean informacionConsultada) throws Exception {

        this.baseMiddleCobros = new BaseMiddleCobros();

        String servicio = PageServicios.getNbLinkServicio(SettingsRun.getTestData().getParameter("Servicio"));
        HashMap<String, String> infoMiddle = resultsMiddle.get(0);
        String verificarCombo         = infoMiddle.get("Verificacion Combo");
        double topeInferiorSaldo      = Double.parseDouble(infoMiddle.get("Tope inferior saldo"));
        double topeSuperiosSaldo      = Double.parseDouble(infoMiddle.get("Tope superior saldo"));
        double saldoPromedioMesAnt    = Double.parseDouble(infoMiddle.get("Saldo Promedio Mes Anterior"));
        String indicadorCumplimiento  = infoMiddle.get("Indicador cumplimiento Saldo Promedio");
        String tipoCobro              = SettingsRun.getTestData().getParameter("Tipo Prueba Cobros");

        double[] resultado = new double[estadotxFinal.length];

        for (int i = 0; i < resultado.length; i++) {
            String[] datosFinales = estadotxFinal[i].split("\\|");
            Util.wait(2);

            String tipoDestino, usarDestino, estadoTx;
            double valorCobro = 0, valorCobroRechazo = 0;
            double descuentoDentroRango = 0, descuentoSobreRango = 0, descuentoXTxRechazo = 0;
            String motivoCobro, descuentoAplicarCombo, aplicaCombo;

            if (servicio.equalsIgnoreCase("Pago de Nóminas") || servicio.equalsIgnoreCase("Pago a Proveedores")) {
                tipoDestino  = datosFinales[1];
                usarDestino  = this.baseMiddleCobros.tipoDestino(tipoDestino);
                estadoTx     = datosFinales[3];

                incrementarContador(infoMiddle, usarDestino);

                descuentoDentroRango = Double.parseDouble(infoMiddle.get("Descuento dentro rango " + usarDestino));
                descuentoSobreRango  = Double.parseDouble(infoMiddle.get("Descuento sobre rango " + usarDestino));
                descuentoXTxRechazo  = Double.parseDouble(infoMiddle.get("Descuento por Tx rechazada " + usarDestino));

                motivoCobro = this.baseMiddleCobros.diccionarioSegmentos(servicio + " " + tipoDestino);
                valorCobro  = cobrosStratus.get(motivoCobro);

                if ("Pago Rechazado".equals(estadoTx)) {
                    String motivoRec = this.baseMiddleCobros.diccionarioSegmentos(
                            servicio + " " + tipoDestino + " Rechazo");
                    valorCobroRechazo = cobrosStratus.get(motivoRec);
                }
            } else {
                tipoDestino = datosFinales[0];
                usarDestino = this.baseMiddleCobros.tipoDestino(tipoDestino);
                estadoTx    = datosFinales[1];

                incrementarContador(infoMiddle, usarDestino);

                if (servicio.contains("Pago de Servicios")) {
                    descuentoDentroRango = Double.parseDouble(infoMiddle.get("Descuento dentro rango " + servicio));
                    descuentoSobreRango  = Double.parseDouble(infoMiddle.get("Descuento sobre rango " + servicio));
                    descuentoXTxRechazo  = 0;
                } else {
                    if (infoMiddle.get("Descuento dentro rango " + usarDestino) != null)
                        descuentoDentroRango = Double.parseDouble(infoMiddle.get("Descuento dentro rango " + usarDestino));
                    if (infoMiddle.get("Descuento sobre rango " + usarDestino) != null)
                        descuentoSobreRango = Double.parseDouble(infoMiddle.get("Descuento sobre rango " + usarDestino));
                    if (infoMiddle.get("Descuento por Tx rechazada " + usarDestino) != null)
                        descuentoXTxRechazo = Double.parseDouble(infoMiddle.get("Descuento por Tx rechazada " + usarDestino));
                }

                motivoCobro = servicio.equalsIgnoreCase("Pago de servicios")
                        ? this.baseMiddleCobros.diccionarioSegmentos(servicio)
                        : this.baseMiddleCobros.diccionarioSegmentos(servicio + " " + tipoDestino);

                if (motivoCobro != null)
                    valorCobro = cobrosStratus.get(motivoCobro);
            }

            Util.wait(2);

            descuentoAplicarCombo = "Descuento para combo " + usarDestino;
            aplicaCombo           = infoMiddle.get(descuentoAplicarCombo);

            boolean esTxExitosa = "Pago Exitoso".equals(estadoTx)
                    || "Pendiente".equals(estadoTx)
                    || "Enviado a Otro Banco".equals(estadoTx);
            boolean esTxRechazada = "Pago Rechazado".equals(estadoTx);

            if (informacionConsultada) {
                if (esTxExitosa) {
                    resultado[i] = "S".equals(indicadorCumplimiento)
                        ? this.baseMiddleCobros.descuentoIndicadorSConCombo(
                                aplicaCombo, saldoPromedioMesAnt, topeInferiorSaldo, topeSuperiosSaldo,
                                0, valorCobro, descuentoDentroRango, descuentoSobreRango)
                        : this.baseMiddleCobros.descuentoIndicadorNConCombo(
                                aplicaCombo, saldoPromedioMesAnt, topeInferiorSaldo, topeSuperiosSaldo,
                                valorCobro, 0, descuentoSobreRango, descuentoDentroRango);
                    if (!"S".equals(indicadorCumplimiento) && !"N".equals(indicadorCumplimiento)) {
                        Reporter.reportEvent(Reporter.MIC_FAIL, "No se encontro la información relacionada");
                        SettingsRun.exitTestIteration();
                    }
                } else if (esTxRechazada) {
                    Reporter.reportEvent(Reporter.MIC_INFO,
                            "La transacción para el tipo destino: " + tipoDestino + " ha sido rechazada.");
                    resultado[i] = "SI".equals(aplicaCombo)
                            ? this.baseMiddleCobros.descuentoXRechazo(0, valorCobroRechazo, descuentoXTxRechazo)
                            : valorCobroRechazo;
                    if ("NO".equals(aplicaCombo)) {
                        Reporter.reportEvent(Reporter.MIC_INFO,
                                "Se cobra tarifa completa del cobro por rechazo de transacción: [ "
                                + valorCobroRechazo + " ].");
                    }
                }
            } else {
                if (esTxExitosa) {
                    resultado[i] = "S".equals(indicadorCumplimiento)
                        ? this.baseMiddleCobros.descuentoIndicadorSSinCombo(
                                saldoPromedioMesAnt, topeInferiorSaldo, topeSuperiosSaldo,
                                0, valorCobro, descuentoDentroRango, descuentoSobreRango)
                        : this.baseMiddleCobros.descuentoIndicadorNSinCombo(
                                saldoPromedioMesAnt, topeInferiorSaldo, topeSuperiosSaldo,
                                0, valorCobro, descuentoDentroRango, descuentoSobreRango);
                    if (!"S".equals(indicadorCumplimiento) && !"N".equals(indicadorCumplimiento)) {
                        Reporter.reportEvent(Reporter.MIC_INFO, "No se encontro la información relacionada");
                        SettingsRun.exitTestIteration();
                    }
                } else if (esTxRechazada) {
                    Reporter.reportEvent(Reporter.MIC_INFO,
                            "La transacción para el tipo destino: " + tipoDestino + " ha sido rechazada.");
                    resultado[i] = this.baseMiddleCobros.descuentoXRechazo(0, valorCobroRechazo, descuentoXTxRechazo);
                }
            }
        }

        if (verificarCombo.contains("Empresa tiene combo")) {
            actualizarContadorTx(infoMiddle, servicio);
        }

        return resultado;
    }

    /** Incrementa el contador del tipo de destino correspondiente si aplica. */
    private void incrementarContador(HashMap<String, String> infoMiddle, String usarDestino) {
        String indicaAplicaContador = infoMiddle.get("Aplica contador " + usarDestino);
        if (!"S".equals(indicaAplicaContador)) return;

        switch (usarDestino) {
            case "Davivienda":             incCuentasDavivienda++;      break;
            case "Otros Bancos":           incCuentasOtrosBancos++;     break;
            case "Tarjeta Prepago Maestro": incTarjetaPrepago++;        break;
            case "Daviplata":              incDaviplata++;              break;
            case "Depósitos Electrónicos": incDepositosElectronicos++;  break;
            case "Pago de Servicios":      incPagoServicios++;          break;
            default:
                Reporter.write("No se encontró ningun destino relacionado para aplicar contador");
                break;
        }
    }

    /** Actualiza {@link #contadorTx} acumulando los totales desde middle. */
    private void actualizarContadorTx(HashMap<String, String> infoMiddle, String servicio) {
        if ("Pago de Servicios".equals(servicio)) {
            contadorTx = new int[1];
            contadorTx[0] = incPagoServicios;
            int acum = Integer.parseInt(infoMiddle.get("Tx acumuladas 1"));
            contadorTx[0] = acum != 0 ? acum + contadorTx[0] : acum;
        } else {
            contadorTx = new int[]{ incCuentasDavivienda, incCuentasOtrosBancos,
                                    incTarjetaPrepago, incDaviplata, incDepositosElectronicos };
            for (int j = 0; j < contadorTx.length; j++) {
                int acum = Integer.parseInt(infoMiddle.get("Tx acumuladas " + (j + 1)));
                contadorTx[j] = acum != 0 ? acum + contadorTx[j] : acum;
            }
        }
    }

