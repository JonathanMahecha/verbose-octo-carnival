    private String procesarAprobacionesMultiples(boolean primeroGuardar) throws Exception {
        if (estado == null) estado = "Todas";

        boolean esInternacionalSinAprobacion = primeroGuardar
                && servicio.contains("Internacionales")
                && !servicio.contains("Aprobación");

        if (estado.contains("Pendiente de Aprobación") && primeroGuardar) {
            aprobarTxPendienteIntern(true);
        } else if (esInternacionalSinAprobacion || (primeroGuardar && DatosDavivienda.IS_RISKMOTOR)) {
            aprobarTxPendienteIntern(true);
        }

        return ejecutarFlujoPorNumeroFirmas(primeroGuardar);
    }

    private String ejecutarFlujoPorNumeroFirmas(boolean primeroGuardar) throws Exception {
        numAprobaciones = param("Números de Aprobaciones");
        int numFirmas   = Integer.parseInt(numAprobaciones);

        if (numFirmas == 1) {
            return procesarUnicaFirma(primeroGuardar);
        }

        // Múltiples firmas
        cerrarSesionDependiemdoPortal();
        String msg = null;

        for (int i = 2; i <= numFirmas; i++) {
            loginPorFirmas(i);

            if (servicio.contains("Internacionales")) {
                Util.wait(5);
                aprobarTxPendienteIntern(primeroGuardar);
                if (i == numFirmas) msg = ejecutarConsultaFinal();
            }

            cerrarSesionDependiemdoPortal();
        }

        return msg;
    }

    /**
     * Ejecuta la consulta de estado para transacciones con una sola firma
     * o la consulta final después de la última firma múltiple.
     * Ambos flujos son idénticos — método único para evitar duplicación.
     */
    private String ejecutarConsultaInternacional() throws Exception {
        pageConsultatxInternacional = new PageConsultatxInternacional(pageDivisas);
        sincronizarFechaHora();
        estado = param("Estado");

        String msg = pageConsultatxInternacional.ConsultaNumtx(
                tipoPrueba, nombreEmpre, servicio, tipoConstaTxRealizadas,
                ordenanteBeneficiario, tipoTranferencia, estado, tipoMoneda,
                fechaTx, horaTx, fechaDesde, fechaHasta, valorsin);

        pageConsultatxInternacional.getDriver().switchTo().defaultContent();
        return msg;
    }

    private String procesarUnicaFirma(boolean primeroGuardar) throws Exception {
        boolean esInternacionalODivisas = servicio.contains("Internacionales")
                || servicio.contains("Divisas");
        boolean noEsAprobacionNiValidar = !servicio.contains("Aprobación")
                && !servicio.contains("Validar");

        if (!esInternacionalODivisas || !noEsAprobacionNiValidar) return null;

        String msg = ejecutarConsultaInternacional();
        if (msg != null) terminarIteracionXError(msg);

        if (DatosDavivienda.STRATUS != null) {
            pageConsultatxInternacional.ValidacionesStratusConsulta();
        }

        return msg;
    }

    private String ejecutarConsultaFinal() throws Exception {
        return ejecutarConsultaInternacional();
    }

