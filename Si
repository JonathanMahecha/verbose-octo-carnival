package dav.middlePymes;

import java.util.List;

import org.openqa.selenium.By;
import org.openqa.selenium.WebElement;

import dav.pymes.PageLoginPymes;
import dav.transversal.DatosEmpresarial;
import library.common.Util;
import library.core.BasePageWeb;
import library.reporting.Evidence;
import library.settings.SettingsRun;

public class PageInicioMiddle extends BasePageWeb {

    // ============================[Locators]======================================

    private static final String XPATH_MENU =
            "//span[@id='lblMasterMenu']//a[contains(text(), 'NB_MENU_INICIAL')]//parent::td";
    private static final String XPATH_SUBMENU =
            "//td[@class='easyMenuItemContentCell']/a[text()='NB_SUBMENU']//parent::td";
    private static final String XPATH_SUBMENU_CONTAINS =
            "//td[@class='easyMenuItemContentCell']/a[contains(text(), 'NB_SUBMENU')]//parent::td";

    private static final By LOC_TITLE      = By.id("lblMasterTitulo");
    private static final String LOC_TITULO = "//td[@class='Titulo']";

    // ============================[Estado]========================================

    protected PageLoginPymes pageLogin;
    private boolean estaEnLogueo;

    // ============================[Constructor]===================================

    /**
     * Único constructor: depende de otra {@link BasePageWeb} ya abierta.
     */
    public PageInicioMiddle(BasePageWeb parentPage) {
        super(parentPage);
    }

    // ============================[Navegación menú]===============================

    /**
     * Navega a través del menú de Middle: abre {@code opcMenu} y recorre
     * {@code opcSubMenu} en orden, haciendo click en el último elemento.
     * <p>
     * Si {@code title} tiene valor, espera a que aparezca en pantalla (ID
     * {@code lblMasterTitulo}). Si la sesión expiró, re-loguea y reintenta.
     *
     * @return {@code null} si tuvo éxito; mensaje de error si no.
     */
    public String irAOpcion(String title, String opcMenu, String... opcSubMenu) throws Exception {
        return navegarMenu(title, opcMenu, false, opcSubMenu);
    }

    /**
     * Variante de {@link #irAOpcion} que acepta submenús nulos o vacíos sin romper.
     * Misma lógica interna; se mantiene como método público independiente
     * para compatibilidad con los llamadores existentes.
     */
    public String irAOpcionMiddle(String title, String opcMenu, String... opcSubMenu) throws Exception {
        return navegarMenu(title, opcMenu, true, opcSubMenu);
    }

    /**
     * Versión alternativa pública con comportamiento idéntico a {@link #irAOpcion}.
     * Se conserva para compatibilidad; delega al mismo núcleo.
     */
    public String irAOpcion2(String title, String opcMenu, String... opcSubMenu) throws Exception {
        return irAOpcion(title, opcMenu, opcSubMenu);
    }

    // ============================[Nucleo de navegación]=========================

    /**
     * Implementación única de la navegación por menú.
     *
     * @param tolerarNulos {@code true} para ignorar entradas de submenú nulas/vacías
     *                     (comportamiento de {@code irAOpcionMiddle}).
     */
    private String navegarMenu(String title, String opcMenu, boolean tolerarNulos, String... opcSubMenu)
            throws Exception {

        Util.wait(tolerarNulos ? 1 : 1); // mismo wait en ambas variantes originales

        String menuXPath   = XPATH_MENU.replace("NB_MENU_INICIAL", opcMenu);
        String pathMenu    = opcMenu;
        String finalOption = opcMenu;

        WebElement menuElement = this.element(menuXPath);
        if (menuElement == null) {
            Evidence.save("ErrorMenu", this);
            return "No se encontró en el Menú [" + opcMenu + "] - Valide la información";
        }

        boolean isChrome = esChrome();

        // Hover menú principal
        hoverElement(menuElement, isChrome);
        if (tolerarNulos) Util.wait(2);    // irAOpcionMiddle tenía un wait extra aquí

        // Recorrer submenús
        if (opcSubMenu != null) {
            for (String subOption : opcSubMenu) {
                Util.wait(1);

                if (tolerarNulos && (subOption == null || subOption.isEmpty())) continue;

                String subXPath = XPATH_SUBMENU_CONTAINS.replace("NB_SUBMENU", subOption);
                List<WebElement> found = this.findElements(By.xpath(subXPath));

                // Si hay múltiples coincidencias se usa la variante con espacios
                if (found.size() > 1) {
                    subXPath = "(" + XPATH_SUBMENU.replace("NB_SUBMENU", subOption + "    ") + ")[1]";
                    found    = this.findElements(By.xpath(subXPath));
                }

                if (found.isEmpty()) {
                    Evidence.save("ErrorMenu", this);
                    return "En el menú [" + pathMenu + "] NO se encontró la opción ["
                            + subOption + "] - Valide la información";
                }
                if (found.size() > 1) {
                    return "Existen muchos submenús que contienen [" + subOption + "] en el WebPage";
                }

                // Espera hasta que el elemento sea visible
                while (!this.isDisplayed(found.get(0))) {
                    Util.wait(1);
                }

                pathMenu   += "/" + subOption;
                finalOption = subOption;

                if (isChrome) {
                    Util.wait(3);
                    this.mouseOver(this.element(subXPath));
                } else {
                    WebElement el = this.element(By.xpath(subXPath));
                    dispatchMouseOver(el);
                    this.getJse().executeScript("arguments[0].click();", el);
                }
            }
        }

        // Click final solo en Chrome
        if (isChrome) this.mouseClick();

        this.estaEnLogueo = false;

        if (title != null && !title.isEmpty())
            this.waitIngresoModulo(title);
        else
            this.retornoALogueo();

        // Si la sesión expiró: re-loguear y reintentar
        if (this.estaEnLogueo) {
            DatosEmpresarial.ESTALOGMIDD_PYM = false;
            this.pageLogin.loginMiddle();
            // Reintento con el método correcto según la variante
            return tolerarNulos
                    ? this.irAOpcionMiddle(title, opcMenu, opcSubMenu)
                    : this.irAOpcion(title, opcMenu, opcSubMenu);
        }

        Evidence.save("IngresoA_" + finalOption.replace(" ", "_"), this);
        return null;
    }

    // ============================[Acceso directo inicio]=========================

    /** Navega a la opción de menú "Inicio". */
    public void irAInicio() throws Exception {
        this.irAOpcion(null, "Inicio");
    }

    // ============================[Espera de módulo]==============================

    /**
     * Espera hasta 60 segundos a que aparezca el título {@code titleModulo}
     * en el elemento con ID {@code lblMasterTitulo}.
     *
     * @throws Exception si transcurren más de 60 segundos sin encontrar el título.
     */
    public void waitIngresoModulo(String titleModulo) throws Exception {
        titleModulo = titleModulo.trim();
        boolean encontrado = false;
        int elapsed = 0;

        while (!encontrado && elapsed <= 60) {
            Util.wait(1);
            elapsed++;

            WebElement elemTitle = this.element(LOC_TITLE);
            if (elemTitle != null)
                encontrado = Util.equalsIgnoreCaseAndAccents(titleModulo, elemTitle.getText().trim());

            if (!encontrado && this.retornoALogueo()) return;
        }

        if (!encontrado) {
            throw new Exception(
                    "PageInicioMiddle ERROR -- Se supera los 60 segundos esperando ingreso al módulo con título ["
                    + titleModulo + "]");
        }
    }

    // ============================[Utilidades privadas]==========================

    /**
     * Detecta si el navegador configurado es Chrome.
     */
    private boolean esChrome() {
        return SettingsRun.getTestData().getParameter("Navegador").trim().contains("CHROME");
    }

    /**
     * Realiza hover sobre un elemento usando el método apropiado según el navegador.
     */
    private void hoverElement(WebElement element, boolean isChrome) {
        if (isChrome) {
            this.mouseOver(element);
        } else {
            dispatchMouseOver(element);
        }
    }

    /**
     * Despacha el evento {@code mouseover} vía JavaScript
     * (necesario para navegadores distintos a Chrome).
     */
    private void dispatchMouseOver(WebElement element) {
        this.getJse().executeScript(
                "var event = new MouseEvent('mouseover', {bubbles:true, cancelable:true, view:window});"
                + " arguments[0].dispatchEvent(event);",
                element);
    }

    /**
     * Verifica si la pantalla actual es la de login del portal PYMES.
     * Almacena el resultado en {@link #estaEnLogueo}.
     *
     * @return {@code true} si está en la pantalla de bienvenida/login.
     */
    private boolean retornoALogueo() {
        WebElement titulo = this.element(LOC_TITULO);
        this.estaEnLogueo = this.isDisplayed(titulo)
                && titulo.getText().contains("Bienvenido al Portal PYMES");
        return this.estaEnLogueo;
    }
}
