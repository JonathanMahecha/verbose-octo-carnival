package Dav_TarjetasDeCar;

import library.core.BasePageWeb;
import library.core.Controller;
import library.data.DataDriven;
import library.reporting.Reporter;
import library.settings.SettingsRun;
import org.openqa.selenium.By;
import pages.actions.client360.PageLoginClient360;
import pages.actions.client360.PageSearchUsersClient360;

public class TarjetasDeCar_Controller implements Controller {

	private static final String NAVEGADOR = "CHROME";
	private static final String ESCENARIO_SOLO_ACTIVAR = "Solo Activar";
	private static final String ESCENARIO_SOLO_COMPRA = "Solo Compra";
	private static final String ESCENARIO_FLUJO_COMPLETO = "Flujo completo";
	private static final String SI = "Si";

	private static final String TIPO_CUPO_INFERIOR = "INFERIOR";
	private static final String TIPO_CUPO_INTERMEDIO = "INTERMEDIO";
	private static final String TIPO_CUPO_SUPERIOR = "SUPERIOR";

	private static final int LIMITE_CUPO_INFERIOR = 10_000_000;
	private static final int LIMITE_CUPO_INTERMEDIO = 100_000_000;

	private static final String RUTA_IDENTIFICACION = "//a[@name='DAV_Identification Number']";
	private static final String MENSAJE_CLIENTE_INEXISTENTE = "Este cliente es inexistemte.";
	private static final String MENSAJE_ESQUEMA_NO_RECONOCIDO = "Escenario no reconocido: ";
	private static final String MENSAJE_SOLICITUD_NO_APROBADA = "Solicitud no aprobada";
	private static final String MENSAJE_SOLICITUD_APROBADA = "Solicitud aprobada exitosamente";
	private static final String MENSAJE_PROCESO_FINALIZADO = "Proceso Finalizado - Cliente: ";
	private static final String MENSAJE_TARJETA_ACTIVADA = "Tarjeta activada exitosamente";
	private static final String MENSAJE_COMPRA_EXITOSA = "Compra aplicada exitosamente";

	private static final String PARAM_USUARIO_C360 = "data.usuarioC360";
	private static final String PARAM_CLAVE_C360 = "data.claveC460";
	private static final String PARAM_USUARIO_AS400 = "data.as400User";
	private static final String PARAM_CLAVE_AS400 = "data.as400Pwd";

	private static final String PARAM_ESCENARIO = "Escenarios As400";
	private static final String PARAM_TIPO_ID = "Tipo ID";
	private static final String PARAM_NUMERO_ID = "Numero ID";
	private static final String PARAM_NOMBRE = "Nombre";
	private static final String PARAM_DIRECCION = "Direccion";
	private static final String PARAM_TIPO_PRODUCTO = "Tipo Producto";
	private static final String PARAM_CUPO_SOLICITADO = "Cupo Solicitado";
	private static final String PARAM_OFICINA_RADIACION = "Oficina Radicación";
	private static final String PARAM_MODALIDAD_CREDITO = "Modalidad Credito";
	private static final String PARAM_TIPO_GARANTIA = "Tipo Garantia";
	private static final String PARAM_ACTIVAR = "Activar";
	private static final String PARAM_COMPRA = "Compra";
	private static final String PARAM_MONTO_COMPRA = "Monto Compra";
	private static final String PARAM_NUMERO_TC = "Numero de Tarjeta de Credito";

	private static final String PARAMETRO_NOMBRE_CLIENTE = "Nombre";
	private static final String PARAMETRO_DIRECCION_CLIENTE = "Direccion";

	private static final String FUNCIONARIO_NO_OPERADOR = "NO OPERADOR";

	private static final String NIVEL_INFERIOR = "112";
	private static final String NIVEL_INTERMEDIO = "111";
	private static final String NIVEL_SUPERIOR = "110";

	private static final String TIPO_CLIENTE_NATURAL = "Persona Natural";

	private TarjetasDeCar_Page tc;
	PageLoginClient360 login360;
	String navegador = NAVEGADOR;
	PageSearchUsersClient360 search360;

	private String EscAs400;
	private String tipoId;
	private String numeroId;
	private String nombre;
	private String direccion;
	private String tipoProduc;
	private String cupoSolic;
	private String oficinaRad;
	private String modaliCred;
	private String tipoGarant;
	private String activar;
	private String compra;
	private String montoCompra;
	private String tipoCupo;
	private String numeroTC;

	public void destroy() {
		if (this.login360 != null) {
			this.login360.closeAllBrowsers();
		}
		if (this.tc != null) {
			this.tc.closeAs400();
		}
	}

	public void main() throws Exception {
		cargarParametros();

		if (esVacio(this.nombre) || esVacio(this.direccion)) {
			ejecutarCliente360();
		}

		iniciarSesionAS400();

		switch (this.EscAs400) {
		case ESCENARIO_SOLO_ACTIVAR:
			asegurarNumeroTC();
			activarTarjeta(this.numeroTC);
			return;

		case ESCENARIO_FLUJO_COMPLETO:
			procesoCompleto();
			return;

		case ESCENARIO_SOLO_COMPRA:
			asegurarNumeroTC();
			aplicarCompra(this.numeroTC);
			return;

		default:
			Reporter.reportEvent(3, MENSAJE_ESQUEMA_NO_RECONOCIDO + this.EscAs400);
		}
	}

	private void iniciarSesionAS400() throws Exception {
		if (this.tc == null) {
			this.tc = new TarjetasDeCar_Page(
					SettingsRun.getGlobalData(PARAM_USUARIO_AS400),
					SettingsRun.getGlobalData(PARAM_CLAVE_AS400),
					FUNCIONARIO_NO_OPERADOR);
			this.tc.ingresoAmbiente();
		}
	}

	private void ejecutarCliente360() throws Exception {
		String userName = SettingsRun.getProperty(PARAM_USUARIO_C360);
		String password = SettingsRun.getProperty(PARAM_CLAVE_C360);

		if (this.login360 == null) {
			this.login360 = new PageLoginClient360(this.navegador);
			this.login360.maximizeBrowser();
			this.search360 = new PageSearchUsersClient360((BasePageWeb) this.login360);
			this.search360.refresh();
			this.login360.loginPageClient360(userName, password);
		}

		this.search360 = new PageSearchUsersClient360((BasePageWeb) this.login360);
		this.search360.searchUsers(this.tipoId, this.numeroId);

		try {
			this.search360.click(By.xpath(RUTA_IDENTIFICACION));
		} catch (Exception e) {
			Reporter.reportEvent(1, MENSAJE_CLIENTE_INEXISTENTE);
			SettingsRun.exitTestIteration();
		}

		String[] datosBasicos = this.search360.getDatosCompletosCliente();
		for (String dato : datosBasicos) {
			System.out.println(dato);
		}

		this.nombre = datosBasicos[2];
		this.direccion = datosBasicos[8];

		if (esVacio(this.nombre) || esVacio(this.direccion)) {
			Reporter.reportEvent(1, "El cliente: " + this.numeroId + " necesita un nombre y/o una dirección válida");
			SettingsRun.exitTestIteration();
		}
	}

	private void procesoCompleto() throws Exception {
		String validacion = this.tc.crearSolicitudTC(
				this.tipoId,
				this.numeroId,
				this.nombre,
				this.tipoProduc,
				this.cupoSolic,
				this.oficinaRad,
				this.modaliCred,
				this.tipoGarant,
				this.direccion);

		if (!esVacio(validacion)) {
			Reporter.reportEvent(1, validacion);
			SettingsRun.exitTestIteration();
		}

		this.numeroTC = aprobarSolicitudPorTipo();

		if (esVacio(this.numeroTC)) {
			Reporter.reportEvent(1, MENSAJE_SOLICITUD_NO_APROBADA);
			SettingsRun.exitTestIteration();
		}

		Reporter.reportEvent(0, MENSAJE_SOLICITUD_APROBADA);

		// Se conserva exactamente el comportamiento original.
		this.numeroTC = SettingsRun.getTestData().getParameter(PARAM_NUMERO_TC);

		if (SI.equalsIgnoreCase(this.activar)) {
			activarTarjeta(this.numeroTC);
		}

		if (SI.equalsIgnoreCase(this.compra)) {
			aplicarCompra(this.numeroTC);
		}

		this.tc.consultarTC(this.numeroTC);
		Reporter.reportEvent(0, MENSAJE_PROCESO_FINALIZADO + this.numeroId);

		if (SettingsRun.esIteracionFinal()) {
			this.tc.closeAs400();
		}
	}

	private String aprobarSolicitudPorTipo() throws Exception {
		String nivel;
		switch (this.tipoCupo) {
		case TIPO_CUPO_INTERMEDIO:
			nivel = NIVEL_INTERMEDIO;
			break;
		case TIPO_CUPO_SUPERIOR:
			nivel = NIVEL_SUPERIOR;
			break;
		case TIPO_CUPO_INFERIOR:
		default:
			nivel = NIVEL_INFERIOR;
			break;
		}
		return this.tc.aprobarSolicitud(this.tipoId, this.numeroId, this.tipoProduc, this.cupoSolic, nivel);
	}

	private void activarTarjeta(String numeroTC) throws Exception {
		String activarTc = this.tc.activarTC(numeroTC);
		this.tc.retornarPantallaWhile("FUNCIONES GRUPO DE FUNCIONES", 6);

		if (!esVacio(activarTc)) {
			Reporter.reportEvent(1, activarTc);
		} else {
			Reporter.reportEvent(0, MENSAJE_TARJETA_ACTIVADA);
		}

		if (SI.equalsIgnoreCase(this.compra)) {
			aplicarCompra(numeroTC);
		}

		SettingsRun.exitTestIteration();
	}

	private void aplicarCompra(String numeroTC) throws Exception {
		this.tc.aplicarCompraTC(numeroTC, this.oficinaRad, this.montoCompra);
		Reporter.reportEvent(0, MENSAJE_COMPRA_EXITOSA);
	}

	private void cargarParametros() {
		DataDriven td = SettingsRun.getTestData();

		this.EscAs400 = td.getParameter(PARAM_ESCENARIO);
		this.tipoId = td.getParameter(PARAM_TIPO_ID);
		this.numeroId = td.getParameter(PARAM_NUMERO_ID);
		this.nombre = td.getParameter(PARAM_NOMBRE);
		this.direccion = td.getParameter(PARAM_DIRECCION);
		this.tipoProduc = td.getParameter(PARAM_TIPO_PRODUCTO);

		this.cupoSolic = normalizarMonto(td.getParameter(PARAM_CUPO_SOLICITADO));
		this.oficinaRad = td.getParameter(PARAM_OFICINA_RADIACION);
		this.modaliCred = td.getParameter(PARAM_MODALIDAD_CREDITO);
		this.tipoGarant = td.getParameter(PARAM_TIPO_GARANTIA);
		this.activar = td.getParameter(PARAM_ACTIVAR);
		this.compra = td.getParameter(PARAM_COMPRA);
		this.montoCompra = normalizarMonto(td.getParameter(PARAM_MONTO_COMPRA));
		this.numeroTC = td.getParameter(PARAM_NUMERO_TC);

		this.tipoCupo = clasificarCupo(Integer.parseInt(this.cupoSolic));
	}

	private String clasificarCupo(int cupo) {
		if (cupo < LIMITE_CUPO_INFERIOR) {
			return TIPO_CUPO_INFERIOR;
		}
		if (cupo < LIMITE_CUPO_INTERMEDIO) {
			return TIPO_CUPO_INTERMEDIO;
		}
		return TIPO_CUPO_SUPERIOR;
	}

	private String normalizarMonto(String valor) {
		if (valor == null) {
			return null;
		}
		return valor.replace(".", "").replace(",", "").replace("$", "");
	}

	private void asegurarNumeroTC() throws Exception {
		if (this.numeroTC == null || this.numeroTC.trim().isEmpty()) {
			this.numeroTC = this.tc.consultaPrimeraVez(this.tipoId, this.numeroId);
		}
	}

	private boolean esVacio(String valor) {
		return valor == null || valor.trim().isEmpty();
	}
}
