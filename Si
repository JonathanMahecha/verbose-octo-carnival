public void actualizarArchivoTxtConLineas(String rutaTxt, List<String> lineasNuevas) throws IOException {

    Path path = Paths.get(rutaTxt);
    List<String> lineasArchivo = new ArrayList<>();

    // 1. Leer archivo existente
    if (Files.exists(path)) {
        lineasArchivo.addAll(Files.readAllLines(path, StandardCharsets.UTF_8));
    }

    // 2. Asegurar encabezado
    if (lineasArchivo.isEmpty()) {
        lineasArchivo.add("TIPO_IDENTIFICACION;NRO_IDENTIFICACION;ACIERTA_PLUS;INGRESO_2;");
    }

    // 3. Mapear IDs existentes → índice
    Map<String, Integer> indicePorId = new HashMap<>();

    for (int i = 1; i < lineasArchivo.size(); i++) {
        String linea = lineasArchivo.get(i).trim();

        if (linea.isEmpty()) continue;

        String[] cols = linea.split(";", -1);

        if (cols.length > 1) {
            String id = cols[1].trim();
            if (!id.isEmpty()) {
                indicePorId.put(id, i);
            }
        }
    }

    // 4. UPSERT (reemplazar o agregar)
    for (String nuevaLinea : lineasNuevas) {

        if (nuevaLinea == null || nuevaLinea.trim().isEmpty()) continue;

        String[] cols = nuevaLinea.split(";", -1);
        if (cols.length < 2) continue;

        String id = cols[1].trim();
        if (id.isEmpty()) continue;

        String lineaNormalizada = normalizarLinea(nuevaLinea);

        if (indicePorId.containsKey(id)) {
            // 🔁 REEMPLAZA
            int index = indicePorId.get(id);
            lineasArchivo.set(index, lineaNormalizada);
        } else {
            // ➕ AGREGA
            lineasArchivo.add(lineaNormalizada);
            indicePorId.put(id, lineasArchivo.size() - 1);
        }
    }

    // 5. Guardar archivo
    Files.write(
        path,
        lineasArchivo,
        StandardCharsets.UTF_8,
        StandardOpenOption.CREATE,
        StandardOpenOption.TRUNCATE_EXISTING
    );
}
