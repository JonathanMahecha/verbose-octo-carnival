    }

    private boolean procesarMensajeAlerta(String mensajeAlerta, Alert alerta) {
        if (esAlertaRelevante(mensajeAlerta)) {
            Reporter.reportEvent(5, "Se presento alerta: " + mensajeAlerta);
            sleep(1);
            alerta.accept();
            return esAlertaError(mensajeAlerta);
        }
        return false;
    }

    private boolean esAlertaRelevante(String mensaje) {
        return mensaje.contains("Este registro ya se encuentra creado en cliente 360")
                || mensaje.contains("Este Registro ya se encuentra creado en cliente 360")
                || mensaje.contains("Ya existe un registro con el nID que estcreando")
                || mensaje.contains("El cliente no ha actualizado su informacidesde hace mde un a")
                || mensaje.contains("Tiene Solicitudes de Servicio que han llegado a la fecha de vencimiento")
                || mensaje.contains("Se han detectado valores de campo o tipos de valor incorrectos")
                || mensaje.contains("El tipo de identificacino existe")
                || mensaje.contains("Nde Identificaciinvpara")
                || mensaje.contains("Otro usuario modificel registro seleccionado")
                || mensaje.contains("El mespecializado '<?>' no es compatible")
                || mensaje.contains("La Vigencia del documento debe ser mayor a la fecha actual")
                || mensaje.contains("Nde Identificacino vpara \"Nit Persona Jur\"")
                || mensaje.contains("Tipo de identificacino coincide con fecha de nacimiento")
                || mensaje.contains("El cdel pano existe")
                || mensaje.contains("No se ha podido ejecutar la consulta porque hay un carno v")
                || mensaje.contains("Operacion Negada por polde la Entidad")
                || mensaje.contains("ACTUALICE LOS DATOS DEL REPRESENTANTE LEGAL")
                || mensaje.contains("La Fecha de ComposiciAccionaria se encuentra Vencida o No Vigente")
                || mensaje.contains("Error al validar si el tipo de identificaciexiste")
                || mensaje.contains("Por favor valide los campos Nombres")
                || mensaje.contains("La operacirequiere ande la Unidad de Control");
    }

    private boolean esAlertaError(String mensaje) {
        return mensaje.contains("El tipo de identificacino existe")
                || mensaje.contains("El cdel pano existe")
                || mensaje.contains("La Fecha de ComposiciAccionaria se encuentra Vencida o No Vigente")
                || mensaje.contains("Error al validar si el tipo de identificaciexiste")
                || mensaje.contains("Por favor valide los campos Nombres")
                || mensaje.contains("La operacirequiere ande la Unidad de Control");
    }
