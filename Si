    /**
     * Cambia el foco del WebDriver a la ventana principal del portal,
     * cerrando popups de notas si los hubiera.
     *
     * @return {@code true} si el cambio fue exitoso
     */
    private boolean cambiarAVentanaEmergente() throws Exception {
        Util.wait(5);

        WebDriver driver = pageLoginPyme.getDriver();
        String ventanaOrigen = driver.getWindowHandle();
        List<String> ventanas = new ArrayList<>(driver.getWindowHandles());

        if (ventanas.size() < 2) {
            fail("No se abrió la segunda pestaña");
            SettingsRun.exitTestIteration();
            return false;
        }

        for (String handle : ventanas) {
            Util.wait(1);
            info(handle);
            driver.switchTo().window(handle);

            WebElement nota = pageLoginPyme.element(LOC_BUGNOTES);
            if (pageLoginPyme.isDisplayed(nota)) {
                driver.close();
                List<String> restantes = new ArrayList<>(driver.getWindowHandles());
                if (restantes.isEmpty()) {
                    fail("No quedaron ventanas abiertas después de cerrar el popup");
                    SettingsRun.exitTestIteration();
                    return false;
                }
                String siguiente = restantes.contains(ventanaOrigen)
                        ? ventanaOrigen : restantes.get(0);
                driver.switchTo().window(siguiente);
                continue;
            }

            if (pageLoginPyme.isDisplayed(pageLoginPyme.element(LOC_DROP_EMPRESA))) {
                return true;
            }
        }

        if (driver.getWindowHandles().contains(ventanaOrigen)) {
            driver.switchTo().window(ventanaOrigen);
        }
        return false;
    }

