		reportarValidacion("Nombre del proceso",
				element(this.xpathNumProcesoPago + "/td[4]").getText(), nomProcesoPago);
		reportarValidacion("Cantidad de pagos",
				element(this.xpathNumProcesoPago + "/td[6]").getText(), cantidaPagos);

		String valorPagosSinCaracteres = element(this.xpathNumProcesoPago + "/td[7]")
				.getText().replace("$", "").replace(",", "").replace(".", "");
		if (valorPagosSinCaracteres.contains(valorPagos)) {
			Reporter.write("*** PASSED :: Valor total de pago correcta");
			Reporter.write("*** PASSED ------ " + element(this.xpathNumProcesoPago + "/td[7]").getText());
			Reporter.write("*** PASSED ------ " + valorPagos);
		} else {
			Reporter.write("*** FAIL :: Valor total de pago incorrecta");
			Reporter.write("*** FAIL ------ " + element(this.xpathNumProcesoPago + "/td[7]").getText());
			Reporter.write("*** FAIL ------ " + valorPagos);
		}

		if (element(this.xpathNumProcesoPago + "/td[8]").getText().contains(convenioPago)) {
			Reporter.write("*** PASSED :: Convenio de pago correcto");
			Reporter.write("*** PASSED ------ " + element(this.xpathNumProcesoPago + "/td[8]").getText());
			Reporter.write("*** PASSED ------ " + convenioPago);
		} else {
			Reporter.write("*** FAIL :: Convenio de pago incorrecto");
			Reporter.write("*** FAIL ------ " + element(this.xpathNumProcesoPago + "/td[8]").getText());
			Reporter.write("*** FAIL ------ " + convenioPago);
		}

		Evidence.save("Registro en Proceso de Pago encontrado", this, new WebElement[0]);
