private void seleccionarTipoRegistro(String tipoLlavRegis) throws Exception {

    // 1) Intento normal: radios directos en la página
    List<WebElement> botonesTipo = findElements(By.xpath("//div[@role='radio']"));

    for (WebElement botonTipo : botonesTipo) {
        try {
            WebElement texto = botonTipo.findElement(
                By.xpath("./ancestor::dav-radio/preceding-sibling::article//span")
            );

            String texto2 = getText(texto).trim();

            if (texto2.contains(tipoLlavRegis)) {
                botonTipo.click();
                Util.wait(1);
                return;
            }
        } catch (Exception ignored) {
        }
    }

    // 2) Fallback: buscar dentro de cada dav-content-box
    List<WebElement> cajas = findElements(By.xpath("//dav-content-box"));

    for (WebElement caja : cajas) {
        try {
            WebElement textoCaja = caja.findElement(
                By.xpath(".//app-card-resum-list//dav-text")
            );

            String texto2 = getText(textoCaja).trim();

            if (texto2.contains(tipoLlavRegis)) {
                WebElement radioCaja = caja.findElement(
                    By.xpath(".//app-card-resum-list//dav-radio/label/div")
                );
                radioCaja.click();
                Util.wait(1);
                return;
            }
        } catch (Exception ignored) {
        }
    }

    fail("No se encontró la opción: " + tipoLlavRegis);
}
