    /** Verifica si el texto contiene al menos uno de los fragmentos dados. */
    private boolean contiene(String texto, String... fragmentos) {
        for (String f : fragmentos) {
            if (texto.contains(f)) return true;
        }
        return false;
    }

    /** Valida campos requeridos de divisas y reporta los que estén vacíos. */
    private void validarCamposDivisas(String numCambiario1, String numCambiario2) {
        StringBuilder sb = new StringBuilder("Los siguientes campos están vacíos: ");
        if (this.numerodereferenciaExterna.isEmpty()) sb.append("Numero de referencia Externa, ");
        if (this.modena.isEmpty())    sb.append("Tipo Moneda, ");
        if (this.concepTx.isEmpty())  sb.append("Concepto de la transferencia, ");
        if (numCambiario1.isEmpty())  sb.append("Numeral cambiario 1, ");
        if (numCambiario2.isEmpty())  sb.append("Numeral cambiario 2, ");
        if (this.valorNumeral1.isEmpty()) sb.append("Valor numeral cambiario 1, ");
        if (this.valorNumeral2.isEmpty()) sb.append("Valor numeral cambiario 2, ");

        String base = "Los siguientes campos están vacíos: ";
        if (sb.length() > base.length()) {
            String msg = sb.substring(0, sb.length() - 2);
            Reporter.reportEvent(Reporter.MIC_FAIL, msg);
        }
    }

    /** Normaliza el valor de {@link #tipoCta} a los formatos reconocidos por divisas. */
    private void normalizarTipoCta() {
        String u = this.tipoCta.toUpperCase();
        if (u.contains("AHORRO"))    this.tipoCta = "CUENTA AHORROS";
        else if (u.contains("CORRIENTE")) this.tipoCta = "CUENTA CORRIENTE";
    }

    /** Retorna el tipo de producto normalizado para Stratus ("AHORROS" o "CORRIENTE"). */
    private String normalizarTipoProd(String tipoCta) {
        String u = tipoCta.toUpperCase();
        if (u.contains("AHORROS"))   return "AHORROS";
        if (u.contains("CORRIENTE")) return "CORRIENTE";
        return " ";
    }

