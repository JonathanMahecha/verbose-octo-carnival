	private String crearExcel(String archivoSource, List<Integer> listaFilasSourceExcel, String[] header,
			String[] paramsSource) throws Exception {
		String ruta = String.valueOf(Evidence.getStartEvidenceName()) + "ArchExcel.xlsx";
		ExcelFile excelFile = new ExcelFile(ruta, 1);
		excelFile.createSheet("Destinos");

		int totalCols = header.length;
		for (int posH = 0; posH < totalCols; posH++) {
			excelFile.setStringCellValue(1, posH + 1, header[posH]);
		}

		DataDriven dd = new DataDrivenExcel(archivoSource);
		int filaAD = 2;

		for (Iterator<Integer> iterator = listaFilasSourceExcel.iterator(); iterator.hasNext();) {
			int fila = ((Integer) iterator.next()).intValue();

			for (int i = 0; i < totalCols; i++) {
				String paramUpper = paramsSource[i].toUpperCase();
				String dato = dd.getParameterByExec(paramsSource[i], fila);

				if ((paramUpper.contains("TIPO") && paramUpper.contains("IDENTIFICACION"))
						|| paramUpper.contains("TIPOID")) {
					dato = getCodigoTipoId(dato);
				} else if (paramUpper.contains("BANCO") && paramUpper.contains("DEST")) {
					dato = this.catBancos.getCodigoXNombreContained(dato);
				} else if (paramUpper.contains("TIPO") && paramUpper.contains("PROD")) {
					dato = getCodigoTipoProducto(dato);
				}

				if (paramUpper.equals("VALORPAGO") && !dato.isEmpty()) {
					this.valorTransaccion += Double.valueOf(dato).doubleValue();
				}

				excelFile.setStringCellValue(filaAD, i + 1, dato);
			}

			filaAD++;
			this.totalDestinos++;
		}

		excelFile.saveAndCloseFile();
		return ruta;
	}

	private String getTipoCuenta(String bancoDest, String tipoCta) {
		String tipoCtaReal = tipoCta;
		if (bancoDest.equals("DAVIVIENDA") && tipoCta.contains("OTRO")) {
			if (tipoCta.contains("AHORRO")) {
				tipoCtaReal = "CUENTA DE AHORROS";
			} else if (tipoCta.contains("CORRIENTE")) {
				tipoCtaReal = "CUENTA CORRIENTE";
			}
		} else if (!bancoDest.equals("DAVIVIENDA") && !tipoCta.contains("OTRO") && !tipoCta.contains("ELECTR")) {
			if (tipoCta.contains("AHORRO")) {
				tipoCtaReal = "CUENTAS AHORRO OTROS BANCOS";
			} else if (tipoCta.contains("CORRIENTE")) {
				tipoCtaReal = "CUENTAS CORRIENTES OTROS BANCOS";
			} else {
				tipoCtaReal = "DEPÓSITOS ELECTRONICOS";
			}
		}
		return tipoCtaReal;
	}

	public String[] CuentasMasivas() throws Exception {
		if (archivoDest == null || archivoDest.trim().isEmpty()) {
			throw new IllegalArgumentException("El archivo no puede ser nulo o vacío");
		}

		File archivo = new File(archivoDest);
		if (!archivo.exists() || !archivo.isFile()) {
			throw new FileNotFoundException("No se encontró el archivo: " + archivoDest);
		}

		String tipoCarga = safeTrim(SettingsRun.getTestData().getParameter("Tipo de Carga"));
		String servicio = safeTrim(SettingsRun.getTestData().getParameter("Servicio"));

		List<String> resultados = new ArrayList<>();
		List<Integer> filasLlenas = new ArrayList<>();

		try (FileInputStream fis = new FileInputStream(archivo); Workbook workbook = WorkbookFactory.create(fis)) {
			if (workbook.getNumberOfSheets() == 0) {
				throw new IllegalStateException("El archivo no contiene hojas");
			}

			Sheet sheet = workbook.getSheetAt(0);
			Iterator<Row> rowIterator = sheet.iterator();

			while (rowIterator.hasNext()) {
				Row row = rowIterator.next();
				boolean filaTieneDatos = false;

				for (Cell cell : row) {
					if (cell != null && cell.getCellType() != CellType.BLANK) {
						String valor = cell.toString().trim();
						if (!valor.isEmpty()) {
							filaTieneDatos = true;
							break;
						}
					}
				}

				if (filaTieneDatos) {
					filasLlenas.add(row.getRowNum());
				}
			}
		}

		DataDriven dd = new DataDrivenExcel(archivoDest);

		for (Integer fila : filasLlenas) {
			if ("Archivo existente Plano".equals(tipoCarga) || "Archivo existente Excel".equals(tipoCarga)) {
				resultados.add("");
				continue;
			}

			String tipoProdDestino = safeGetParameter(dd, "tipoProdDestino", fila);
			String numProdDestino = safeGetParameter(dd, "numProdDestino", fila);

			if ("Crédito.3ros".equals(servicio)) {
				resultados.add(tipoProdDestino + "|" + numProdDestino + "|");
			} else {
				String valorPago = safeGetParameter(dd, "valorPago", fila);
				resultados.add(tipoProdDestino + "|" + numProdDestino + "|" + valorPago);
			}
		}

		return resultados.toArray(new String[0]);
	}

	private String safeTrim(String s) {
		return s == null ? "" : s.trim();
	}

	private String safeGetParameter(DataDriven dd, String paramName, int row) {
		try {
			String v = dd.getParameterByExec(paramName, row);
			return v == null ? "" : v.trim();
		} catch (Exception e) {
			System.err.println("No se pudo leer '" + paramName + "' en fila " + row + ": " + e.getMessage());
			return "";
		}
	}

