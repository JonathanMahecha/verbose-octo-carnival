    }

    private void waitForElementWithTimeout(By locator, int maxAttempts) {
        int attempts = 0;
        int limit = maxAttempts > 0 ? maxAttempts : MAX_WAIT_ATTEMPTS;
        while (safeElement(locator) == null && attempts < limit) {
            sleep(DEFAULT_WAIT_SECONDS);
            attempts++;
        }
    }

    private WebElement waitForElement(By locator, int maxAttempts) {
        int attempts = 0;
        WebElement el = null;
        int limit = maxAttempts > 0 ? maxAttempts : MAX_WAIT_ATTEMPTS;

        while (attempts < limit) {
            el = safeElement(locator);
            if (el != null) {
                return el;
            }
            sleep(DEFAULT_WAIT_SECONDS);
            attempts++;
        }
        return null;
    }

    private void waitUntilEnabled(By locator) {
        int attempts = 0;
        while (attempts < MAX_WAIT_ATTEMPTS) {
            WebElement el = safeElement(locator);
            if (el != null && el.isEnabled()) {
                return;
            }
            sleep(DEFAULT_WAIT_SECONDS);
            attempts++;
        }
    }

    private WebElement waitForPopup() {
        int attempts = 0;
        WebElement popup = null;
        while (attempts < POPUP_MAX_ATTEMPTS) {
            popup = safeElement(xp("/html/body/div[23]"));
            if (popup != null) {
                return popup;
            }
            sleep(POPUP_WAIT_SECONDS);
            attempts++;
        }
        return null;
    }

