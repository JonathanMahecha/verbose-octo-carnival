    /**
     * Punto de entrada principal para ejecutar la transacción completa,
     * incluyendo aprobaciones adicionales.
     */
    public String transar() throws Exception {
        boolean primeroGuardar = TP_PEND_APR.equals(tipoPrueba);

        switch (servicio) {
            case "Tx Internacionales Recibir desde el exterior":
                Recibirdinerodelexterior(primeroGuardar);
                break;

            case "Tx Internacionales Enviar al exterior":
                EnviarTransferenciasInternacionales(primeroGuardar);
                break;

            case "Tx Internacionales Enviar al exterior Pendiente Aprobación":
                if (esPyme()) inicioCrearTx();
                EnviarTransferenciasInternacionalesPendAprobacion();
                break;

            case "Divisas Documentos y Formularios":
                ejecutarDivisasDocumentosYFormularios();
                break;

            case "Consulta Tx Internacionales Validar Estado":
                ejecutarConsultaValidarEstado();
                break;

            default:
                terminarIteracionXError("Servicio no soportado en flujo Divisas: " + servicio);
                throw new UnsupportedOperationException("Servicio no soportado: " + servicio);
        }

        return procesarAprobacionesMultiples(primeroGuardar);
    }

