    /** Navega al módulo "Crear Transacción → Transferencias Internacionales" en el portal Pyme. */
    public void inicioCrearTx() throws Exception {
        pageOrigenPyme = new PageOrigen1(loginFrontPyme);
        String pagoyTx = pageOrigenPyme.getTextMid();

        String msgError = navegarACrearTransaccion(pagoyTx);
        if (msgError != null) { terminarIteracionXError(msgError); return; }

        msgError = pageOrigenPyme.irAServicio("Transferencias Internacionales");
        if (msgError != null) { terminarIteracionXError(msgError); return; }

        this.riesgo = this.prioridaRiesgo;
    }

    private String navegarACrearTransaccion(String pagoyTx) throws Exception {
        String menu = determinarMenuPrincipal(pagoyTx);
        if (this.navegador.contains("CHROME")) {
            return pageOrigenPyme.irAOpcion("Crear Transacción", menu, "Crear Transacción");
        }
        return pageOrigenPyme.irAOpcionMoZilla("Crear Transacción", menu, "Crear Transacción", null, null);
    }

    private String determinarMenuPrincipal(String pagoyTx) {
        String lower = pagoyTx.toLowerCase();
        if (lower.contains("pagos, transferencias y otros"))       return "Pagos, Transferencias y otros";
        if (lower.contains("pagos, transferencias e inscripciones")) return "Pagos, Transferencias e Inscripciones";
        return "Pagos y Transferencias";
    }

