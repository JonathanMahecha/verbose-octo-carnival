						this.totalDestinos++;
					} else {
						Reporter.write("Fila [" + rowIndex + "] del Excel : " + msgError);
					}
				}
			}
		}
		return null;
	}

	private Workbook getWorkbook(FileInputStream inputStream, String archivoDatos) throws IOException {
		if (archivoDatos.endsWith(".xls")) {
			return new HSSFWorkbook(inputStream);
		} else if (archivoDatos.endsWith(".xlsx")) {
			return new XSSFWorkbook(inputStream);
		}
		throw new IllegalArgumentException("El archivo no es un archivo de Excel");
	}

	private String[] getRowCellValues(Row row, int numCells) {
		String[] values = new String[numCells];
		for (int i = 0; i < numCells; i++) {
			Cell cell = row.getCell(i);
			values[i] = (cell != null) ? getCellValueAsString(cell) : "";
		}
		return values;
	}

	private String getCellValueAsString(Cell cell) {
		if (cell.getCellType() == CellType.STRING) {
			return cell.getStringCellValue();
		} else if (cell.getCellType() == CellType.NUMERIC) {
			return Double.toString(cell.getNumericCellValue());
		} else {
			return "";
		}
	}

	private String validateAndAdicionarDestino_NomProv(String[] values) throws Exception {
		String tipoId = values[0];
		String numId = values[1];
		String nombre = values[2];
		String apellido = values[3];
		String bancoDest = values[4];
		bancoDest = this.catBancos.getNombreXCodigo(bancoDest);
		String tipoCtades = values[5];
		String numProdes = values[6];
		String valorPago = values[7];
		String referencia = values[8];

		if (hasEmptyValues(bancoDest, tipoCtades, numProdes, nombre, tipoId, numId, valorPago)) {
			return "Falta información en la fila";
		}

		return pageDestino.adicionarDestino(tipoId, numId, nombre, apellido, bancoDest, tipoCtades, numProdes,
				valorPago, referencia);
	}

	private String validateAndAdicionarDestino_CtasAFC(String[] values) throws Exception {
		String numeroAFC = values[0];
		String titular = values[1];
		String numId = values[2];
		String valorAporte = values[3];
		String valorCuotaCont = values[4];

		if (hasEmptyValues(numeroAFC, titular, numId, valorAporte, valorCuotaCont)) {
			return "Falta información en la fila";
		}

		return pageDestino.adicionarDestinoAFC(numeroAFC, titular, numId, valorAporte, valorCuotaCont);
	}

	private String validateAndAdicionarCred3ros(String[] values) throws Exception {
		String tipoProdDestino = values[0];
		String numProdDestino = values[1];
		String titular = values[2];
		String numDocumento = values[3];
		String valorPagar = values[4];

		if (hasEmptyValues(tipoProdDestino, numProdDestino, titular, numDocumento, valorPagar)) {
			return "Falta información en la fila";
		}

		return pageDestino.adicionarDestinoCred3ros(tipoProdDestino, numProdDestino, titular, numDocumento,
				valorPagar);
	}

	private boolean hasEmptyValues(String... values) {
		for (String value : values) {
			if (value == null || value.isEmpty()) {
				return true;
			}
		}
		return false;
	}

	private String crearArchivoPlano_NomProv(String archivoDatos, List<Integer> listRowExcel) throws Exception {
		String tipoDocEmpr = SettingsRun.getTestData().getParameter("Tipo ID Empresa").trim();
		String numDocEmpr = SettingsRun.getTestData().getParameter("Numero ID Empresa").trim();
		String servicio = SettingsRun.getTestData().getParameter("Servicio").trim();
		String tipoCta = SettingsRun.getTestData().getParameter("Tipo producto origen / Franquicia").trim();
		String numCta = SettingsRun.getTestData().getParameter("Número producto origen").trim();

		String header = getHeader(tipoDocEmpr, numDocEmpr, servicio, tipoCta, numCta);
		String[] arrContenido = getContenido(archivoDatos, listRowExcel);
		String conten = arrContenido[0];
		header = header.replace("TOTAL_TRAS", arrContenido[1]).replace("VALOR_TRAS", arrContenido[2]);

		this.totalDestinos = Integer.valueOf(arrContenido[1]);
		this.valorTransaccion = Double.valueOf(arrContenido[2]);

		String ruta = Evidence.getStartEvidenceName() + "ArchPlano.txt";
		File file = new File(ruta);
		if (!file.exists()) {
			file.createNewFile();
		}

		try (FileWriter fw = new FileWriter(file); BufferedWriter bw = new BufferedWriter(fw)) {
			bw.write(header);
			bw.write(conten);
		}
		return ruta;
	}

	private String getHeader(String tipoDocEmpr, String numDocEmpr, String servicio, String tipoCtaOrigen,
			String numCtaOrigen) throws Exception {

		String numEmp = Util.leftComplete(numDocEmpr, 16, '0');
		String tipoPag = "";
		String ctaOrigen = Util.leftComplete(numCtaOrigen, 16, '0');
		String tipCta = "";
		String codBan = Util.leftComplete("51", 6, '0');
		String valorTras = "VALOR_TRAS";
		String numTottras = "TOTAL_TRAS";
		Util.leftComplete("0", 6, '0');
		String fechpro = Util.dateToString("YYYYMMDD");
		String horapro = Util.hourToString("HH:mm:ss").replace(":", "");
		String complem1 = "000099990000000000000000";
		String tipid = "";
		String complem2 = Util.leftComplete("0", 56, '0');

		servicio = Util.removeAccents(servicio).toUpperCase();
		String codServ = "NA";
		if (servicio.contains("NOMINA")) {
			codServ = "NOMINOMI";
		} else if (servicio.contains("PROVEEDORES")) {
			codServ = "PROVPROV";
		}
		tipoPag = codServ;

		tipCta = getCodigoTipoProducto(tipoCtaOrigen);

		if (catTiposDoc == null) {
			catTiposDoc = new DavCatalogo("");
		}

		String codTipid = this.catTiposDoc.getCodigoXNombre(Util.removeAccents(tipoDocEmpr).toUpperCase());
		tipid = Util.leftComplete(codTipid, 2, '0');

		return "RC" + numEmp + tipoPag + ctaOrigen + tipCta + codBan + valorTras + numTottras + fechpro + horapro
				+ complem1 + tipid + complem2;
	}

	private String[] getContenido(String archivoDatos, List<Integer> listaFilasExcel) throws Exception {
		DataDriven dd = new DataDrivenExcel(archivoDatos);
		StringBuilder contenido = new StringBuilder();

		int totalDestinatarios = 0;
		double valorTotal = 0.0;

		if (catTiposDoc == null) {
			catTiposDoc = new DavCatalogo("");
		}

		for (int fila : listaFilasExcel) {
			String referencia = Util.leftComplete("0", 16, '0');
			String numIdDest = Util.leftComplete(dd.getParameterByExec("numId", fila), 16, '0');
			String numProd = Util.leftComplete(dd.getParameterByExec("numProdDestino", fila), 16, '0');

			String valorTx = dd.getParameterByExec("valorPago", fila);
			if (valorTx == null || valorTx.trim().isEmpty()) {
				valorTx = "0.00";
			} else {
				valorTx = valorTx.trim().replace(",", ".");
				if (!valorTx.contains(".")) {
					valorTx = valorTx + ".00";
					valorTx = valorTx.replace(".", "");
				}
			}
			valorTx = Util.leftComplete(valorTx, 18, '0');

			String talon = "000000";
			String resulPros = "9999";
			String complem3 = Util.leftComplete("0", 81, '0');

			String tipoId = dd.getParameterByExec("tipoId", fila);
			String codTipoId = Util.leftComplete(tipoId == null ? "0" : Util.removeAccents(tipoId).toUpperCase(), 2,
					'0');

			String tipProd = dd.getParameterByExec("tipoProdDestino", fila);
			String codProd = getCodigoTipoProducto(tipProd);

			String nbBanco = dd.getParameterByExec("bancoDestino", fila);
			nbBanco = nbBanco == null ? "" : nbBanco.toUpperCase();

			String codBanDest = Util.leftComplete(catBancos.getCodigoXNombreContained(nbBanco), 6, '0');
			String trasach = nbBanco.contains("DAVIVIENDA") ? "0" : "1";

			contenido.append("\r\nTR").append(numIdDest).append(referencia).append(numProd).append(codProd)
					.append(codBanDest).append(valorTx).append(talon).append(codTipoId).append(trasach)
					.append(resulPros).append(complem3);

			totalDestinatarios++;
			valorTotal += Double.parseDouble(valorTx);
		}

		String numTotTras = Util.leftComplete(String.valueOf(totalDestinatarios), 6, '0');
		String valorTras = Util.leftComplete(Util.formatPlano(valorTotal), 18, '0');

		return new String[] { contenido.toString(), numTotTras, valorTras };
	}

	private String getCodigoTipoProducto(String tipoProducto) {
		String tipoProd = Util.removeAccents(tipoProducto).toUpperCase();
		String codPro = "NA";
		if (tipoProd.contains("ELECTRONICOS") || tipoProd.equalsIgnoreCase("DE")) {
			codPro = "DE";
		} else if (tipoProd.contains("PREPAGO") || tipoProd.contains("MAESTRO") || tipoProd.equalsIgnoreCase("TPM")
				|| tipoProd.equalsIgnoreCase("TP")) {
			codPro = "TP";
		} else if (tipoProd.contains("CORRIENTE") || tipoProd.contains("CREDIPLUS")
				|| tipoProd.equalsIgnoreCase("CC")) {
			codPro = "CC";
		} else if (tipoProd.contains("AHORRO") || tipoProd.equalsIgnoreCase("CA")) {
			codPro = "CA";
		} else if (tipoProd.contains("DAVIPLATA") || tipoProd.equalsIgnoreCase("DP")) {
			codPro = "DP";
		} else if (tipoProd.contains("TARJETA") || tipoProd.equalsIgnoreCase("TC")) {
			codPro = "TC";
		} else if (tipoProd.contains("LLAVE") || tipoProd.equalsIgnoreCase("LL")) {
			codPro = "LL";
		} else {
			codPro = "CR";
		}

		return codPro;
	}

	private String getCodigoTipoId(String tipoid) {
		String tipoIdProd = Util.removeAccents(tipoid).toUpperCase();
		String codPro = "NA";
		if (tipoIdProd.contains("CEDULA DE CIUDADANIA") || tipoIdProd.contains("1")) {
			codPro = "1";
		} else if (tipoIdProd.contains("NIT") || tipoIdProd.contains("3")) {
			codPro = "3";
		} else if (tipoIdProd.contains("CEDULA DE EXTRANJERIA") || tipoIdProd.contains("2")) {
			codPro = "2";
		} else {
			codPro = "0";
		}

		return codPro;
	}

