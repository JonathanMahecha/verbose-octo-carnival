    /**
     * Registra en el Motor de Riesgo cada destino de una transacción masiva
     * (Nómina / Proveedores / AFC / Crédito.3ros), evaluando el nivel de riesgo
     * para determinar el resultado esperado.
     */
    public void validarIngresoMRDestinosMasivo() throws Exception {
        int intentosFall = 0;
        String[] cuentas = this.getCuentasMotor();

        for (String datoDes : cuentas) {
            DatosDavivienda.RISKMOTOR.adicionarRegistro();
            DatosDavivienda.RISKMOTOR.setNumeroTx();
            DatosDavivienda.RISKMOTOR.setResultado();
            DatosDavivienda.RISKMOTOR.setObservacion();

            String uuidLocal = SettingsRun.getTestData().getParameter("Hash").trim();
            DatosDavivienda.RISKMOTOR.setHash(uuidLocal);

            if (!this.tipoPrueba.equals(TP_LOGIN))
                this.transaccion = this.getTransaccion(this.tipoPrueba, this.servicio);
            DatosDavivienda.RISKMOTOR.setTransaccion(this.transaccion);

            String userType = DatosEmpresarial.TOKEN_OTP.equals(DatosEmpresarial.TIPO_TOKEN) ? "Virtual" : "Token";

            String intentos = SettingsRun.getTestData().getParameter("Ingresos Fallidos").trim();
            if (Util.isInteger(intentos)) intentosFall = Integer.valueOf(intentos);

            DatosDavivienda.RISKMOTOR.setUserType(userType);
            DatosDavivienda.RISKMOTOR.setRisk(riesgoBc);
            if (!this.servicio.equals("Tx Internacionales Recibir desde el exterior")
                    && !this.servicio.equals("Tx Internacionales Enviar al exterior"))
                DatosDavivienda.RISKMOTOR.setRiskEFM(riesgoEfm);

            if (this.numeroTx != null) DatosDavivienda.RISKMOTOR.setNumeroTx(this.numeroTx);
            DatosDavivienda.RISKMOTOR.setNumRetosFallidos(intentosFall);

            String navLocal = SettingsRun.getTestData().getParameter("Navegador").trim();
            DatosDavivienda.RISKMOTOR.setNavegador_SistemaOperativo(navLocal);
            DatosDavivienda.RISKMOTOR.setCliente(DatosEmpresarial.CLI_EMPRESAR);
            DatosDavivienda.RISKMOTOR.setDocumento(DatosEmpresarial.TIPO_ID_LOGUEO, DatosEmpresarial.NUM_ID_LOGUEO);

            String[] datoCtaSinEspacios = datoDes.split("\\|");
            DatosDavivienda.RISKMOTOR.setHash(uuidLocal);

            if (this.desdeElDetalle.contains("SI") && this.tipoPrueba.equals("Tx Pend Aprobación"))
                this.desdeElDetalle = "Aprobado dentro del detalle";
            else if (this.desdeElDetalle.contains("NO") && this.tipoPrueba.equals("Tx Pend Aprobación"))
                this.desdeElDetalle = "Aprobado furea del detalle";

            // FIX: condición lógica corregida de || a && para evitar NPE
            if (this.descripcionsin != null
                    && !this.descripcionsin.isEmpty()
                    && !this.descripcionsin.equals(" "))
                DatosDavivienda.RISKMOTOR.setObservacion(this.descripcionsin + " - " + this.desdeElDetalle);

            this.riesgo = this.prioridaRiesgo;

            switch (this.riesgo.toUpperCase()) {
                case MotorRiesgo.RISK_ALTO:
                    procesarRiesgoAltoMasivo(datoCtaSinEspacios);
                    break;
                case MotorRiesgo.RISK_MEDIO:
                case MotorRiesgo.RISK_BAJO:
                    procesarRiesgoBajoMedioMasivo(datoCtaSinEspacios);
                    break;
                default:
                    Reporter.reportEvent(Reporter.MIC_FAIL, "Riesgo [" + riesgo + "] NO contemplado");
                    break;
            }
        }
    }

    /**
     * Lógica de Motor de Riesgo ALTO para destinos masivos.
     */
    private void procesarRiesgoAltoMasivo(String[] d) throws Exception {
        if (this.estadoTx.equals("DECLINADA")) {
            DatosDavivienda.RISKMOTOR.setTemporalResultado("Declinada");
            DatosDavivienda.RISKMOTOR.setTemporalObservacion(servicio);
            DatosDavivienda.RISKMOTOR.setTemporalTime(pageConf.getFechaHoraTx());
            DatosDavivienda.RISKMOTOR.setTime();
            DatosDavivienda.RISKMOTOR.setCuentaOrigen(this.TipoProd(this.tipoCta));
            DatosDavivienda.RISKMOTOR.setNumCuentaOrigen(this.numCta);
            DatosDavivienda.RISKMOTOR.setNumIdEmpresa(this.nitEmpre);
            DatosDavivienda.RISKMOTOR.setReferencia_1("N/A");

            setearCuentaDestinoMasivo(d[1]);

            if (d.length > 2 && d[2] != null) {
                String monto = d[2].contains(",") ? d[2].replace(",", ".").trim() : d[2];
                DatosDavivienda.RISKMOTOR.setMonto(monto);
            }

            resolverCuentaHomologadaMasiva(d);
            setearResultadoEstado();
            setearResultadoDestinoMasivoConRechazo(d);

        } else {
            Reporter.reportEvent(Reporter.MIC_FAIL,
                    "Se esperaba declinación y el mensaje fue [" + (d.length > 5 ? d[5] : "") + "]");

            DatosDavivienda.RISKMOTOR.setTemporalResultado("Exitosa");
            DatosDavivienda.RISKMOTOR.setTemporalObservacion(servicio);
            DatosDavivienda.RISKMOTOR.setTemporalTime(pageConf.getFechaHoraTx());
            DatosDavivienda.RISKMOTOR.setTime();
            DatosDavivienda.RISKMOTOR.setCausaRechazo(this.estado);
            DatosDavivienda.RISKMOTOR.setCuentaOrigen(this.TipoProd(this.tipoCta));
            DatosDavivienda.RISKMOTOR.setNumCuentaOrigen(this.numCta);
            DatosDavivienda.RISKMOTOR.setNumIdEmpresa(this.nitEmpre);

            if (d.length > 2 && d[2] != null)
                DatosDavivienda.RISKMOTOR.setMonto(d[2]);

            setearCuentaDestinoMasivo(d[1]);
            DatosDavivienda.RISKMOTOR.setReferencia_1("N/A");
            resolverCuentaHomologadaMasiva(d);
            setearResultadoDestinoMasivoConRechazo(d);
            DatosDavivienda.RISKMOTOR.setResultado("Exitosa");
        }
    }

    /**
     * Lógica de Motor de Riesgo MEDIO/BAJO para destinos masivos.
     */
    private void procesarRiesgoBajoMedioMasivo(String[] d) throws Exception {
        if (Util.itemInArray(this.estadoTx, arrEstadosTxAprob)) {
            DatosDavivienda.RISKMOTOR.setTemporalResultado(MotorRiesgo.RESULT_SUCCESS);
            DatosDavivienda.RISKMOTOR.setTemporalObservacion(servicio);
            DatosDavivienda.RISKMOTOR.setTemporalTime(pageConf.getFechaHoraTx());
            DatosDavivienda.RISKMOTOR.setTime();
            DatosDavivienda.RISKMOTOR.setNumIdEmpresa(this.nitEmpre);
            DatosDavivienda.RISKMOTOR.setReferencia_1("N/A");

            if (d.length > 2 && d[2] != null)
                DatosDavivienda.RISKMOTOR.setMonto(d[2]);

            DatosDavivienda.RISKMOTOR.setCuentaOrigen(this.TipoProd(this.tipoCta));
            DatosDavivienda.RISKMOTOR.setNumCuentaOrigen(this.numCta);
            setearCuentaDestinoMasivo(d[1]);

            if (this.servicio.contains("Mismo NIT") || this.servicio.contains("Cuenta No Inscrita")
                    || this.servicio.contains("Cuenta Inscrita"))
                DatosDavivienda.RISKMOTOR.setNumCuentaDestino(this.referencia2);

            resolverCuentaHomologadaMasiva(d);

            DatosDavivienda.RISKMOTOR.setCausaRechazo(this.estado);
            setearResultadoEstado();
            setearResultadoDestinoMasivoConRechazo(d);

        } else {
            Reporter.reportEvent(Reporter.MIC_FAIL,
                    "Se esperaba transaccion exitosa y el estado fue [" + this.estadoTx + "]");

            DatosDavivienda.RISKMOTOR.setTemporalObservacion(servicio);
            DatosDavivienda.RISKMOTOR.setTemporalTime(pageConf.getFechaHoraTx());
            DatosDavivienda.RISKMOTOR.setTime();
            DatosDavivienda.RISKMOTOR.setCausaRechazo(this.estado);
            DatosDavivienda.RISKMOTOR.setResultado("Declinada");
            DatosDavivienda.RISKMOTOR.setNumCuentaOrigen(this.numCta);
            DatosDavivienda.RISKMOTOR.setNumIdEmpresa(this.nitEmpre);

            if (d.length > 2 && d[2] != null)
                DatosDavivienda.RISKMOTOR.setMonto(d[2]);

            DatosDavivienda.RISKMOTOR.setCuentaOrigen(this.TipoProd(this.tipoCta));
            DatosDavivienda.RISKMOTOR.setReferencia_1("N/A");
            setearCuentaDestinoMasivo(d[1]);
            resolverCuentaHomologadaMasiva(d);
            setearResultadoDestinoMasivoConRechazo(d);
        }
    }

    /** Asigna el tipo de cuenta destino según el texto del campo destino masivo. */
    private void setearCuentaDestinoMasivo(String textoDestino) throws Exception {
        if (contiene(textoDestino, "otros", "OTROS", "OTROS BANCOS", "otros bancos",
                "CUENTAS CORRIENTES OTROS BANCOS", "CUENTAS AHORRO OTROS BANCOS",
                "electronicos", "electrónicos", "ELECTRONICOS", "ELECTRÓNICOS")) {
            DatosDavivienda.RISKMOTOR.setCuentaDestino("Monedero otro Banco");
            if (contiene(textoDestino, "electronicos", "electrónicos", "ELECTRONICOS", "ELECTRÓNICOS"))
                DatosDavivienda.RISKMOTOR.setTransaccion("Pago a monederos");
        } else if (contiene(textoDestino, "cuenta de ahorros", "CUENTA DE AHORROS")) {
            DatosDavivienda.RISKMOTOR.setCuentaDestino("Cuenta Ahorros");
        } else if (contiene(textoDestino, "Cuenta Corriente", "CUENTA CORRIENTE")) {
            DatosDavivienda.RISKMOTOR.setCuentaDestino("Cuenta corriente");
        } else if (contiene(textoDestino, "Daviplata", "DAVIPLATA")) {
            DatosDavivienda.RISKMOTOR.setCuentaDestino("Daviplata");
        } else if (contiene(textoDestino, "TARJETA PREPAGO MAESTRO", "tarjeta prepago maestro")) {
            DatosDavivienda.RISKMOTOR.setCuentaDestino("Tarjeta Prepago");
        } else if (!textoDestino.contains("Davivienda") || !textoDestino.contains("Daviplata")) {
            DatosDavivienda.RISKMOTOR.setCuentaDestino(this.TipoProd(this.referencia1));
        }
    }

    /** Busca y registra la cuenta homologada para destinos masivos de Nómina o Proveedores. */
    private void resolverCuentaHomologadaMasiva(String[] d) throws Exception {
        if (!this.servicio.contains("Nómina") && !this.servicio.contains("Pago a Proveedores")) return;
        if (datoNumDestCuentas == null) return;

        for (String desMigrada : datoNumDestCuentas) {
            String[] d2 = desMigrada.split("\\|");
            if (contiene(d2[0], "DEPÓSITOS ELECTRONICOS", "DEPÓSITOS ELECTRÓNICOS"))
                d2[0] = "DEPÓSITOS ELECTRONICOS";

            if (d2[0].equals(d[1]) && d.length > 4 && d2[1].contains(Util.right(d[4], 4))) {
                DatosDavivienda.RISKMOTOR.setNumCuentaDestino(d2[1]);

                if (controlDest == null) controlDest = new ControllerDestinosMasivos(pageDestino);
                String homologada = controlDest.BuscarCuentasMigrada(d2[0], d2[1]);
                DatosDavivienda.RISKMOTOR.setNumCuentaOrigenMigrada(homologada);
                break;
            }
        }
    }

    /**
     * Registra el resultado de la transacción a partir del mensaje de estado.
     */
    private void setearResultadoEstado() {
        if (contiene(this.estado, "rechazada", "denegado", "no")) {
            DatosDavivienda.RISKMOTOR.setResultado("Declinada");
            DatosDavivienda.RISKMOTOR.setCausaRechazo(" ");
        } else if (contiene(this.estado, "EXCEDE", "TOPE", "1480")) {
            DatosDavivienda.RISKMOTOR.setResultado("Rechazado");
            DatosDavivienda.RISKMOTOR.setCausaRechazo(this.estado);
        } else {
            DatosDavivienda.RISKMOTOR.setResultado("Exitosa");
            DatosDavivienda.RISKMOTOR.setCausaRechazo(this.estado);
        }

        if (contiene(this.estado, "rechazada", "no pudo ser realizada"))
            DatosDavivienda.RISKMOTOR.setTemporalResultado("Declinada");
        else if (this.estado.contains("TX EXCEDE TOPE SALDO"))
            DatosDavivienda.RISKMOTOR.setTemporalResultado("Rechazado");
    }

    /**
     * Evalúa las posiciones [5] y [6] del array de datos del destino masivo
     * para registrar rechazos específicos.
     */
    private void setearResultadoDestinoMasivoConRechazo(String[] d) {
        if (d.length <= 5 || d[5] == null || d[5].isEmpty()) return;

        String estado5 = d[5];
        String estado6 = d.length > 6 ? d[6] : null;
        boolean tieneEstado6 = estado6 != null && !estado6.isEmpty()
                && !estado6.equals("null") && !estado6.equals(" ");

        if ("Pago Rechazado".equals(estado5)) {
            if (!tieneEstado6 && esValido(estado5)) {
                Reporter.reportEvent(Reporter.MIC_FAIL, "Pago Rechazado y el mensaje fue [" + estado5 + "]");
                DatosDavivienda.RISKMOTOR.setCausaRechazo(estado5);
                DatosDavivienda.RISKMOTOR.setResultado("Rechazada");
            } else if (tieneEstado6) {
                Reporter.reportEvent(Reporter.MIC_FAIL, "Pago Rechazado y el mensaje fue [" + estado6 + "]");
                DatosDavivienda.RISKMOTOR.setCausaRechazo(estado6);
                DatosDavivienda.RISKMOTOR.setResultado("Rechazada");
            }
        } else if (!estado5.isEmpty() && tieneEstado6) {
            Reporter.reportEvent(Reporter.MIC_FAIL, "Pago Rechazado y el mensaje fue [" + estado6 + "]");
            DatosDavivienda.RISKMOTOR.setCausaRechazo(estado6);
            DatosDavivienda.RISKMOTOR.setResultado("Rechazada");
        } else if ("Exitoso".equals(estado5)) {
            DatosDavivienda.RISKMOTOR.setResultado("Exitosa");
            Reporter.reportEvent(Reporter.MIC_FAIL,
                    "Se esperaba declinación y el mensaje fue [" + estado5 + "]");
        }
    }

    private boolean esValido(String s) {
        return s != null && !s.equals("null") && !s.isEmpty() && !s.equals(" ");
    }

    // ============================[Motor de riesgo - Individual]==================

    /**
     * Registra en el Motor de Riesgo una transacción individual, evaluando el
     * nivel de riesgo para determinar el resultado esperado.
     */
    public void validarIngresoMR() throws Exception {
        DatosDavivienda.RISKMOTOR.adicionarRegistro();

        Date fechaHoraLogMR = new Date();
        DatosDavivienda.RISKMOTOR.setTemporalTime(fechaHoraLogMR);
        DatosDavivienda.RISKMOTOR.setTime();
        DatosDavivienda.RISKMOTOR.setMonto();
        DatosDavivienda.RISKMOTOR.setNumeroTx();
        DatosDavivienda.RISKMOTOR.setResultado();
        DatosDavivienda.RISKMOTOR.setObservacion();
        DatosDavivienda.RISKMOTOR.setObservacion(this.desdeElDetalle);

        String uuidLocal = SettingsRun.getTestData().getParameter("Hash").trim();
        DatosDavivienda.RISKMOTOR.setHash(uuidLocal);

        this.servicio = SettingsRun.getTestData().getParameter("Servicio").trim();
        DatosDavivienda.RISKMOTOR.setTransaccion(this.getTransaccion(this.tipoPrueba, this.servicio));

        String userType = DatosEmpresarial.TOKEN_OTP.equals(DatosEmpresarial.TIPO_TOKEN) ? "Virtual" : "Token";

        String intentos = SettingsRun.getTestData().getParameter("Ingresos Fallidos").trim();
        int intentosFall = Util.isInteger(intentos) ? Integer.valueOf(intentos) : 0;

        DatosDavivienda.RISKMOTOR.setUserType(userType);
        DatosDavivienda.RISKMOTOR.setRisk(riesgoBc);
        if (!this.servicio.equals("Tx Internacionales Recibir desde el exterior")
                && !this.servicio.equals("Tx Internacionales Enviar al exterior"))
            DatosDavivienda.RISKMOTOR.setRiskEFM(riesgoEfm);

        DatosDavivienda.RISKMOTOR.setNumRetosFallidos(intentosFall);
        DatosDavivienda.RISKMOTOR.setNavegador_SistemaOperativo(this.navegador);
        DatosDavivienda.RISKMOTOR.setCliente(DatosEmpresarial.CLI_EMPRESAR);
        DatosDavivienda.RISKMOTOR.setDocumento(DatosEmpresarial.TIPO_ID_LOGUEO, DatosEmpresarial.NUM_ID_LOGUEO);

        if (!this.servicio.contains("Nómina") || !this.servicio.contains("Pago a Proveedores")
                || !this.servicio.contains("AFC") || !this.servicio.contains("Crédito.3ros")) {
            DatosDavivienda.RISKMOTOR.setTemporalMonto(this.montoReal);
        }

        if (!this.tipoPrueba.equals(TP_LOGIN))
            this.transaccion = this.getTransaccion(this.tipoPrueba, this.servicio);
        DatosDavivienda.RISKMOTOR.setTransaccion(this.transaccion);
        DatosDavivienda.RISKMOTOR.setHash(uuidLocal);

        if (this.numeroTx != null) DatosDavivienda.RISKMOTOR.setNumeroTx(this.numeroTx);

        if (this.desdeElDetalle.contains("SI") && this.tipoPrueba.equals("Tx Pend Aprobación"))
            this.desdeElDetalle = "Aprobado dentro del detalle";
        else if (this.desdeElDetalle.contains("NO") && this.tipoPrueba.equals("Tx Pend Aprobación"))
            this.desdeElDetalle = "Aprobado furea del detalle";

        DatosDavivienda.RISKMOTOR.setObservacion(this.desdeElDetalle);

        // FIX: condición corregida de || a && para evitar NPE sobre descripcionsin
        if (this.descripcionsin != null
                && !this.descripcionsin.isEmpty()
                && !this.descripcionsin.equals(" "))
            DatosDavivienda.RISKMOTOR.setObservacion(this.descripcionsin + " - " + this.desdeElDetalle);

        DatosDavivienda.RISKMOTOR.setRisk(SettingsRun.getTestData().getParameter("Nivel de Riesgo BC").trim());
        if (!this.servicio.equals("Tx Internacionales Recibir desde el exterior")
                && !this.servicio.equals("Tx Internacionales Enviar al exterior"))
            DatosDavivienda.RISKMOTOR.setRiskEFM(
                    SettingsRun.getTestData().getParameter("Nivel de Riesgo SAS EFM").trim());

        this.riesgo = this.prioridaRiesgo;

        switch (this.riesgo.toUpperCase()) {
            case MotorRiesgo.RISK_ALTO:
                procesarRiesgoAltoIndividual();
                break;
            case MotorRiesgo.RISK_MEDIO:
            case MotorRiesgo.RISK_BAJO:
                procesarRiesgoBajoMedioIndividual();
                break;
            default:
                Reporter.reportEvent(Reporter.MIC_FAIL, "Riesgo [" + riesgo + "] NO contemplado");
                break;
        }
    }

    private void procesarRiesgoAltoIndividual() throws Exception {
        if (this.estadoTx.equals("DECLINADA")) {
            DatosDavivienda.RISKMOTOR.setTemporalResultado(MotorRiesgo.RESULT_SUCCESS);
            DatosDavivienda.RISKMOTOR.setTemporalObservacion(servicio);
            DatosDavivienda.RISKMOTOR.setTemporalTime(pageConf.getFechaHoraTx());
            DatosDavivienda.RISKMOTOR.setTime();
            DatosDavivienda.RISKMOTOR.setNumIdEmpresa(this.nitEmpre);
            if (activityAmount != null) DatosDavivienda.RISKMOTOR.setMonto(activityAmount);

            setearCuentaOrigenIndividual();
            setearCuentaDestinoIndividual();
            buscarCuentaMigradaIndividual();

            DatosDavivienda.RISKMOTOR.setCausaRechazo(this.estado);
            setearResultadoEstadoIndividual();

        } else {
            Reporter.reportEvent(Reporter.MIC_FAIL,
                    "Se esperaba declinación y el mensaje fue [" + this.estadoTx + "]");

            DatosDavivienda.RISKMOTOR.setTemporalObservacion(servicio);
            DatosDavivienda.RISKMOTOR.setTemporalTime(pageConf.getFechaHoraTx());
            DatosDavivienda.RISKMOTOR.setTime();
            DatosDavivienda.RISKMOTOR.setCausaRechazo(this.estado);
            DatosDavivienda.RISKMOTOR.setNumIdEmpresa(this.nitEmpre);
            if (activityAmount != null) DatosDavivienda.RISKMOTOR.setMonto(activityAmount);

            setearCuentaOrigenIndividual();
            setearCuentaDestinoIndividual();
            buscarCuentaMigradaIndividual();

            DatosDavivienda.RISKMOTOR.setResultado("Exitosa");
            if (contiene(this.estado, "rechazada", "no pudo ser realizada"))
                DatosDavivienda.RISKMOTOR.setResultado("Declinada");
            else if (this.estado.contains("TX EXCEDE TOPE SALDO"))
                DatosDavivienda.RISKMOTOR.setResultado("Rechazado");
        }
    }

    private void procesarRiesgoBajoMedioIndividual() throws Exception {
        if (Util.itemInArray(this.estadoTx, arrEstadosTxAprob)) {
            DatosDavivienda.RISKMOTOR.setTemporalResultado(MotorRiesgo.RESULT_SUCCESS);
            DatosDavivienda.RISKMOTOR.setTemporalObservacion(servicio);
            DatosDavivienda.RISKMOTOR.setTemporalTime(pageConf.getFechaHoraTx());
            DatosDavivienda.RISKMOTOR.setTime();
            DatosDavivienda.RISKMOTOR.setNumIdEmpresa(this.nitEmpre);
            if (activityAmount != null) DatosDavivienda.RISKMOTOR.setMonto(activityAmount);

            setearCuentaOrigenIndividual();
            setearCuentaDestinoIndividual();
            buscarCuentaMigradaIndividual();

            DatosDavivienda.RISKMOTOR.setCausaRechazo(this.estado);
            setearResultadoEstadoIndividual();

        } else {
            Reporter.reportEvent(Reporter.MIC_FAIL,
                    "Se esperaba transaccion exitosa y el estado fue [" + this.estadoTx + "]");

            DatosDavivienda.RISKMOTOR.setTemporalObservacion(servicio);
            DatosDavivienda.RISKMOTOR.setTemporalTime(pageConf.getFechaHoraTx());
            DatosDavivienda.RISKMOTOR.setTime();
            DatosDavivienda.RISKMOTOR.setCausaRechazo(this.estado);
            DatosDavivienda.RISKMOTOR.setResultado("Declinada");
            DatosDavivienda.RISKMOTOR.setNumIdEmpresa(this.nitEmpre);
            if (activityAmount != null) DatosDavivienda.RISKMOTOR.setMonto(activityAmount);

            setearCuentaOrigenIndividual();
            setearCuentaDestinoIndividual();
            buscarCuentaMigradaIndividual();
        }
    }

    private void setearCuentaOrigenIndividual() {
        if (!this.servicio.equals("Tx Internacionales Recibir desde el exterior")) {
            DatosDavivienda.RISKMOTOR.setCuentaOrigen(this.TipoProd(this.tipoCta));
            DatosDavivienda.RISKMOTOR.setNumCuentaOrigen(this.numCta);
        } else {
            DatosDavivienda.RISKMOTOR.setCuentaOrigen("Cuenta en el extranjero");
            DatosDavivienda.RISKMOTOR.setNumCuentaOrigen("N/A");
        }
    }

    private void setearCuentaDestinoIndividual() {
        // Banco destino
        if (this.bancoDesMotor != null && !this.bancoDesMotor.equals(" ")) {
            if (contiene(this.bancoDesMotor, "Davivienda", "DAVIVIENDA", "Daviplata")) {
                DatosDavivienda.RISKMOTOR.setCuentaDestino(this.TipoProd(this.referencia1));
            } else {
                DatosDavivienda.RISKMOTOR.setCuentaDestino("Monedero otro Banco");
            }
        }

        if (this.servicio.contains("Servicios")) {
            if (Util.isNumeric(this.referencia1)) {
                if (referencia2.isEmpty())
                    DatosDavivienda.RISKMOTOR.setReferencia_1(this.referencia1);
                else
                    DatosDavivienda.RISKMOTOR.setReferencia_1(this.referencia1, this.referencia2);
            } else {
                DatosDavivienda.RISKMOTOR.setReferencia_1(this.referencia2);
            }
            DatosDavivienda.RISKMOTOR.setNumCuentaDestino("No Aplica");
            DatosDavivienda.RISKMOTOR.setCuentaDestino("Cuenta Corriente");

        } else {
            DatosDavivienda.RISKMOTOR.setCuentaDestino(this.TipoProd(this.referencia1));
            DatosDavivienda.RISKMOTOR.setReferencia_1("N/A");

            if (this.servicio.equals("Tx Internacionales Recibir desde el exterior")) {
                DatosDavivienda.RISKMOTOR.setTransaccion("Recibir Dinero del Exterior");
                DatosDavivienda.RISKMOTOR.setCuentaDestino(this.referencia1);
                DatosDavivienda.RISKMOTOR.setObservacion("Tipo Cta Destino " + this.referencia2);
            }

            if (this.servicio.equals("Tx Internacionales Enviar al exterior")) {
                DatosDavivienda.RISKMOTOR.setTransaccion("Enviar Dinero al Exterior");
                DatosDavivienda.RISKMOTOR.setCuentaDestino("Cuenta en el extranjero");
                DatosDavivienda.RISKMOTOR.setObservacion("");
            }

            if (this.servicio.contains("Cuenta No Inscrita") || this.servicio.contains("Mismo NIT")
                    || this.servicio.contains("Cuenta Inscrita")) {
                DatosDavivienda.RISKMOTOR.setNumCuentaDestino(this.referencia2);
                DatosDavivienda.RISKMOTOR.setCuentaDestino(this.TipoProd(this.referencia1));

                if (contiene(this.referencia1, "DEPÓSITOS ELECTRONICOS", "DEPÓSITOS ELECTRÓNICOS",
                        "Depósitos electronicos")) {
                    DatosDavivienda.RISKMOTOR.setCuentaDestino("Monedero otro Banco");
                    DatosDavivienda.RISKMOTOR.setTransaccion("Transferencias a monederos");
                }
            }
        }
    }

    private void buscarCuentaMigradaIndividual() throws Exception {
        if (!this.servicio.equals("Tx Internacionales Recibir desde el exterior")) {
            if (contiene(this.servicio, "Nómi", "Proveedores", "AFC", "Pago a Créditos de Terceros",
                    "Pagos a créditos de terceros", "Crédito.3ros", "Transferencias Mismo NIT",
                    "Transferencia NIT Propio", "Mismo NIT", "Transferencias Cuenta Inscrita",
                    "Cuenta Inscrita", "Transferencias Cuenta No Inscrita",
                    "Transferencias Cuenta NO Inscrita", "Cuenta No Inscrita")) {

                if (controlDest == null) controlDest = new ControllerDestinosMasivos(pageDestino);
                String homologada = controlDest.BuscarCuentasMigrada(this.TipoProd(this.tipoCta), this.numCta);
                DatosDavivienda.RISKMOTOR.setNumCuentaOrigenMigrada(homologada);
            }
        } else {
            if (contiene(this.referencia1, "DEPÓSITOS ELECTRONICOS", "DEPÓSITOS ELECTRÓNICOS",
                    "Depósitos electronicos"))
                this.referencia1 = "DEPÓSITOS ELECTRONICOS";

            DatosDavivienda.RISKMOTOR.setNumCuentaDestino(this.referencia2);

            if (controlDest == null) controlDest = new ControllerDestinosMasivos(pageDestino);
            String homologada = controlDest.BuscarCuentasMigrada(this.TipoProd(this.referencia1), this.referencia2);
            DatosDavivienda.RISKMOTOR.setNumCuentaOrigenMigrada(homologada);
        }
    }

    private void setearResultadoEstadoIndividual() {
        if (contiene(this.estado, "rechazada", "denegado", "no")) {
            DatosDavivienda.RISKMOTOR.setResultado("Declinada");
        } else if (contiene(this.estado, "EXCEDE", "TOPE", "1480")) {
            DatosDavivienda.RISKMOTOR.setResultado("Rechazado");
        } else {
            DatosDavivienda.RISKMOTOR.setResultado("Exitosa");
            DatosDavivienda.RISKMOTOR.setCausaRechazo(" ");
        }

        if (contiene(this.estado, "rechazada", "no pudo ser realizada"))
            DatosDavivienda.RISKMOTOR.setTemporalResultado("Declinada");
        else if (this.estado.contains("TX EXCEDE TOPE SALDO"))
            DatosDavivienda.RISKMOTOR.setTemporalResultado("Rechazado");
    }

