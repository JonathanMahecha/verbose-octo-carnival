public void validacionSaldosStratus(String servicio,
                                    String tipoDocumento,
                                    String numeroDoc,
                                    String tipoCta,
                                    String numCta,
                                    boolean saldoOrigen) throws Exception {

    if (this.instanciaStratus == null) {
        return;
    }

    String saldoPortal = null;
    String saldoDisponiblePortal = null;

    List<String> saldosCrediexpress = new ArrayList<>();

    if (saldoOrigen) {

        saldoPortal = obtenerSaldoPortal(servicio, tipoCta, numCta);

        if (saldoPortal != null) {
            saldoDisponiblePortal = saldoPortal
                    .replace("$ ", "")
                    .replace(".", "")
                    .replace(",", ".");
        }

        if (!tipoCta.contains("CREDITO")) {

            List<WebElement> listaCredi = findElements(
                    By.xpath(
                            this.saldoDisXpath
                                    .replace("NUMCUENTA", Util.right(numCta, 4))
                                    .replace("TIPOCUENTA", "Crediexpress")
                    )
            );

            for (WebElement saldo : listaCredi) {

                saldosCrediexpress.add(
                        saldo.getText()
                                .replace("$ ", "")
                                .replace(".", "")
                                .replace(",", ".")
                );
            }
        }
    }

    String[] datosCuenta = ajustarTipoCuentaStratus(tipoCta, numCta);

    tipoCta = datosCuenta[0];
    numCta = datosCuenta[1];

    String[] saldosStratus = this.instanciaStratus.getDatosPantallaSaldos(
            tipoDocumento,
            numeroDoc,
            tipoCta,
            numCta
    );

    if (saldosStratus == null) {
        return;
    }

    if (saldosStratus[0].contains("NO EXISTE")) {

        Reporter.reportEvent(
                5,
                "Cuenta no encontrada en Stratus: " + numCta
        );

        return;
    }

    procesarSaldosStratus(
            tipoCta,
            saldosStratus,
            saldoOrigen
    );

    if (saldoOrigen && saldoDisponiblePortal != null) {

        validarCorrespondenciaSaldo(
                tipoCta,
                saldoDisponiblePortal,
                saldoPortal,
                saldosCrediexpress,
                numCta
        );
    }
}

private String obtenerSaldoPortal(String servicio,
                                  String tipoCta,
                                  String numCta) throws Exception {

    String saldoDis = null;

    if (!servicio.contains("Servicios")) {

        if (!servicio.contains("Mismo NIT") && !servicio.contains("TC")) {

            saldoDis = getText(
                    element(
                            this.saldoDisXpath
                                    .replace("NUMCUENTA", Util.right(numCta, 4))
                                    .replace("TIPOCUENTA", tipoCta)
                    )
            );

        } else {

            saldoDis = getText(
                    element(
                            this.saldoDisXpathMismoNit
                                    .replace("NUMCUENTA", Util.right(numCta, 4))
                                    .replace("TIPOCUENTA", tipoCta)
                    )
            );
        }

    } else {

        saldoDis = getText(
                element(
                        this.saldoDisServiciosXpath2
                                .replace("NUMCUENTA", Util.right(numCta, 4))
                                .replace("TIPOCUENTA", tipoCta)
