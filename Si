    /**
     * Inicializa el controlador y configura el ambiente de pruebas.
     * Debe invocarse antes que {@link #doingTest()}.
     */
    public void initializeControllerAndConfiguration() throws Exception {
        Reporter.write("\n*** PRUEBAS PORTAL PYME ***");
        DXCUtil.startWinAppDriver();

        SettingsRun.ARRAY_DATA_PARAMS = new String[]{"Selección", "Tx Finalizada", "Tx FAIL"};

        configurarAmbiente();
        configurarValidaciones();
        cargarDatosDePrueba();
        configurarMotorDeRiesgoSiCorresponde();
    }

    private void configurarAmbiente() {
        nombreAmbiente = mapearAmbiente(globalData("AMBIENTE_PYME"));
        if (isEmpty(nombreAmbiente)) {
            fail("Nombre del ambiente seleccionado: Portal - " + nombreAmbiente);
        } else {
            Reporter.reportEvent(Reporter.MIC_HEADER,
                    "Nombre del ambiente seleccionado: Portal - " + nombreAmbiente);
        }
        DatosEmpresarial.AMBIENTE_TEST = nombreAmbiente;
    }

    private void configurarValidaciones() {
        contratacion = globalData("CONTRATACION");
        realizarMR   = globalData("MOTOR.motorDeRiesgo");

        if (NO.equals(realizarMR)) {
            cobros  = globalData("VALIDACION.COBROS");
            stratus = globalData("VALIDAR.STRATUS");
        } else {
            cobros  = NO;
            stratus = NO;
        }
    }

    private void cargarDatosDePrueba() {
        servicio = requireParam(param("Servicio"), "Servicio");

        if (!"Crédito.3ros".equals(servicio)) {
            valorTx = requireParam(param("Valor a Pagar / Transferir"), "Valor a Pagar / Transferir");
        }

        usuario = requireParam(param("Nombre de Usuario"), "Nombre de Usuario");

        // Parámetros opcionales para consultas
        tipoConstaTxRealizadas  = paramIfExists("Tiempo de Consulta");
        ordenanteBeneficiario   = paramIfExists("Ordenante / Nombre del beneficiario en el exterior");
        tipoTranferencia        = paramIfExists("Tipo de Transferencia");
        estado                  = paramIfExists("Estado");
        tipoMoneda              = paramIfExists("Tipo Moneda");
        fechaTx                 = paramIfExists("Fecha tx");
        horaTx                  = paramIfExists("Hora tx");
    }

    private String paramIfExists(String name) {
        return SettingsRun.getTestData().parameterExist(name) ? param(name) : null;
    }

    private void configurarMotorDeRiesgoSiCorresponde() throws Exception {
        if (!SI.equals(realizarMR)) return;

        riesgoBc  = requireParam(param("Nivel de Riesgo BC"),      "Nivel de Riesgo BC");
        riesgoEfm = requireParam(param("Nivel de Riesgo SAS EFM"), "Nivel de Riesgo SAS EFM");

        DatosDavivienda.IS_RISKMOTOR = true;
        String nombreArchivo = MotorRiesgo.preguntarPorArchivoMR();
        String canal = esServicioDivisas(servicio)
                ? DatosDavivienda.CANAL_PYME_FRONT_DIVISAS
                : DatosDavivienda.CANAL_PYME_FRONT;

        DatosDavivienda.RISKMOTOR = (nombreArchivo == null)
                ? new MotorRiesgo(canal)
                : new MotorRiesgo(canal, nombreArchivo);
    }

    /**
     * Convierte el código de ambiente en su nombre completo.
     * Acepta tanto el número como el nombre literal para flexibilidad.
     */
    private String mapearAmbiente(String codigo) {
        if (codigo == null) return "";
        switch (codigo) {
            case "1": case "PROYECTOS":       return "PROYECTOS";
            case "2": case "CONTENCION":      return "CONTENCION";
            case "3": case "OBSOLESCENCIA":   return "OBSOLESCENCIA";
            case "4": case "ONPREMISE":       return "ONPREMISE";
            case "5": case "POST_NUBE":       return "POST_NUBE";
            case "6": case "CONTENCION_NUBE": return "CONTENCION_NUBE";
            case "7": case "PROYECTOS_NUBE":  return "PROYECTOS_NUBE";
            case "8": case "PROYECTOS_SO":    return "PROYECTOS_SO";
            case "9": case "MEJORAS":         return "MEJORAS";
            default:
                fail("Opción de ambiente no válida: " + codigo);
                return codigo;
        }
    }

