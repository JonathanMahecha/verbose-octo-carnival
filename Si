	private boolean cambiarAVentanaEmergente() throws Exception {
		Util.wait(5);
		int i = 0;
		WebElement empresa = null;
		WebElement nota = null;
		List<String> ventanas = new ArrayList<>(getDriver().getWindowHandles());

		do {
			for (String handle : ventanas) {
				i++;
				Util.wait(3);

				Reporter.reportEvent(Reporter.MIC_INFO, handle);
				getDriver().switchTo().window(handle);

				nota = element(By.xpath("//*[contains(text(),'usted ha ingresado al Portal Empresarial Davivienda')]"));

				try {
					changeFrame("left_frame");
				} catch (Exception e) {
					// TODO: handle exception
					System.out.println(1);
				}
				empresa = element(By.xpath("//select[contains(@id,'ComboEmpresas')]"));

				if (isDisplayed(nota)) {
					getDriver().close();
				} else if (isDisplayed(empresa)) {
					return true;
				}

			}
		} while (isDisplayed(empresa));
