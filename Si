public String setDireccion(
        String direccion,
        String claseDireccion,
        String pais,
        String departamento,
        String ciudad,
        String municipio) throws Exception {

    changeToDefaultFrame();

    WebElement popup = waitForPopup();
    if (popup == null) {
        return "No fue posible visualizar el popup de Dirección";
    }

    completarFormularioDireccion(
            direccion,
            claseDireccion,
            pais,
            departamento,
            ciudad,
            municipio);

    safeClick(btonCrear);
    waitSeconds(1);

    if (reporteAlertas()) {
        return "Revise hoja de datos, los valores ingresados para la dirección no existen en C360";
    }

    return null;
}

private void completarFormularioDireccion(
        String direccion,
        String claseDireccion,
        String pais,
        String departamento,
        String ciudad,
        String municipio) {

    write(inputDireccion, direccion);
    write(inputClaseDireccion, claseDireccion);
    write(inputPais, pais);
    write(inputDepartamento, departamento);
    write(inputCiudad, ciudad);
    write(inputMunicipio, municipio);
}

