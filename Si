	// ── Inicialización ───────────────────────────────────────────────────────

	private void inicializarMotorRiesgo(String canal, String archivo) throws Exception {
		this.nbArchivoMR = archivo;
		this.tieneDatos = true;

		boolean yaExisteFile = archivo != null && !archivo.isEmpty() && new File(archivo).exists();

		String[] datosArchivo = getDataArchivoMR(canal);
		String rutaPlantilla = datosArchivo[0];
		String nbArchivoNuevo = datosArchivo[1];

		if (!yaExisteFile) {
			this.tieneDatos = false;

			String dirTest = Evidence.getNbEvidenceDirectory();
			File directory = new File(dirTest);
			if (!directory.exists()) {
				directory.mkdir();
			}

			this.nbArchivoMR = dirTest + File.separator + nbArchivoNuevo;
			Util.copyFile(MotorRiesgo.class, rutaPlantilla, this.nbArchivoMR);
		}

		if (this.dataSheetMR == null) {
			this.dataSheetMR = new DataSheet(this.nbArchivoMR, NB_SHEET_MR, 2);
		}

		if (!this.dataSheetMR.parametersExist(this.nbParamsEsperados)) {
			throw new Exception("MotorRiesgo ERROR -- Alguno de los parámetros para [" + canal
					+ "] NO se encuentra en el archivo de MR :\n" + Util.arrayToString(this.nbParamsEsperados, "\n"));
		}

		cargarFilaNextRegistro();
	}

	/**
	 * Retorna { rutaPlantilla, nombreArchivoDestino } según el canal, y deja
	 * configurados los campos de instancia [rangoColumns] y [nbParamsEsperados]
	 * requeridos para ese canal.
	 */
	private String[] getDataArchivoMR(String canal) throws Exception {
		String prefijo = Util.dateToString("yyyymmdd") + "_" + Util.hourToString("HHmm");

		switch (canal) {

		case DatosDavivienda.CANAL_APP_PERSONAS:
		case DatosDavivienda.CANAL_DAVICOM: {
			boolean esDavicom = canal.equals(DatosDavivienda.CANAL_DAVICOM);
			this.nbApplication = esDavicom ? "Davivienda.com" : "App Personas";
			String nbArchivo = prefijo + (esDavicom ? "_SetMR_Davicom.xlsx" : "_SetMR_AppPersonas.xlsx");

			MR_NAV_SO = "Operating System";
			this.rangoColumns = "1:32";
			this.nbParamsEsperados = new String[] { MR_ID_REG, MR_SESSION_ID, MR_FECHA, MR_HORA, MR_HASH,
					MR_USER_TYPE, MR_RISK, MR_POLICY_ACTION, MR_ACTIVITY_NAME, MR_NB_TX, MR_RESULTADO,
					MR_OBSERVACION, MR_NUM_RETOS, MR_MONTO, MR_DIR_IP, MR_NAV_SO, MR_TRANSACT_ID, MR_USER_AGENT,
					MR_TIPO_DOC, MR_NUM_DOC, MR_OBS_TX, MR_PAYEE_VALUE, MR_PAYER_VALUE, MR_PAYER_ACCOUNT_TYPE,
					MR_PAYEE_ACCOUNT_TYPE, MR_RIESGO_SAS, MR_NUMERO_TX, MR_REFERENCIA, MR_STATUS_ID_TIPO,
					MR_MOTIVO_ID_CONCEPTO, MR_TIPO, MR_NUM_CUENTA_DAVIVIENDA };

			return new String[] { TPT_MR_PN, nbArchivo };
		}

		case DatosDavivienda.CANAL_APP_EMPRESAS:
		case DatosDavivienda.CANAL_PYME_FRONT: {
			boolean esPyme = canal.equals(DatosDavivienda.CANAL_PYME_FRONT);
			this.nbApplication = esPyme ? "P_PYME" : "App Empresas";
			String nbArchivo = prefijo + (esPyme ? "_SetMR_Pyme.xlsx" : "_SetMR_AppEmpresas.xlsx");

			MR_NAV_SO = "Navegador / SO";
			this.rangoColumns = "1:35";
			// CORREGIDO: el arreglo original tenía MR_TIP_CTA_ORG duplicado dos veces
			// seguidas; se reemplaza la segunda ocurrencia por MR_PAYER_ACCOUNT_TYPE,
			// siguiendo el mismo patrón usado en el canal de Divisas (origen + destino +
			// payer + payee).
			this.nbParamsEsperados = new String[] { MR_ID_REG, MR_SESSION_ID, MR_FECHA, MR_HORA, MR_HASH,
					MR_USER_TYPE, MR_RISK, MR_POLICY_ACTION, MR_RIS_EFM, MR_ACTIVITY_NAME, MR_NB_TX, MR_RESULTADO,
					MR_TIP_CTA_ORG, MR_PAYER_ACCOUNT_TYPE, MR_TIP_CTA_DEST, MR_PAYEE_ACCOUNT_TYPE, MR_OBSERVACION,
					MR_NUM_RETOS, MR_MONTO, MR_MONTO, MR_OPERA_SYSTEM, MR_TRANSACT_ID, MR_USER_AGENT, MR_CLIENTE,
					MR_TIPO_DOC, MR_NUM_DOC, MR_NUM_ID_EMP, MR_NUM_TX, MR_NUM_CTA_ORIGEN, MR_NUM_CTA_ORIGEN_MIGRADA,
					MR_BANCO, MR_NUM_CTA_DESTINO, MR_REFERENCIA1 };

			return new String[] { TPT_MR_PJ, nbArchivo };
		}

		case DatosDavivienda.CANAL_PYME_FRONT_DIVISAS: {
			this.nbApplication = "Portal PYME";
			String nbArchivo = prefijo + "_SetMR_Pyme.xlsx";

			MR_NAV_SO = "Navegador / SO";
			this.rangoColumns = "1:35";
			this.nbParamsEsperados = new String[] { MR_ID_REG, MR_SESSION_ID, MR_FECHA, MR_HORA, MR_HASH,
					MR_USER_TYPE, MR_RISK, MR_ACTIVITY_NAME, MR_TIP_CTA_ORG, MR_TIP_CTA_DEST, MR_RESULTADO,
					MR_PAYER_ACCOUNT_TYPE, MR_PAYEE_ACCOUNT_TYPE, MR_NB_TX, MR_OBSERVACION, MR_NUM_RETOS, MR_MONTO,
					MR_DIR_IP, MR_OPERA_SYSTEM, MR_TRANSACT_ID, MR_USER_AGENT, MR_PYME_CLIENTE, MR_PYME_TIPO_DOC,
					MR_PYME_NUM_DOC, MR_NUM_CTA_ORIGEN_MIGRADA, MR_NUM_CTA_ORIGEN, MR_NUM_TX, MR_NUM_ID_EMP,
					MR_NUM_ID_EMP, MR_COD_CAUSAL_RECHA, MR_REFERENCIA1, MR_REFERENCIA_2 };

			return new String[] { TPT_MR_PJ_DIVISAS, nbArchivo };
		}

		default:
			return new String[] { null, null };
		}
	}

	private void cargarFilaNextRegistro() throws Exception {
		int rowNumber = PRIMERA_FILA_DATOS;
		while (!this.dataSheetMR.getParameterByRow(MR_ID_REG, rowNumber).trim().isEmpty()) {
			rowNumber++;
		}
		this.filaNextRegistro = rowNumber;
	}

	private void loadApplication() throws Exception {
		this.dataSheetMR.setValueByCell(1, 2, this.nbApplication);
	}

	// ── Diálogo de selección de archivo ──────────────────────────────────────

	public static String preguntarPorArchivoMR() {
		String[] opciones = { "NUEVO", "EXISTENTE" };
		int posOpc;
		do {
			posOpc = JOptionPane.showOptionDialog(null, "Archivo Motor de Riesgo...", "ARCHIVO MR", -1, 3, null,
					(Object[]) opciones, opciones[0]);
		} while (posOpc < 0);

		if (posOpc != 1) {
			return null;
		}

		JFileChooser fileChooser = new JFileChooser("C:\\");
		fileChooser.setApproveButtonText("Seleccionar");
		fileChooser.setDialogTitle("Archivo Motor de Riesgo");
		fileChooser.setFileSelectionMode(JFileChooser.FILES_ONLY);

		FileFilter filtro = new FileNameExtensionFilter("Archivos excel", "xls", "xlsx");
		fileChooser.setFileFilter(filtro);

		int seleccion = fileChooser.showOpenDialog(fileChooser);
		return seleccion == JFileChooser.APPROVE_OPTION ? fileChooser.getSelectedFile().getAbsolutePath() : null;
	}

	// ── Manejo de filas / registros ──────────────────────────────────────────

	public void setCurrentRow(int currentRow) throws Exception {
		if (currentRow >= this.filaNextRegistro) {
			throw new Exception(
					"MotorRiesgo ERROR -- No se puede poner como CurrentRow un valor >= " + this.filaNextRegistro);
		}
		this.currentRow = currentRow;
	}

	public int adicionarRegistro() throws Exception {
		if (this.dataSheetMR == null) {
			throw new Exception("MotorRiesgo ERROR -- No se ha cargado hoja de datos o se cerró");
		}

		this.tieneDatos = true;

		int numReg = 1;
		if (this.filaNextRegistro != PRIMERA_FILA_DATOS) {
			int filaLastReg = this.filaNextRegistro - 1;
			String numTemp = this.dataSheetMR.getParameterByRow(MR_ID_REG, filaLastReg);
			numReg += Integer.parseInt(numTemp);
			this.dataSheetMR.getExcelFile().copyCellStyle(String.valueOf(filaLastReg), this.rangoColumns,
					this.filaNextRegistro);
		}

		this.filaNextRegistro++;
		this.currentRow = this.filaNextRegistro - 1;
		this.dataSheetMR.setParameterByRow(MR_ID_REG, this.currentRow, numReg);
		return this.currentRow;
	}

	public int getRowRegistroMR(String[] nbParams, String[] values) throws Exception {
		int numParams = nbParams.length;

		for (int posRow = PRIMERA_FILA_DATOS; posRow < this.filaNextRegistro; posRow++) {
			boolean esRegistroLibre = this.dataSheetMR.getParameterByRow(MR_RESULTADO, posRow).trim().isEmpty();
			if (!esRegistroLibre) {
				continue;
			}

			if (!coincideRegistro(nbParams, values, posRow, numParams)) {
				continue;
			}

			if (!this.dicRowsCargados.containsKey(posRow)) {
				this.dicRowsCargados.put(posRow, posRow);
				return posRow;
			}
		}

		return 0;
	}

	private boolean coincideRegistro(String[] nbParams, String[] values, int posRow, int numParams) throws Exception {
		if (numParams == 0) {
			return false;
		}
		for (int posArr = 0; posArr < numParams; posArr++) {
			String valueMR = this.dataSheetMR.getParameterByRow(nbParams[posArr], posRow);
			if (!valueMR.equals(values[posArr])) {
				return false;
			}
		}
		return true;
	}

	public void cerrarMotorRiesgo() {
		this.dataSheetMR.liberarData();
		this.dataSheetMR = null;
		if (!this.tieneDatos) {
			Reporter.write("No se almacenaron datos, por ende se borra el archivo de MR");
			new File(this.nbArchivoMR).delete();
		}
	}

