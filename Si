	/**
	 * Versión interna de waitForElement que retorna WebElement (By).
	 * Usada en lugar del loop manual con Util.wait(2).
	 */
	private WebElement waitForElement(By locator, int maxAttempts, String elemento) {
		return fluentWaitForElement(locator, Math.max(maxAttempts, 1) * 2);
