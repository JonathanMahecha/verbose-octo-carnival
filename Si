}

private String[] ajustarTipoCuentaStratus(String tipoCta,
                                          String numCta) throws Exception {

    String tipo = tipoCta;
    String numero = numCta;

    if (tipo.toUpperCase().contains("DIPLUS")) {

        String[] datos = this.instanciaStratus.getCtaCobroCrediplus(numCta);

        tipo = datos[0];
        numero = datos[1];

        if (tipo.contains("AH")) {
            tipo = "CC";
        }

    } else if (tipo.contains("ompanita")
            || tipo.contains("emp pyme 22")) {

        tipo = "CREDITO";
    }

    return new String[]{tipo, numero};
}

private void procesarSaldosStratus(String tipoCta,
                                   String[] saldos,
                                   boolean saldoOrigen) {

    String saldoTotal;
    String saldoDisponible;

    if (tipoCta.contains("ahorro") || tipoCta.contains("AH")) {

        saldoTotal = saldos[0].replace("$ ", "");
        saldoDisponible = saldos[1].replace("$ ", "");

    } else if (tipoCta.contains("corriente") || tipoCta.contains("CC")) {

        saldoTotal = saldos[6].replace("$ ", "");
        saldoDisponible = saldos[0].replace("$ ", "");

    } else if (tipoCta.contains("CREDITO")) {

        saldoTotal = saldos[7].replace("$ ", "");
        saldoDisponible = saldos[2].replace("$ ", "");

    } else {

        saldoTotal = saldos[1].replace("$ ", "");
        saldoDisponible = saldos[0].replace("$ ", "");
    }

    if (saldoOrigen) {

        saldoTotalInicial = saldoTotal;
        saldoDispoInicial = saldoDisponible;

    } else {

        saldoTotalFinal = saldoTotal;
        saldoDispoFinal = saldoDisponible;
    }

    Reporter.reportEvent(
            5,
            (saldoOrigen ? "Saldo inicial: " : "Saldo final: ")
                    + saldoDisponible.replace(".", ",")
    );
}

private void validarCorrespondenciaSaldo(String tipoCta,
                                         String saldoDisponiblePortal,
                                         String saldoPortal,
                                         List<String> saldosCredi,
                                         String numCta) {

    if (!tipoCta.contains("CREDITO")) {

        if (saldoTotalInicial.contains(saldoDisponiblePortal)) {

            Reporter.reportEvent(
                    5,
                    "Saldo portal corresponde con Stratus: " + saldoPortal
            );

        } else {

            Reporter.reportEvent(
                    5,
                    "Saldo portal NO corresponde con Stratus: " + saldoPortal
            );
        }

        return;
    }

    double sumaCredi = 0;

    for (String saldo : saldosCredi) {
        sumaCredi += Double.parseDouble(saldo);
    }

    Reporter.reportEvent(
            5,
            "Saldo Crediexpress acumulado cuenta "
                    + numCta
                    + ": "
                    + BigDecimal.valueOf(sumaCredi)
    );
}
public void NotaDebitoAdenda(String descripcion,
                             String detalleVacio) throws Exception {

    boolean multiproceso = descripcion.equals("Descuento por Pago a Proveedores")
            || descripcion.equals("Descuento para pago de Nomina");

    int totalIteraciones = obtenerCantidadIteracionesAdenda(multiproceso);

    for (int i = 1; i <= totalIteraciones; i++) {

        abrirModuloAdenda();

        boolean encontrado = buscarYProcesarRegistroAdenda(
                descripcion,
                detalleVacio,
                i
        );

        if (!encontrado) {

            Reporter.reportEvent(
                    1,
                    "No se encuentra el registro de la transacción"
            );

            this.pagePortalPymes.terminarIteracion();
            return;
        }

        click(By.xpath("//*[@id=\"cphCuerpo_btnVolver\"]"));
    }
}

private int obtenerCantidadIteracionesAdenda(boolean multiproceso) {

    if (!multiproceso) {
        return 1;
    }

    String filas = SettingsRun.getTestData()
            .getParameter("Filas a Tomar")
            .trim();

    String[] partes = filas.split(" ");

    int inicio = Integer.parseInt(partes[0]);
    int fin = Integer.parseInt(partes[2]);

    return (fin - inicio) + 1;
}

private void abrirModuloAdenda() throws Exception {

    waitForElement(this.btnDatosAdenda, TIMEOUT_MEDIO);

    click(this.btnDatosAdenda);

    waitForElement(this.tableAdenda, TIMEOUT_MEDIO);

    Util.wait(4);

    Evidence.saveAllScreens("Adenda", this);
}

private boolean buscarYProcesarRegistroAdenda(String descripcion,
                                              String detalleVacio,
                                              int filaInicial) throws Exception {

    for (int offset = 0; offset < 3; offset++) {

        int filaReal = filaInicial + offset;

        String xpathRegistro = construirXpathRegistroAdenda(
                descripcion,
                filaReal
        );

        if (element(By.xpath(xpathRegistro)) != null) {

            procesarRegistroAdenda(
                    xpathRegistro,
                    detalleVacio,
                    filaReal
            );

            return true;
        }
    }

    return false;
}

private String construirXpathRegistroAdenda(String descripcion,
                                            int fila) {

    return "(//*[@id=\"cphCuerpo_gvMovimientosCuentas\"]/tbody/tr[" 
            + fila
            + "]/td/span[contains(text(), '"
            + descripcion
            + "')])[1]";
}

private void procesarRegistroAdenda(String xpathRegistro,
                                    String detalleVacio,
                                    int fila) throws Exception {

    String xpathLink = xpathRegistro
            .replace("td/span", "td[4]/a")
            .replace(")[1]", "")
            .replace("(", "");

    String xpathData = xpathLink
            .replace("td[4]/a", "td[3]");

    WebElement dataElement = element(By.xpath(xpathData));

    if (dataElement != null) {

        String data = dataElement.getText();

        Reporter.reportEvent(
                0,
                ".........." + data + "..........."
        );
    }

    Util.wait(2);

    click(element(xpathLink));

    Util.wait(4);

    NotaDebitoDetalleReferencia(detalleVacio);
}

