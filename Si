import java.awt.Robot;
import java.awt.event.KeyEvent;

public static void presionarTecla(String tecla) throws Exception {
    presionarTecla(tecla, 1);
}

public static void presionarTecla(String tecla, int veces) throws Exception {

    Robot robot = new Robot();

    int keyCode;

    switch (tecla.toUpperCase()) {
        case "TAB":
            keyCode = KeyEvent.VK_TAB;
            break;
        case "ENTER":
            keyCode = KeyEvent.VK_ENTER;
            break;
        case "ESC":
            keyCode = KeyEvent.VK_ESCAPE;
            break;
        case "SPACE":
            keyCode = KeyEvent.VK_SPACE;
            break;
        case "UP":
            keyCode = KeyEvent.VK_UP;
            break;
        case "DOWN":
            keyCode = KeyEvent.VK_DOWN;
            break;
        case "LEFT":
            keyCode = KeyEvent.VK_LEFT;
            break;
        case "RIGHT":
            keyCode = KeyEvent.VK_RIGHT;
            break;
        default:
            throw new IllegalArgumentException("Tecla no soportada: " + tecla);
    }

    for (int i = 0; i < veces; i++) {
        robot.keyPress(keyCode);
        robot.keyRelease(keyCode);
    }
}
