    /**
     * Determina el código de transacción para el Motor de Riesgo.
     *
     * @param tipoPrueba tipo de prueba activo
     * @param servicio   nombre del servicio
     */
    public String getTransaccion(String tipoPrueba, String servicio) throws Exception {
        if (TP_PEND_APR.equals(tipoPrueba)) {
            if ("Retiro sin Tarjeta".equals(servicio)) return MotorRiesgo.TX_PYM_APROB_RET;
            return MotorRiesgo.TX_EMP_APROB_TX;
        }

        if (TP_EN_LINEA.equals(tipoPrueba)) {
            return determinarTransaccionPorServicio(servicio);
        }

        return tipoPrueba;
    }

    private String determinarTransaccionPorServicio(String svc) {
        switch (svc) {
            case "Nómina":
            case "Pago de Nóminas":                return MotorRiesgo.TX_EMP_PAGO_NOMI;
            case "Pago a Proveedores":
            case "Proveedores":                    return MotorRiesgo.TX_EMP_PAGO_PROV;
            case "Pago de Servicios":
            case "Servicios":                      return MotorRiesgo.TX_EMP_PAGO_SERVIC;
            case "Transferencia NIT Propio":
            case "Mismo NIT":                      return MotorRiesgo.TX_EMP_TF_MISMONIT;
            case "Transferencias Cuenta Inscrita":
            case "Cuenta Inscrita":                return MotorRiesgo.TX_EMP_TF_TERCEROS;
            case "Transferencias Cuenta No Inscrita":
            case "Cuenta No Inscrita":             return MotorRiesgo.TX_EMP_TF_CTANO;
            case "Tx Internacionales Enviar al exterior":
                return MotorRiesgo.TX_PYM_ENVIAR_AL_EXTERIOR;
            case "Tx Internacionales Recibir desde el exterior":
                return MotorRiesgo.TX_PYM_RECIBIR_DESDE_EL_EXTERIOR;
            default:                               return svc;
        }
    }

    /** Normaliza el tipo de producto para reportes y UI. */
    public String TipoProd(String tipoProdUpper) {
        String lower = tipoProdUpper.toLowerCase();
        if (lower.contains("ahorro"))                        return "Cuenta Ahorros";
        if (lower.contains("corriente"))                     return "Cuenta Corriente";
        if (lower.contains("crédito") || lower.contains("credito")) return "Tarjeta Crédito";
        return "No Aplica";
    }

    // =========================================================================
    // VENTANA EMERGENTE
    // =========================================================================

    /**
     * Cambia el foco del WebDriver a la ventana principal del portal,
     * cerrando cualquier popup de notas si estuviera abierto.
     *
     * @return {@code true} si el cambio fue exitoso
     */
    private boolean cambiarAVentanaEmergente() throws Exception {
        Util.wait(5);

        List<String> ventanas = new ArrayList<>(loginFrontPyme.getDriver().getWindowHandles());

        if (ventanas.size() < 2) {
            fail("No se abrió la segunda pestaña");
            SettingsRun.exitTestIteration();
            return false;
        }

        // Con más de 2 ventanas: cerrar las que no tienen el selector de empresa
        if (ventanas.size() > 2) {
            for (String handle : ventanas) {
                Util.wait(2);
                info(handle);
                loginFrontPyme.getDriver().switchTo().window(handle);
                WebElement empresa = loginFrontPyme.element(
                        By.xpath("//select[@id='dropMasterEmpresa']"));

                if (!loginFrontPyme.isDisplayed(empresa)) {
                    loginFrontPyme.getDriver().close();
                }
                // Continuar iterando hasta revisar todas las ventanas
            }
            // Tras el bucle, enfocarse en la ventana que quedó abierta
            List<String> restantes = new ArrayList<>(loginFrontPyme.getDriver().getWindowHandles());
            if (!restantes.isEmpty()) {
                loginFrontPyme.getDriver().switchTo().window(restantes.get(0));
            }
            return true;
        }

        // Caso normal: 2 ventanas — cerrar la primera y quedarse con la segunda
        String primeraVentana  = ventanas.get(0);
        String segundaVentana  = ventanas.get(1);
        Reporter.write("Primera ventana: " + primeraVentana
                + " || Segunda ventana: " + segundaVentana);

        loginFrontPyme.getDriver().switchTo().window(primeraVentana);
        Util.wait(2);
        loginFrontPyme.getDriver().close();
        loginFrontPyme.getDriver().switchTo().window(segundaVentana);
        return true;
    }

