    private void procesarLugarGenerico(String datoLugar, By btnAceptar) throws Exception {
        WebElement btonIr = element(btnIr);
        if (btonIr != null) {
            btonIr.click();
        }
        waitSeconds(2);

        if (isEnabled(tabla)) {
            int columnas = getColumnCount(tabla, 2);
            int filas = getRowCount(tabla);

            if (columnas == 0) {
                manejarLugarNoEncontrado(datoLugar);
            } else {
                buscarYSeleccionarLugar(datoLugar, columnas, filas, btnAceptar);
            }
        }
    }

    private void manejarLugarNoEncontrado(String datoLugar) throws Exception {
        safeClick(btnCancelar);
        cancelarCreacion();
        irAModulo(MOD_PAGINA_INICIAL);
        waitSeconds(1);
        irAModulo(MOD_PERSONAS);
        Reporter.reportEvent(Reporter.MIC_NOEXEC, "[ERROR DATA] El lugar: " + datoLugar + ", no se encontró");
        SettingsRun.exitTestIteration();
    }

    private void buscarYSeleccionarLugar(String datoLugar, int columnas, int filas, By btnAceptar) {
        boolean encontrado = false;

        for (int i = 2; i <= columnas && !encontrado; i++) {
            for (int j = 2; j <= filas && !encontrado; j++) {
                String datoComparar = getCellValue(tabla, j, i);
                if (datoComparar != null && datoComparar.contains(datoLugar)) {
                    By select = By.xpath("//*[@summary='Seleccionar Centro Poblado']/tbody/tr[" + j + "]/td[" + i + "]");
                    safeClick(select);

                    waitForElementWithTimeout(btnAceptar, -1);
                    safeClick(btnAceptar);
                    encontrado = true;
                }
            }
        }
    }

