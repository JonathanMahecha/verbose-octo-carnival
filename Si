public String waitElements(int maxTime, WebElement... elements) {
    try {
        WebDriverWait wait = new WebDriverWait(driver, Duration.ofSeconds(maxTime));

        wait.until(driver -> {
            for (WebElement element : elements) {
                try {
                    if (element.isDisplayed()) {
                        return true;
                    }
                } catch (Exception e) {
                    // Ignorar mientras el elemento no exista
                }
            }
            return false;
        });

        return null;

    } catch (TimeoutException e) {
        String msgError = "Tiempo de espera máximo [" + maxTime + " Seg] fue superado.";
        Reporter.write("*** FAILED - " + msgError);
        return msgError;
    }
}
