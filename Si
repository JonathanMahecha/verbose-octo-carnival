    /**
     * Aprueba una transacción pendiente cuyo número está en "Número Aprobación".
     *
     * @param desdeDetalle {@code true} para aprobar desde el detalle;
     *                     {@code false} para aprobar desde la caja de lista.
     */
    public void aprobarTxPendiente(boolean desdeDetalle) throws Exception {
        Util.wait(10);

        String pagoyTx   = this.pagePortalPymes.getTextMid();
        String navegador = SettingsRun.getTestData().getParameter("Navegador").trim();
        String seccion   = resolverSeccionMenu(pagoyTx);

        String msgError = navegador.contains("CHROME")
                ? pagePortalPymes.irAOpcion("Transacciones Pendientes de Firmas", seccion, "Pendientes de Aprobación")
                : pagePortalPymes.irAOpcionMoZilla(
                        "Transacciones Pendientes de Firmas", seccion, "Pendientes de Aprobación", null, null);

        if (msgError != null) this.terminarIteracionXError(msgError);

        int numRetosFalla = resolverNumRetosFallidos();

        if (desdeDetalle) {
            msgError = pagePendApr.entrarDetalleTx(this.numeroTx);
            if (msgError != null) this.terminarIteracionXError(msgError);
        } else {
            pagePendApr.seleccionarTransaccion(this.numeroTx);
            pageConf.setNbButtonAprobar("Aprobar Transacciones Seleccionadas");
        }

        String msgRta = pageConf.aprobarTx(numRetosFalla, desdeDetalle);

        if (DatosDavivienda.IS_RISKMOTOR) {
            this.estadoTx = msgRta;
            this.SetEstado(msgRta);

            if (Util.itemContainsAnyArrayItem(msgRta, arrMsgBuscarEstado)) {
                this.estadoTx = "Transferencia Realizada";
                Reporter.reportEvent(Reporter.MIC_INFO, msgRta);
            } else if (Util.itemContainsAnyArrayItem(msgRta, this.arrMsgTxDeclinada)) {
                Reporter.reportEvent(Reporter.MIC_INFO, msgRta);
                this.estadoTx = "DECLINADA";

                this.valorTx    = pageConf.getValorFinalTx();
                this.bancoDesTx = pageConf.getBancoDesTx();
                if (this.bancoDesTx != null) SetBancoDesTx(this.bancoDesTx);
                if (this.valorTx  != null) SetActivityAmount(this.valorTx.replace("$", "").replace(" ", ""));

                this.numeroTx = pageConf.getNumeroDocumento();
                if (this.numeroTx != null
                        && (this.servicio.contains("Nómina") || this.servicio.contains("Pago a Proveedores"))
                        && pagePortalPymes.CuentaDesMotor() != null) {
                    this.cuentasDesMotor = pagePortalPymes.CuentaDesMotor();
                }

                if (esDestinoMasivo())
                    this.validarIngresoMRDestinosMasivo();
                else
                    this.validarIngresoMR();

                this.pagePortalPymes.terminarIteracion();
            }
        }

        if (!msgRta.contains(PageConfirmacion.MSG_EXITO_PAGO)
                && !msgRta.contains(PageConfirmacion.MSG_EXITO_GUARD)
                && !msgRta.contains(PageConfirmacion.MSG_EXITO_ENV_OTP)
                && !msgRta.contains(PageConfirmacion.MSG_EXITO_APROB))
            this.terminarIteracionXError(msgRta);
    }

