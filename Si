public void setTelefono(String tipo, String telefono, String ciudad, String clase) throws Exception {
    boolean isPersonaNatural = tipo != null && tipo.contains("Persona Natural");

    if (isPersonaNatural) {
        procesarTelefonoPersonaNatural(telefono, ciudad);
    } else {
        procesarTelefonoEmpresa(tipo, telefono, ciudad, clase);
    }

    finalizarConfiguracionTelefono();
}

private void procesarTelefonoPersonaNatural(String telefono, String ciudad) throws Exception {
    safeClick(iconoTelefonoPersonas);

    WebElement btnNuevo = waitForElement(btnNuevoTelefonoPer, 15, "");
    if (btnNuevo == null) {
        return;
    }

    safeClick(btnNuevoTelefonoPer);
    changeToDefaultFrame();

    WebElement popup = waitForElement(locPopUpGeneral, 3, "");
    if (popup == null) {
        return;
    }

    waitSeconds(1);
    configurarCiudadTelefonoPersona(ciudad);
    completarTelefonoPersonaNatural(telefono, ciudad);
}

private void configurarCiudadTelefonoPersona(String ciudad) {
    By celda = By.xpath(
            "(//tr[@class='ui-widget-content jqgrow ui-row-ltr ui-state-highlight selected-row ui-state-hover'])[2]//td[5]");

    WebElement celdaCiudad = element(celda);
    if (celdaCiudad != null) {
        safeClick(celdaCiudad);
    }

    write(inputCiudadTelefonoPer, ciudad);

    WebElement celdaTelefono = element(tdTelefonoPer);
    if (celdaTelefono != null) {
        safeClick(tdTelefonoPer);
    }

    waitSeconds(1);

    if (element(btnSiguientePersonas) != null) {
        procesarSiguienteYAceptarCiudad();
    }
}

private void completarTelefonoPersonaNatural(String telefono, String ciudad) {
    String ciudadNormalizada = normalizarCiudad(ciudad);

    By botonBuscarCiudad = By.xpath("//span[@class='siebui-icon-pick']");
    By inputBuscar = By.xpath("//input[@aria-label='Buscar']");
    By inputCiudad = By.xpath("(//span[@class='siebui-popup-button']//input[@type='text'])[2]");
    By btnIrCiudad = By.xpath("(//button[@title='Seleccionar Centro Poblado Lista:Ir'])[2]");
    By btnAceptarCiudad = By.xpath("//button[@title='Seleccionar Centro Poblado Lista:Aceptar']");
    By celdaTelefono = By.xpath("(//td[contains(@id,'Telephone')])[2]");
    By inputTelefono = By.xpath("//td[contains(@id,'Telephone')]//input");

    safeClick(botonBuscarCiudad);
    waitForElement(inputBuscar, 5);
    clearInputbox(inputBuscar);
    write(inputBuscar, "Ciudad");
    waitSeconds(1);

    write(inputCiudad, ciudadNormalizada);
    waitSeconds(1);

    safeClick(btnIrCiudad);
    waitSeconds(1);

    safeClick(btnAceptarCiudad);
    waitSeconds(1);

    safeClick(celdaTelefono);
    waitSeconds(1);

    write(inputTelefono, telefono);
    waitSeconds(1);

    if (element(btnAceptarTelefonoPer) != null) {
        safeClick(btnAceptarTelefonoPer);
    }

    if (existDialog()) {
        acceptDialog();
    }

    if (element(btnSiguientePersonas) != null && isDisplayed(btnSiguientePersonas)) {
        procesarSiguienteYAceptarCiudad();
    }
}

private void procesarTelefonoEmpresa(String tipo, String telefono, String ciudad, String clase) throws Exception {
    safeClick(iconoTelefonoEmpresas);

    WebElement btnNuevo = waitForElement(btnNuevoTelefonoEmp, 15, "");
    if (btnNuevo == null) {
        return;
    }

    safeClick(btnNuevoTelefonoEmp);
    changeToDefaultFrame();

    WebElement popup = waitForElement(locPopUpGeneral, 3, "");
    if (popup == null) {
        return;
    }

    WebElement ciudadTelefono = waitForElement(tdCuidadTelefonoEmp, 10, "");
    if (ciudadTelefono == null) {
        return;
    }

    escribirDatosTelefonoEmpresa(tipo, telefono, clase);
    configurarCiudadTelefonoEmpresa(ciudad);
}

private void escribirDatosTelefonoEmpresa(String tipo, String telefono, String clase) {
    if (tipo != null && tipo.contains("Persona Natural")) {
        waitSeconds(1);
        safeClick(tdTelefonoEmp);
        write(inputTelefonoEmp, telefono);
        waitSeconds(1);
        return;
    }

    if (tipo != null && tipo.contains("Persona Juridica")) {
        waitSeconds(1);
        safeClick(tdTelefonoEmpresas);
        write(inputTelefonoEmpresas, telefono);

        safeClick(tdClaseTelefonoEmpresas);
        write(inputClaseTelefonoEmpresas, clase);
        waitSeconds(1);
    }
}

private void configurarCiudadTelefonoEmpresa(String ciudad) {
    safeClick(tdCuidadTelefonoEmp);
    safeClick(By.xpath("//*[@id='s_3_2_215_0_icon']"));

    WebElement typeCity = waitForElement(typeCityPhone, 10, "");
    if (typeCity == null) {
        return;
    }

    clearInputbox(typeCityPhone);
    waitSeconds(1);
    write(typeCityPhone, "Ciudad");
    waitSeconds(1);

    clearInputbox(CityPhone);
    waitSeconds(1);
    write(CityPhone, ciudad);
    waitSeconds(1);

    safeClick(btnCityPhone);
    waitSeconds(1);

    safeClick(acceptCityPhone);
    waitSeconds(1);
}

private void procesarSiguienteYAceptarCiudad() {
    safeClick(btnSiguientePersonas);
    waitSeconds(2);

    if (element(tituloTablaCiudad) != null && element(btnAceptarCiudadTelefonoPer) != null) {
        WebElement btnAceptar = waitForElement(btnAceptarCiudadTelefonoPer, 10, "");
        if (btnAceptar != null) {
            safeClick(btnAceptarCiudadTelefonoPer);
        }
    }
}

private void finalizarConfiguracionTelefono() {
    waitSeconds(2);

    if (element(btnAceptarTelefonoPer) != null) {
        safeClick(btnAceptarTelefonoPer);
    }

    if (existDialog()) {
        acceptDialog();
    }
}

private String normalizarCiudad(String ciudad) {
    if (ciudad == null) {
        return "";
    }

    String valor = ciudad.trim().toUpperCase();
    if (valor.contains("BOGOTA")) {
        return "bogota";
    }
    return valor.toLowerCase();
}
