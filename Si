    // =========================================================================

    private void configurarParametrosGeneralesPyme() throws Exception {
        String numAprob  = param("Números de Aprobaciones");
        String idUsuario = param("Id usuario");

        if (idUsuario.equals(lastIdusuario)
                && this.nombreEmpre.equals(lastempresa)
                && numAprob.equals(lastNumAprobaciones)) {
            return;
        }

        pageAdminParametros = new PageAdminParametros1(loginFrontPyme);
        String msgError = pageAdminParametros.hacerConfiguracion(numAprob, "", "");

        if (msgError != null && !msgError.contains("exitosa")) {
            terminarConError(msgError);
            throw new Exception("Configuración de parámetros generales fallida: " + msgError);
        }

        lastNumAprobaciones = numAprob;
        lastIdusuario       = idUsuario;
        lastempresa         = this.nombreEmpre;
    }

