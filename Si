            new String[]{"lblMasterAlerta"}
    );

    if (msgError != null) {
        return "Error en lista 'Servicio a pagar' : " + msgError;
    }

    msgError = seleccionarOrigenAutomatico(
            tipoProducto,
            numeroProducto,
            "1"
    );

    Util.wait(2);

    if (!tipoProductoSec.isEmpty() && !numeroProductoSec.isEmpty()) {

        msgError = seleccionarOrigenAutomatico(
                tipoProductoSec,
                numeroProductoSec,
                "2"
        );
    }

    click(this.locButtonSig);

    return msgError;
